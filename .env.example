# ==============================================
# Chirag Singhal — Personal Website Environment
# ==============================================
# Copy this to .env and fill in the values.
# All keys prefixed with VITE_ are exposed to client.
# Keys WITHOUT VITE_ are server/build-time only (safe).
# ==============================================

# --- Firebase (Client-Side) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- EmailJS (Client-Side, for unknown query alerts) ---
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Movies & TV (Build-Time Only) ---
# Trakt: https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
# TMDB: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# --- Music (Build-Time Only) ---
# Last.fm: https://www.last.fm/api/account/create
LASTFM_API_KEY=
# Spotify: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- Gaming (Build-Time Only) ---
# Steam: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
STEAM_USER_ID=

# --- Coding & Developer (Build-Time Only) ---
# GitHub: https://github.com/settings/tokens (optional, higher rate limit)
GITHUB_TOKEN=
# WakaTime: https://wakatime.com/settings/api-key
WAKATIME_API_KEY=
# Dev.to: https://dev.to/settings/extensions (optional)
DEVTO_API_KEY=

# --- Social (Build-Time Only) ---
# Bluesky: Settings → App Passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# YouTube: https://console.cloud.google.com
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
