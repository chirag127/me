# ==============================================
#  Chirag Singhal — chirag127.in
#  Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
#
# VITE_ prefix = exposed to browser (client-side)
# No prefix   = build-time only (safe in GH Secrets)
# ==============================================
# Cloudflare (Global API Key used for GitHub Actions)
# 1. Go to Cloudflare Dashboard -> My Profile -> API Tokens
# 2. View "Global API Key" 
# 3. Add to GitHub Secrets as CLOUDFLARE_GLOBAL_API_KEY
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_ORIGIN_CA_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ACCOUNT_ID=

# ── Firebase (Client-Side) ─────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Select your project → Settings → General
# 3. Scroll to "Your apps" → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (Build-Time / Node.js) ────────
# Note: These are required in GitHub Secrets for 
# data fetching / server-side logic.
# 1. Go to https://console.firebase.google.com -> Project Settings
# 2. Go to the "Service accounts" tab
# 3. Click "Generate new private key". A JSON file will download.
# 4. Open the JSON file and copy the exact values for:
#    - project_id -> FIREBASE_PROJECT_ID
#    - client_email -> FIREBASE_CLIENT_EMAIL
#    - private_key -> FIREBASE_PRIVATE_KEY
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ── EmailJS (Client-Side, unknown query alerts) ─
# 1. Go to https://www.emailjs.com/ → Sign Up free
# 2. Dashboard → Email Services → Add Service
#    → Connect Gmail (whyiswhen@gmail.com)
#    → Copy Service ID
# 3. Dashboard → Email Templates → Create Template
#    → Subject: "Unknown Query Alert: {{query}}"
#    → Body: "Query: {{query}}\nUser: {{user}}\n
#            Time: {{time}}\nSession: {{sessionId}}"
#    → Copy Template ID
# 4. Dashboard → Account → API Keys → Copy Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=


# ── Trakt (Build-Time) ────────────────────────
# 1. Go to https://trakt.tv/oauth/applications
# 2. Click "New Application"
#    → Name: "chirag127-portfolio"
#    → Redirect URI: urn:ietf:wg:oauth:2.0:oob
# 3. Copy "Client ID" (NOT client secret)
TRAKT_CLIENT_ID=


# ── TMDB (Build-Time, movie posters) ──────────
# 1. Go to https://www.themoviedb.org/signup
# 2. Settings → API → Request API Key (free)
# 3. Copy "API Key (v3 auth)"
TMDB_API_KEY=


# ── Last.fm (Build-Time) ─────────────────────
# 1. Go to https://www.last.fm/api/account/create
# 2. Fill in app name: "chirag127-portfolio"
# 3. Copy "API Key"
LASTFM_API_KEY=


# ── Spotify (Build-Time) ─────────────────────
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create App → Redirect URI: http://localhost:3000
# 3. Copy Client ID & Client Secret
# 4. Get refresh_token via OAuth flow:
#    → Visit: https://accounts.spotify.com/authorize?
#      client_id=YOUR_ID&response_type=code&
#      redirect_uri=http://localhost:3000&
#      scope=user-top-read+user-read-recently-played
#    → Copy the ?code= from redirect URL
#    → curl -X POST https://accounts.spotify.com/api/
#      token -d grant_type=authorization_code
#      -d code=YOUR_CODE
#      -d redirect_uri=http://localhost:3000
#      -H "Authorization: Basic BASE64(id:secret)"
#    → Copy refresh_token from response
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=


# ── Steam (Build-Time) ──────────────────────
# 1. Go to https://steamcommunity.com/dev/apikey
# 2. Enter domain: chirag127.in
# 3. Copy API Key
# 4. Find Steam ID: go to your Steam profile →
#    right-click → "Copy Page URL" → the number
#    in the URL is your Steam ID (76561198...)
STEAM_API_KEY=
STEAM_USER_ID=


# ── GitHub (Build-Time, optional higher rate) ─
# 1. Go to https://github.com/settings/tokens
# 2. Generate new token (classic)
#    → Scopes: public_repo, read:user
# 3. Copy token
GITHUB_TOKEN=
GH_PAT=
GH_USERNAME=

# ── WakaTime (Build-Time) ───────────────────
# 1. Go to https://wakatime.com/settings/api-key
# 2. Copy "Secret API Key"
# NOTE: To share stats publicly, also create an
# embeddable chart at https://wakatime.com/share
# and copy the JSON embed URL:
WAKATIME_API_KEY=
WAKATIME_EMBED_JSON_URL=


# ── Dev.to (Build-Time, optional) ────────────
# 1. Go to https://dev.to/settings/extensions
# 2. Generate API Key
DEVTO_API_KEY=


# ── Bluesky (Build-Time) ─────────────────────
# 1. Go to Settings → App Passwords → Add App
#    Password → Name: "portfolio"
# 2. Copy the generated password
BLUESKY_HANDLE=chirag127.bsky.social
BLUESKY_APP_PASSWORD=


# ── YouTube (Build-Time, optional) ────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable YouTube Data API v3
# 3. Credentials → Create API Key
# 4. Find your channel ID from YouTube Studio
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=


# ── MULTI-PLATFORM DEPLOYMENT ───────────────────
# Note: These are required in GitHub Secrets for 
# the 'deploy-all.yml' workflow.
# ────────────────────────────────────────────────

# Cloudflare Pages
# 1. API Token: Dashboard -> My Profile -> API Tokens -> Create (Pages Edit)
# 2. Account ID: Dashboard -> Workers & Pages -> Overview (Right sidebar)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Surge.sh
# 1. install surge: npm install -g surge
# 2. run: surge token (copy the token)
# 3. email: your surge account email
SURGE_LOGIN=
SURGE_TOKEN=

# Firebase Hosting
# 1. run: firebase login:ci
# 2. copy the generated token
FIREBASE_TOKEN=

# Neocities / Reocities
# 1. Go to https://neocities.org/settings#api_key
# 2. Copy the API key
NEOCITIES_API_KEY=

# Nekoweb
# 1. Go to https://nekoweb.org/dashboard/settings
# 2. Generate and copy API Key
NEKOWEB_API_KEY=

# Sourcehut Pages
# 1. Go to https://meta.sr.ht/oauth
# 2. Create personal access token with 'pages:write'
SOURCEHUT_TOKEN=

# AppWrite (Static Hosting)
# 1. Dashboard -> Project -> Settings -> Project ID
# 2. API Key: Project -> API Keys -> Create (hosting scope)
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# BitBucket / Codeberg / Sourcehut (SSH)
# For platforms requiring git push over SSH:
# 1. Generate SSH key: ssh-keygen -t ed25519 -C "chirag"
# 2. Add public key to the platform settings
# 3. Add private key to GitHub Secrets as SSH_PRIVATE_KEY
SSH_PRIVATE_KEY=

# pages.gay
# Usually managed via GitHub Action integration.
# Use your GitHub PAT (GITHUB_TOKEN) for this.
PAGES_GAY_TOKEN=
