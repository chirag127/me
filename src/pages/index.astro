---
import { experience, honors, projects, summary } from '../data/resume';
import {
  fetchBlogPosts,
  fetchDevToArticles,
  fetchGitHubRepos,
  fetchGitHubUser,
  fetchLeetCodeStats,
} from '../lib/api/index';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CommandPalette from '../components/CommandPalette.astro';
import HeroChatButton from '../components/islands/HeroChatButton';
import Footer from '../components/Footer.astro';

const [, githubRepos, leetcodeStats, devtoArticles] =
  await Promise.all([
    fetchGitHubUser(),
    fetchGitHubRepos(),
    fetchLeetCodeStats(),
    fetchDevToArticles(),
    fetchBlogPosts(),
  ]);

const totalStars = githubRepos.reduce(
  (sum: number, r: any) => sum + (r.stargazers_count || 0),
  0,
);
const recentArticles = devtoArticles.slice(0, 3);
const featuredProjects = projects.filter((p) => p.featured);
const activeRole = experience[0];
---

<Layout title="Chirag Singhal — Software Engineer" description={summary.substring(0, 155) + '...'}>
  <Navbar />
  <CommandPalette />

  <main class="relative pb-24">
    <!-- ═══ HERO ═══ -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <!-- Ambient light -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-20%] right-[-10%] w-[800px] h-[600px] bg-[var(--color-primary)]/10 rounded-[100%] blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] bg-[var(--color-accent-violet)]/10 rounded-[100%] blur-[120px]"></div>
        <!-- Grid pattern -->
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <div class="will-animate animate-fade-in inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-semibold text-[var(--color-primary-light)] uppercase tracking-wider mb-8">
            <span class="h-2 w-2 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
            {activeRole.title} @ {activeRole.company}
          </div>

          <h1 class="will-animate animate-slide-up text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter mb-8 leading-[1.1]" style="font-family: 'Outfit', sans-serif;">
            Building scalable <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-primary-light)] to-[var(--color-accent-violet)]">backend systems</span> <br/>
            & intelligent APIs.
          </h1>

          <p class="will-animate animate-slide-up delay-200 text-lg sm:text-xl text-white/50 max-w-2xl font-medium leading-relaxed mb-10" set:html={summary.split('. ').slice(0, 2).join('. ') + '.'} />

          <div class="will-animate animate-slide-up delay-300 flex flex-wrap items-center gap-4">
            <a href="/work" class="px-8 py-3.5 rounded-xl bg-white text-black font-semibold hover:bg-white/90 transition-colors">
              View Work
            </a>
            <HeroChatButton client:load />
            <div class="flex items-center gap-4 ml-4 text-white/40">
              <a href="https://github.com/chirag127" target="_blank" class="hover:text-white transition-colors">
                <span class="sr-only">GitHub</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              </a>
              <a href="https://linkedin.com/in/chirag127" target="_blank" class="hover:text-[var(--color-primary-light)] transition-colors">
                <span class="sr-only">LinkedIn</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 space-y-24">
      
      <!-- ═══ EXPERIENCE & EDUCATION ═══ -->
      <section class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="glass p-8 rounded-2xl">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="h-5 w-5 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Current Role
          </h2>
          <div class="relative pl-5 border-l border-white/10">
            <div class="absolute -left-[5px] top-1.5 h-2 w-2 rounded-full bg-[var(--color-primary)] shadow-[0_0_10px_var(--color-primary)]"></div>
            <h3 class="font-bold text-white text-lg">{activeRole.title}</h3>
            <p class="text-[var(--color-primary-light)] text-sm mb-3">{activeRole.company} · {activeRole.date}</p>
            <p class="text-white/50 text-sm leading-relaxed mb-4">
              {activeRole.items[0]}
            </p>
            <a href="/work" class="text-xs font-semibold text-white/40 hover:text-white transition-colors group">
              View full resume <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <div class="glass p-8 rounded-2xl">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
            Background
          </h2>
          <div class="space-y-4">
            <div class="p-4 rounded-xl bg-white/5 border border-white/5">
              <h3 class="font-bold text-white text-sm mb-1">{honors[0].title}</h3>
              <p class="text-[var(--color-primary-light)] text-xs">{honors[0].description}</p>
              <p class="text-white/30 text-[10px] mt-1">{honors[0].year}</p>
            </div>
            <div class="p-4 rounded-xl bg-white/5 border border-white/5">
              <h3 class="font-bold text-white text-sm mb-1">Honors & Awards</h3>
              <p class="text-white/50 text-xs">Won multiple hackathons including Smart India Hackathon finalist.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ KEY STATS ═══ -->
      <section class="max-w-6xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
          <span class="h-8 w-1 bg-[var(--color-primary)] rounded-full"></span>
          Ecosystem Reach
        </h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="glass p-6 rounded-2xl group hover:border-[var(--color-primary)]/30 transition-all">
            <div class="text-white/40 text-xs font-bold uppercase tracking-widest mb-2">GitHub Impact</div>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black text-white">{totalStars}</span>
              <span class="text-[var(--color-primary-light)] text-sm font-bold">Stars</span>
            </div>
          </div>
          <div class="glass p-6 rounded-2xl group hover:border-[var(--color-primary)]/30 transition-all">
            <div class="text-white/40 text-xs font-bold uppercase tracking-widest mb-2">LeetCode</div>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black text-white">{leetcodeStats?.totalSolved || '500+'}</span>
              <span class="text-emerald-400 text-sm font-bold">Solved</span>
            </div>
          </div>
          <div class="glass p-6 rounded-2xl group hover:border-[var(--color-primary)]/30 transition-all">
            <div class="text-white/40 text-xs font-bold uppercase tracking-widest mb-2">Projects</div>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black text-white">{projects.length}</span>
              <span class="text-blue-400 text-sm font-bold">Live</span>
            </div>
          </div>
          <div class="glass p-6 rounded-2xl group hover:border-[var(--color-primary)]/30 transition-all">
            <div class="text-white/40 text-xs font-bold uppercase tracking-widest mb-2">Experience</div>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black text-white">4+</span>
              <span class="text-purple-400 text-sm font-bold">Years</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ FEATURED PROJECTS ═══ -->
      <section class="reveal-stagger">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl font-black text-white mb-2">Featured Work</h2>
            <p class="text-white/40 font-medium">Flagship engineering projects and AI platforms</p>
          </div>
          <a href="/work" class="px-6 py-2.5 rounded-xl border border-white/10 text-white/60 font-semibold hover:bg-white/5 hover:text-white transition-all text-sm">
            Explore All
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredProjects.slice(0, 3).map((project, i) => (
            <a href={project.link.startsWith('http') ? project.link : `https://${project.link}`} target="_blank" class={`group relative aspect-[4/5] overflow-hidden rounded-3xl bg-[#0A0A0A] border border-white/5 hover:border-white/10 transition-all ${i === 0 ? 'md:col-span-1' : ''}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent z-10 opacity-0 group-hover:opacity-20 transition-opacity"></div>
              <div class="absolute inset-x-0 bottom-0 p-8 z-20">
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.tech.split(', ').slice(0, 2).map((tag: string) => (
                    <span class="px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-[10px] uppercase font-bold text-white/60 tracking-wider transition-colors group-hover:border-[var(--color-primary)]/30 group-hover:text-white/80">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-[var(--color-primary-light)] transition-colors">{project.name}</h3>
                <p class="text-sm text-white/40 line-clamp-2 leading-relaxed">{project.items[0]}</p>
                <div class="mt-6 flex items-center gap-2 text-xs font-bold text-[var(--color-primary-light)] opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
                  VIEW CASE STUDY
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </div>
              </div>
              <div class="absolute inset-0 z-0 bg-white/[0.02]" />
            </a>
          ))}
        </div>
      </section>

      <!-- ═══ BLOG & INSIGHTS ═══ -->
      <section class="reveal-stagger">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="text-3xl font-black text-white mb-2">Technical Insights</h2>
            <p class="text-white/40 font-medium">Writings on backend architecture and AI</p>
          </div>
          <a href="/writing" class="px-6 py-2.5 rounded-xl border border-white/10 text-white/60 font-semibold hover:bg-white/5 hover:text-white transition-all text-sm">
            Read Blog
          </a>
        </div>

        <div class="space-y-4">
          {recentArticles.map((article: any) => (
            <a href={article.url} target="_blank" class="glass group flex items-center justify-between p-6 rounded-2xl hover:bg-white/[0.03] transition-all border-l-2 border-transparent hover:border-[var(--color-primary)]">
              <div class="flex items-center gap-6">
                <div class="flex flex-col items-center p-3 rounded-xl bg-white/5 border border-white/5 min-w-[64px]">
                  <span class="text-xs font-bold text-white/30 uppercase tracking-tighter">{new Date(article.published_at).toLocaleString('default', { month: 'short' })}</span>
                  <span class="text-xl font-black text-white leading-none">{new Date(article.published_at).getDate()}</span>
                </div>
                <div>
                  <h3 class="font-bold text-white text-lg group-hover:text-[var(--color-primary-light)] transition-colors mb-1">{article.title}</h3>
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-medium text-white/30">{article.readable_publish_date}</span>
                    <span class="h-1 w-1 rounded-full bg-white/10"></span>
                    <div class="flex gap-2">
                       {article.tag_list?.slice(0, 2).map((tag: string) => (
                         <span class="text-[10px] font-bold text-[var(--color-primary-light)]/60 italic">#{tag}</span>
                       ))}
                    </div>
                  </div>
                </div>
              </div>
              <div class="h-10 w-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/20 group-hover:text-white group-hover:border-[var(--color-primary)]/50 transition-all">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- ═══ RECOGNITION ═══ -->
      <section class="max-w-6xl mx-auto py-12 border-t border-white/5">
         <div class="flex flex-wrap items-center justify-center gap-x-16 gap-y-8 opacity-40 grayscale group hover:grayscale-0 transition-all duration-700">
            <span class="text-sm font-black tracking-widest text-white whitespace-nowrap uppercase">TCS Research</span>
            <span class="text-sm font-black tracking-widest text-white whitespace-nowrap uppercase">Microsoft Learn</span>
            <span class="text-sm font-black tracking-widest text-white whitespace-nowrap uppercase">Postman Student Expert</span>
            <span class="text-sm font-black tracking-widest text-white whitespace-nowrap uppercase">LeetCode Top 5%</span>
         </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .glass {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .reveal-stagger > * {
    opacity: 0;
    transform: translateY(20px);
  }
</style>

<script>
  import { observeElements } from '../lib/utils';
  
  observeElements('.will-animate', {
    threshold: 0.1,
    rootMargin: '50px'
  });

  observeElements('.reveal-stagger > *', {
    threshold: 0.1,
    stagger: 100
  });
</script>
