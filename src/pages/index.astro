---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import StatsCounter from '../components/islands/StatsCounter';
import HeroChatButton from '../components/islands/HeroChatButton';
import { fetchGitHubUser, fetchGitHubRepos, fetchLeetCodeStats, fetchDevToArticles, fetchCodewarsUser } from '../lib/api';
import { skills, experience, summary, projects } from '../data/resume';
import { fetchBlogPosts } from '../lib/api/blog';

const [githubUser, githubRepos, leetcodeStats, devtoArticles, codewarsUser, blogPosts] = await Promise.all([
  fetchGitHubUser(),
  fetchGitHubRepos(),
  fetchLeetCodeStats(),
  fetchDevToArticles(),
  fetchCodewarsUser(),
  fetchBlogPosts(),
]);

const totalStars = githubRepos.reduce((sum, r) => sum + r.stargazers_count, 0);
const recentArticles = devtoArticles.slice(0, 3);
const featuredProjects = projects.filter(p => p.featured);
---

<Layout title="Chirag Singhal Dashboard" description="Chirag Singhal — Software Engineer at TCS. Building things that matter.">
  <Navbar />
  <CommandPalette />

  <main class="relative pb-24">
    <!-- ═══ HERO ═══ -->
    <section class="relative pt-28 pb-20 flex items-center justify-center overflow-hidden">
      <!-- Ambient glow orbs -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[var(--color-primary)]/15 rounded-[100%] blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-0 left-[20%] w-[300px] h-[300px] bg-[var(--color-accent-warm)]/8 rounded-full blur-[100px]"></div>
        <div class="absolute top-[20%] right-[10%] w-[200px] h-[200px] bg-[var(--color-accent-violet)]/8 rounded-full blur-[80px]"></div>
        <!-- Dot grid -->
        <div class="absolute inset-0 opacity-[0.035]" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 48px 48px;"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-6xl px-4 w-full flex flex-col items-center text-center">
        <!-- Status pill -->
        <div class="will-animate animate-fade-in inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mb-8 shadow-glow-sage">
          <span class="h-2 w-2 rounded-full bg-[var(--color-accent-sage)] animate-pulse"></span>
          <span class="text-xs font-semibold text-white/70 uppercase tracking-widest">Available for opportunities</span>
        </div>

        <!-- Name -->
        <h1 class="will-animate animate-slide-up text-6xl sm:text-8xl lg:text-9xl font-black tracking-tighter mb-6" style="font-family: 'Outfit', sans-serif;">
          <span class="text-gradient hover:scale-[1.02] transition-transform duration-500 inline-block">Chirag</span>
          <span class="text-white/90"> Singhal</span>
        </h1>

        <!-- Sub -->
        <p class="will-animate animate-slide-up delay-200 text-xl sm:text-2xl text-white/45 max-w-2xl mx-auto mb-10 font-medium tracking-tight leading-relaxed">
          Software Engineer at <span class="text-white font-semibold">TCS</span> · Building robust, AI-driven systems at scale.
        </p>

        <!-- CTAs -->
        <div class="will-animate animate-slide-up delay-400 flex flex-wrap items-center justify-center gap-4">
          <a href="#dashboard" class="btn-primary text-base px-8 py-3 rounded-2xl hover:scale-105 transition-transform">
            Explore Dashboard
          </a>
          <a href="/connect" class="btn-ghost text-base px-8 py-3 rounded-2xl">Connect</a>
          <HeroChatButton client:load />
        </div>

        <!-- Scroll indicator -->
        <div class="will-animate animate-fade-in delay-800 mt-16 flex flex-col items-center gap-2 text-white/20">
          <span class="text-[10px] uppercase tracking-[0.3em] font-semibold">Scroll</span>
          <div class="w-px h-8 bg-gradient-to-b from-white/20 to-transparent animate-pulse"></div>
        </div>
      </div>
    </section>

    <!-- ═══ BENTO DASHBOARD ═══ -->
    <section id="dashboard" class="relative z-10 mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 mt-4">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 auto-rows-[minmax(120px,_auto)]">

        <!-- Welcome Card (8 cols, 2 rows) -->
        <div class="reveal glass md:col-span-8 md:row-span-2 p-8 sm:p-10 flex flex-col justify-between group relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--color-primary)]/5 rounded-full blur-[100px] pointer-events-none"></div>
          <div class="relative">
            <div class="text-[0.65rem] font-bold text-[var(--color-primary)] tracking-widest uppercase mb-4">Core Identifier</div>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-[1.15] mb-4" style="font-family: 'Outfit', sans-serif;">
              {summary.split('.')[0]}.
            </h2>
            <p class="text-white/50 text-base max-w-xl leading-relaxed">
              I specialize in React, Node.js, and scaling high-performance full-stack architectures. Welcome to my spatial digital identity.
            </p>
          </div>
          <div class="mt-8 flex gap-3">
             <a href="https://github.com/chirag127" target="_blank" class="tag-violet">GitHub ↗</a>
             <a href="https://linkedin.com/in/chirag127" target="_blank" class="tag-sky">LinkedIn ↗</a>
          </div>
        </div>

        <!-- Stats Cards (4 cols each) -->
        <div class="reveal delay-100 card md:col-span-4 p-6 sm:p-8 flex items-center justify-between group hover:border-[var(--color-accent-warm)]/30 transition-colors">
          <div>
            <div class="text-[0.65rem] font-bold text-white/40 tracking-widest uppercase mb-1">Impact Signal</div>
            <div class="text-3xl font-black text-white tracking-tighter"><StatsCounter client:visible value={totalStars} label="" icon="" /></div>
            <div class="text-sm font-medium text-[var(--color-accent-warm)] mt-1">Open Source Stars</div>
          </div>
          <div class="h-12 w-12 rounded-full bg-[var(--color-accent-warm)]/10 flex items-center justify-center text-[var(--color-accent-warm)] border border-[var(--color-accent-warm)]/20 group-hover:scale-110 transition-transform">⭐</div>
        </div>

        <div class="reveal delay-200 card md:col-span-4 p-6 sm:p-8 flex items-center justify-between group hover:border-[var(--color-accent-sage)]/30 transition-colors">
          <div>
            <div class="text-[0.65rem] font-bold text-white/40 tracking-widest uppercase mb-1">Logic Execution</div>
            <div class="text-3xl font-black text-white tracking-tighter"><StatsCounter client:visible value={leetcodeStats?.totalSolved || 0} label="" icon="" /></div>
            <div class="text-sm font-medium text-[var(--color-accent-sage)] mt-1">LeetCode Solved</div>
          </div>
          <div class="h-12 w-12 rounded-full bg-[var(--color-accent-sage)]/10 flex items-center justify-center text-[var(--color-accent-sage)] border border-[var(--color-accent-sage)]/20 group-hover:scale-110 transition-transform">🧩</div>
        </div>

        <!-- Career Timeline (4 cols, 3 rows) -->
        <div class="reveal delay-100 card md:col-span-4 md:row-span-3 p-6 sm:p-8 flex flex-col">
          <div class="flex items-center justify-between mb-8">
            <div class="text-[0.65rem] font-bold text-[var(--color-primary)] tracking-widest uppercase">Career Trajectory</div>
            <a href="/work/career" class="h-8 w-8 flex items-center justify-center rounded-full bg-white/5 hover:bg-white/10 text-white transition hover:scale-110">→</a>
          </div>
          <div class="flex-1 space-y-8">
            {experience.slice(0, 3).map((job) => (
              <div class="relative pl-6 before:absolute before:left-0 before:top-2 before:w-2 before:h-2 before:bg-[var(--color-primary)] before:rounded-full before:shadow-glow">
                <div class="absolute left-[3px] top-6 bottom-[-20px] w-[1px] bg-gradient-to-b from-[var(--color-primary)]/50 to-transparent last:hidden"></div>
                <div class="text-xs text-[var(--color-primary)] font-semibold mb-1 uppercase tracking-wider">{job.date}</div>
                <h3 class="text-base font-bold text-white leading-tight mb-1">{job.title}</h3>
                <p class="text-sm text-white/40">{job.company}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Featured Project (8 cols, 2 rows) -->
        <div class="reveal glass flex flex-col md:flex-row md:col-span-8 md:row-span-2 overflow-hidden group">
          <div class="p-8 sm:p-10 flex flex-col justify-center flex-1 z-10">
            <div class="text-[0.65rem] font-bold text-[var(--color-accent-rose)] tracking-widest uppercase mb-4">Deployed Node</div>
            <h3 class="text-2xl sm:text-3xl font-black text-white group-hover:text-[var(--color-accent-rose)] transition-colors mb-3 leading-tight">{featuredProjects[0]?.name || 'Flagship Project'}</h3>
            <p class="text-sm sm:text-base text-white/50 mb-6 leading-relaxed">
              {featuredProjects[0]?.items[0] || 'Core infrastructure deployed and actively scaling.'}
            </p>
            <div class="flex flex-wrap gap-2">
              {featuredProjects[0]?.tech.split(', ').slice(0, 4).map((t) => (
                <span class="px-2.5 py-1 text-[10px] uppercase font-bold tracking-wider rounded-md bg-white/5 text-white/70 border border-white/10">{t}</span>
              ))}
            </div>
          </div>
          <div class="w-full md:w-[45%] bg-white/[0.02] border-l border-white/5 relative overflow-hidden flex items-center justify-center p-6 sm:p-8">
             <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent-rose)]/10 to-transparent"></div>
             <div class="w-full aspect-video rounded-lg border border-white/10 bg-black/40 shadow-2xl skew-y-6 group-hover:skew-y-0 group-hover:scale-110 transition-transform duration-700 ease-spring">
                <div class="h-4 border-b border-white/10 flex items-center px-2 gap-1.5"><div class="w-1.5 h-1.5 rounded-full bg-white/20"></div><div class="w-1.5 h-1.5 rounded-full bg-white/20"></div></div>
                <div class="p-3 flex flex-col gap-2 opacity-20"><div class="h-2.5 bg-white rounded w-2/3"></div><div class="h-2.5 bg-white rounded w-full"></div><div class="h-2.5 bg-white rounded w-1/2 mt-2"></div></div>
             </div>
          </div>
        </div>

        <!-- Skills Matrix (full width) -->
        <div class="reveal card md:col-span-12 p-6 sm:p-8 flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="shrink-0 text-center md:text-left">
            <div class="text-[0.65rem] font-bold text-[var(--color-accent-violet)] tracking-widest uppercase mb-1">Tech Matrix</div>
            <div class="text-xl sm:text-2xl font-black text-white">System Capabilities</div>
          </div>
          <div class="flex flex-wrap gap-2 justify-center md:justify-end flex-1">
            {skills.flatMap((c) => c.items).slice(0, 14).map((skill) => (
                <span class="px-3.5 py-1.5 text-[0.7rem] font-bold uppercase tracking-wider rounded-xl bg-white/5 text-white/70 hover:bg-white/10 hover:text-white transition-colors cursor-default border border-white/5">{skill}</span>
            ))}
          </div>
        </div>

        <!-- Dev.to Articles -->
        {recentArticles.length > 0 && (
        <div class="reveal md:col-span-12 grid grid-cols-1 md:grid-cols-3 gap-4">
            {recentArticles.map((article) => (
              <a href={article.url} target="_blank" rel="noopener noreferrer" class="glass p-6 sm:p-8 group hover:border-[var(--color-accent-warm)]/20 transition-colors">
                <div class="text-[0.65rem] font-bold text-[var(--color-accent-warm)] tracking-widest uppercase mb-3">Dev.to Article</div>
                <h3 class="text-lg sm:text-xl font-bold text-white group-hover:text-[var(--color-accent-warm)] transition-colors mb-4 line-clamp-2 leading-snug">{article.title}</h3>
                <div class="flex items-center gap-4 text-[11px] font-bold tracking-wider uppercase text-white/40 mt-auto pt-4 border-t border-white/5">
                  <span class="flex items-center gap-1.5">⏱ {article.reading_time_minutes} min</span>
                  <span class="flex items-center gap-1.5 text-[var(--color-accent-rose)]/80">❤ {article.positive_reactions_count}</span>
                </div>
              </a>
            ))}
        </div>
        )}

        <!-- Blog RSS Section -->
        {blogPosts.length > 0 && (
        <div class="reveal md:col-span-12">
          <div class="text-[0.65rem] font-bold text-[var(--color-primary)] tracking-widest uppercase mb-4 px-1">Latest from Blog</div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {blogPosts.slice(0, 3).map((post) => (
              <a href={post.link} target="_blank" rel="noopener noreferrer" class="glass p-6 group hover:border-[var(--color-primary)]/20 transition-colors">
                <h3 class="text-lg font-bold text-white group-hover:text-[var(--color-primary)] transition-colors mb-3 line-clamp-2 leading-snug">{post.title}</h3>
                <p class="text-sm text-white/40 line-clamp-2 mb-4">{post.description}</p>
                <div class="text-[11px] font-bold tracking-wider uppercase text-white/30 pt-3 border-t border-white/5">
                  {new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </div>
              </a>
            ))}
          </div>
        </div>
        )}

        <!-- Quick Nav Cards (full width) -->
        <div class="reveal-stagger md:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-4 mt-2">
          <a href="/work" class="glass p-6 group text-center hover:border-amber-400/20 transition-colors">
            <div class="text-2xl mb-2">💼</div>
            <div class="text-sm font-bold text-white group-hover:text-amber-400 transition-colors">Work</div>
            <div class="text-[10px] text-white/30 mt-1">Career & Skills</div>
          </a>
          <a href="/library" class="glass p-6 group text-center hover:border-sky-400/20 transition-colors">
            <div class="text-2xl mb-2">📚</div>
            <div class="text-sm font-bold text-white group-hover:text-sky-400 transition-colors">Library</div>
            <div class="text-[10px] text-white/30 mt-1">Movies, Books, Music</div>
          </a>
          <a href="/gaming" class="glass p-6 group text-center hover:border-emerald-400/20 transition-colors">
            <div class="text-2xl mb-2">🎮</div>
            <div class="text-sm font-bold text-white group-hover:text-emerald-400 transition-colors">Gaming</div>
            <div class="text-[10px] text-white/30 mt-1">Steam & Chess</div>
          </a>
          <a href="/me" class="glass p-6 group text-center hover:border-violet-400/20 transition-colors">
            <div class="text-2xl mb-2">🧠</div>
            <div class="text-sm font-bold text-white group-hover:text-violet-400 transition-colors">About Me</div>
            <div class="text-[10px] text-white/30 mt-1">Story & Philosophy</div>
          </a>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
