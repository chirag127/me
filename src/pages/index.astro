---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import StatsCounter from '../components/islands/StatsCounter';
import HeroChatButton from '../components/islands/HeroChatButton';
import { fetchGitHubUser, fetchGitHubRepos, fetchLeetCodeStats, fetchDevToArticles, fetchBlogPosts } from '../lib/api/index';
import { skills, experience, summary, projects, honors } from '../data/resume';

const [githubUser, githubRepos, leetcodeStats, devtoArticles, blogPosts] = await Promise.all([
  fetchGitHubUser(),
  fetchGitHubRepos(),
  fetchLeetCodeStats(),
  fetchDevToArticles(),
  fetchBlogPosts(),
]);

const totalStars = githubRepos.reduce((sum: number, r: any) => sum + (r.stargazers_count || 0), 0);
const recentArticles = devtoArticles.slice(0, 3);
const featuredProjects = projects.filter(p => p.featured);
const currentRole = experience[0];
---

<Layout title="Chirag Singhal — Software Engineer" description={summary.substring(0, 155) + '...'}>
  <Navbar />
  <CommandPalette />

  <main class="relative pb-24">
    <!-- ═══ HERO ═══ -->
    <section class="relative pt-32 pb-24 overflow-hidden">
      <!-- Ambient light -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-20%] right-[-10%] w-[800px] h-[600px] bg-[var(--color-primary)]/10 rounded-[100%] blur-[120px]"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] bg-[var(--color-accent-violet)]/10 rounded-[100%] blur-[120px]"></div>
        <!-- Grid pattern -->
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 64px 64px;"></div>
      </div>

      <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <div class="will-animate animate-fade-in inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-semibold text-[var(--color-primary-light)] uppercase tracking-wider mb-8">
            <span class="h-2 w-2 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
            {currentRole.title} @ {currentRole.company}
          </div>

          <h1 class="will-animate animate-slide-up text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter mb-8 leading-[1.1]" style="font-family: 'Outfit', sans-serif;">
            Building scalable <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-primary-light)] to-[var(--color-accent-violet)]">backend systems</span> <br/>
            & intelligent APIs.
          </h1>

          <p class="will-animate animate-slide-up delay-200 text-lg sm:text-xl text-white/50 max-w-2xl font-medium leading-relaxed mb-10">
            {summary.split('. ').slice(0, 2).join('. ') + '.'}
          </p>

          <div class="will-animate animate-slide-up delay-300 flex flex-wrap items-center gap-4">
            <a href="/work" class="px-8 py-3.5 rounded-xl bg-white text-black font-semibold hover:bg-white/90 transition-colors">
              View Work
            </a>
            <HeroChatButton client:load />
            <div class="flex items-center gap-4 ml-4 text-white/40">
              <a href="https://github.com/chirag127" target="_blank" class="hover:text-white transition-colors">
                <span class="sr-only">GitHub</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              </a>
              <a href="https://linkedin.com/in/chirag127" target="_blank" class="hover:text-[var(--color-primary-light)] transition-colors">
                <span class="sr-only">LinkedIn</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 space-y-24">
      
      <!-- ═══ EXPERIENCE & EDUCATION ═══ -->
      <section class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="glass p-8 rounded-2xl">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="h-5 w-5 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Current Role
          </h2>
          <div class="relative pl-5 border-l border-white/10">
            <div class="absolute -left-[5px] top-1.5 h-2 w-2 rounded-full bg-[var(--color-primary)] shadow-[0_0_10px_var(--color-primary)]"></div>
            <h3 class="font-bold text-white text-lg">{currentRole.title}</h3>
            <p class="text-[var(--color-primary-light)] text-sm mb-3">{currentRole.company} · {currentRole.date}</p>
            <p class="text-white/50 text-sm leading-relaxed mb-4">
              {currentRole.items[0]}
            </p>
            <a href="/work" class="text-xs font-semibold text-white/40 hover:text-white transition-colors group">
              View full resume <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>

        <div class="glass p-8 rounded-2xl">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
            Background
          </h2>
          <div class="space-y-4">
            <div class="p-4 rounded-xl bg-white/5 border border-white/5">
              <h3 class="font-bold text-white text-sm">{honors[1].title}</h3>
              <p class="text-amber-400/80 text-xs mb-1">{honors[1].description}</p>
              <p class="text-white/40 text-[10px] uppercase tracking-wider">{honors[1].year}</p>
            </div>
            <div class="p-4 rounded-xl bg-white/5 border border-white/5">
              <h3 class="font-bold text-white text-sm">Computer Science Engineering</h3>
              <p class="text-[var(--color-primary-light)] text-xs mb-1">Dr. A.P.J. Abdul Kalam Technical University</p>
              <p class="text-white/40 text-[10px] uppercase tracking-wider">CGPA: 8.81 · College Topper</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ FEATURED PROJECTS ═══ -->
      <section class="reveal">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2" style="font-family: 'Outfit', sans-serif;">Featured Work</h2>
            <p class="text-white/40">Open source projects and deployments.</p>
          </div>
          <a href="/work/projects" class="hidden sm:block text-sm font-semibold text-[var(--color-primary-light)] hover:text-white transition-colors">View all projects &rarr;</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featuredProjects.slice(0, 4).map((project) => (
            <div class="glass p-8 rounded-2xl flex flex-col group hover:border-white/10 transition-colors">
              <div class="flex items-start justify-between mb-4">
                <h3 class="text-xl font-bold text-white group-hover:text-[var(--color-primary-light)] transition-colors">{project.name}</h3>
                <a href={project.link.startsWith('http') ? project.link : `https://${project.link}`} target="_blank" class="h-8 w-8 rounded-full bg-white/5 flex items-center justify-center text-white/50 hover:bg-white/10 hover:text-white transition-colors flex-shrink-0">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
              <p class="text-sm text-white/50 leading-relaxed mb-6 flex-1">
                {project.items[0]}
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                {project.tech.split(', ').map(t => (
                  <span class="px-2.5 py-1 text-[10px] font-semibold text-white/60 bg-white/5 rounded-md border border-white/5">{t}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ═══ LIVE CODING METRICS ═══ -->
      <section class="reveal">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-white">Live Engineering Metrics</h2>
          <a href="/code" class="text-xs text-[var(--color-primary-light)] hover:text-white transition-colors">View detailed stats →</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="glass p-6 rounded-2xl text-center flex flex-col items-center justify-center min-h-[140px]">
            <div class="text-3xl font-black text-white mb-1"><StatsCounter client:visible value={githubUser?.public_repos || 0} label="" icon="" /></div>
            <div class="text-xs text-white/40 uppercase tracking-widest font-semibold mt-1">GitHub Repos</div>
          </div>
          <div class="glass p-6 rounded-2xl text-center flex flex-col items-center justify-center min-h-[140px] border-[var(--color-primary)]/10 bg-[var(--color-primary)]/5">
            <div class="text-3xl font-black text-[var(--color-primary-light)] mb-1"><StatsCounter client:visible value={totalStars} label="" icon="" /></div>
            <div class="text-xs text-[var(--color-primary)] uppercase tracking-widest font-semibold mt-1">Total Stars</div>
          </div>
          <div class="glass p-6 rounded-2xl text-center flex flex-col items-center justify-center min-h-[140px]">
            <div class="text-3xl font-black text-white mb-1"><StatsCounter client:visible value={leetcodeStats?.totalSolved || 0} label="" icon="" /></div>
            <div class="text-xs text-white/40 uppercase tracking-widest font-semibold mt-1">LeetCode Solved</div>
          </div>
          <div class="glass p-6 rounded-2xl text-center flex flex-col items-center justify-center min-h-[140px]">
            <div class="text-3xl font-black text-white mb-1"><StatsCounter client:visible value={leetcodeStats?.totalMediumSolved || 0} label="" icon="" /></div>
            <div class="text-xs text-amber-400/60 uppercase tracking-widest font-semibold mt-1">Medium+ Hard</div>
          </div>
        </div>
      </section>

      <!-- ═══ WRITINGS / BLOG ═══ -->
      {(blogPosts.length > 0 || recentArticles.length > 0) && (
      <section class="reveal">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2" style="font-family: 'Outfit', sans-serif;">Writings</h2>
            <p class="text-white/40">Thoughts on software, architecture, and engineering.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {blogPosts.slice(0, 3).map((post: any) => (
            <a href={post.link} target="_blank" rel="noopener noreferrer" class="glass p-6 rounded-2xl group hover:bg-white/[0.04] transition-colors flex flex-col">
              <div class="text-[10px] font-bold text-[var(--color-primary)] tracking-widest uppercase mb-3">Blog</div>
              <h3 class="text-lg font-bold text-white group-hover:text-[var(--color-primary-light)] transition-colors mb-3 leading-snug">{post.title}</h3>
              <p class="text-sm text-white/40 line-clamp-3 mb-6 flex-1">{post.description}</p>
              <div class="text-[10px] font-semibold tracking-widest uppercase text-white/30 pt-4 border-t border-white/5">
                {new Date(post.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </div>
            </a>
          ))}
          {/* Fallback to Dev.to if blog empty or to fill up space */}
          {blogPosts.length < 3 && recentArticles.slice(0, 3 - blogPosts.length).map((article: any) => (
             <a href={article.url} target="_blank" rel="noopener noreferrer" class="glass p-6 rounded-2xl group hover:bg-white/[0.04] transition-colors flex flex-col">
              <div class="text-[10px] font-bold text-amber-400 tracking-widest uppercase mb-3">Dev.to</div>
              <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors mb-3 leading-snug">{article.title}</h3>
              <div class="mt-auto pt-4 border-t border-white/5 flex items-center justify-between text-[10px] font-semibold tracking-widest uppercase text-white/30">
                <span>{article.reading_time_minutes} min read</span>
                <span class="text-amber-400/60">{article.positive_reactions_count} reactions</span>
              </div>
            </a>
          ))}
        </div>
      </section>
      )}

      <!-- ═══ LIBRARY PREVIEW ═══ -->
      <section class="reveal">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-3xl font-bold text-white mb-2" style="font-family: 'Outfit', sans-serif;">Library</h2>
            <p class="text-white/40">Movies, anime, books, and music I track.</p>
          </div>
          <a href="/library" class="hidden sm:block text-sm font-semibold text-[var(--color-primary-light)] hover:text-white transition-colors">Explore library &rarr;</a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/library/movies" class="glass p-5 rounded-xl hover:bg-white/[0.04] transition-colors group">
            <div class="text-2xl mb-2">🎬</div>
            <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-primary-light)] transition-colors">Movies & TV</h3>
            <p class="text-xs text-white/40 mt-1">Trakt synced</p>
          </a>
          <a href="/library/anime" class="glass p-5 rounded-xl hover:bg-white/[0.04] transition-colors group">
            <div class="text-2xl mb-2">🌸</div>
            <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-primary-light)] transition-colors">Anime</h3>
            <p class="text-xs text-white/40 mt-1">AniList tracked</p>
          </a>
          <a href="/library/books" class="glass p-5 rounded-xl hover:bg-white/[0.04] transition-colors group">
            <div class="text-2xl mb-2">📚</div>
            <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-primary-light)] transition-colors">Books</h3>
            <p class="text-xs text-white/40 mt-1">OpenLibrary</p>
          </a>
          <a href="/library/music" class="glass p-5 rounded-xl hover:bg-white/[0.04] transition-colors group">
            <div class="text-2xl mb-2">🎵</div>
            <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-primary-light)] transition-colors">Music</h3>
            <p class="text-xs text-white/40 mt-1">Last.fm</p>
          </a>
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Layout>
