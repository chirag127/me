---
/**
 * All Tracked Shows — Full history of TV Shows
 */
import Layout from '../../layouts/Layout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let shows: any[] = [];

try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/movies.json'),
    'utf-8',
  );
  const db = JSON.parse(raw);
  shows = db.shows || [];
} catch {
  console.warn('[Shows] movies.json not found.');
}

const totalEpisodes = shows.reduce((acc, s) => acc + (s.episodesWatched || 0), 0);
---

<Layout
  title="All Tracked Shows"
  description="Complete TV show tracking history"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-10"
  >
    <!-- Breadcrumb -->
    <div class="flex items-center gap-1.5
      text-xs text-white/25 mb-6">
      <a
        href="/library"
        class="hover:text-white/40 transition-colors"
      >Library</a>
      <span>/</span>
      <a
        href="/library/shows"
        class="hover:text-white/40 transition-colors"
      >TV Shows</a>
      <span>/</span>
      <span class="text-white/40">All Tracked</span>
    </div>

    <!-- Header -->
    <div class="mb-8">
      <h1
        class="text-2xl font-black text-white mb-2"
        style="font-family:
          var(--font-display, 'Outfit');"
      >
        All Tracked Shows
      </h1>
      <p class="text-sm text-white/30">
        {shows.length} shows · {totalEpisodes} episodes watched
      </p>
    </div>

    <!-- Show List -->
    <div class="space-y-2">
      {shows.map((show, i) => (
        <div
          class="group flex items-center gap-4
            p-3 rounded-xl bg-white/[0.01]
            border border-white/[0.03]
            hover:border-violet-500/10
            hover:bg-white/[0.02]
            transition-all duration-200"
        >
          <div
            class="flex items-center justify-center
              h-7 w-7 rounded-md bg-white/[0.02]
              text-[10px] text-white/15 font-mono
              flex-shrink-0"
          >
            {i + 1}
          </div>
          <div class="relative h-12 w-8 flex-shrink-0 overflow-hidden rounded bg-violet-500/10">
            {show.posterUrl ? (
              <img src={show.posterUrl} alt={show.title} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-lg text-violet-400">📺</div>
            )}
          </div>
          <div class="flex-1 min-w-0">
            <h3
              class="text-sm font-medium
                text-white/70 truncate
                group-hover:text-violet-300
                transition-colors"
            >
              {show.title}
            </h3>
            <p class="text-[10px] text-white/20">
              {show.year}
              {(show.genres || [])[0] &&
                ` · ${(show.genres || [])[0]}`}
            </p>
          </div>
          <div class="text-right flex-shrink-0">
             <div class="text-xs font-bold text-violet-400/60">
                 {show.episodesWatched || 0}
             </div>
             <div class="text-[8px] text-white/15 uppercase tracking-wider">
                 eps
             </div>
          </div>
        </div>
      ))}
    </div>

    {shows.length === 0 && (
      <div
        class="text-center py-20 text-white/20
          text-sm"
      >
        No shows tracked yet. Run
        <code class="text-violet-400/50">
          pnpm run fetch-data
        </code>
        to sync.
      </div>
    )}

    <!-- Trakt Profile Link -->
    <div class="mt-16 text-center">
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500/10 text-red-500 hover:text-red-400 hover:bg-red-500/20 font-semibold text-sm transition-all">
        View complete profile on Trakt
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
