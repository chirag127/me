---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import CONFIG from '../../lib/config';
---

<Layout title="SoundCloud" description="Chirag Singhal on SoundCloud — music and audio">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[#ff5500]/10 flex items-center justify-center">
        <span class="text-xl">☁️</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">SoundCloud</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">My SoundCloud profile — {CONFIG.user.soundcloud}.</p>

    <div class="glass-strong p-8 mb-12">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-[#ff5500]/20 flex items-center justify-center">
          <span class="text-3xl">☁️</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">@{CONFIG.user.soundcloud}</h2>
          <p class="text-sm text-[var(--color-text-muted)]">on SoundCloud</p>
        </div>
      </div>
    </div>

    <!-- SoundCloud Embed -->
    <div class="glass p-4 mb-12">
      <h2 class="text-lg font-semibold text-white mb-4">Profile</h2>
      <iframe
        width="100%"
        height="300"
        scrolling="no"
        frameborder="no"
        allow="autoplay"
        src={`https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/${CONFIG.user.soundcloud}&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true`}
        loading="lazy"
      ></iframe>
    </div>

    <div class="glass p-6 text-center">
      <a href={`https://soundcloud.com/${CONFIG.user.soundcloud}`} target="_blank" rel="noopener noreferrer" class="text-sm text-[#ff5500] hover:underline">View on SoundCloud →</a>
    </div>
  </main>
  <Footer />
  <ChatWidget client:load />
</Layout>
