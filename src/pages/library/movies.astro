---
/**
 * Movies Hub — Redesigned with only movie contents.
 * No colored image placeholders.
 */
import Layout from '../../layouts/Layout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

interface Movie {
  title: string;
  year: number;
  rating: number | null;
  genres: string[];
  watchedAt: string | null;
  posterUrl?: string;
  runtime?: number;
  overview?: string;
}

let db = {
  watched: [] as Movie[],
  watchlist: [] as Movie[],
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch {
  console.warn(
    '[Movies] movies.json not found.',
  );
}

const movies = db.watched || [];
const watchlist = db.watchlist || [];

// Movie stats
const movieCount = movies.length;
const ratedMovies = movies.filter((m) => m.rating);
const avgMovieRating = ratedMovies.length > 0
  ? (
      ratedMovies.reduce(
        (s, m) => s + (m.rating || 0),
        0,
      ) / ratedMovies.length
    ).toFixed(1)
  : '—';

const topRatedMovies = [...movies]
  .filter((m) => m.rating)
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 8);

const recentMovies = [...movies].slice(0, 8);

// Genre analysis (movies only)
const genreCounts: Record<string, number> = {};
movies.forEach((m) => {
  (m.genres || []).forEach((g: string) => {
    genreCounts[g] = (genreCounts[g] || 0) + 1;
  });
});
const topGenres = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([g]) => g);
---

<Layout
  title="Movies"
  description="Film diary — tracked via Trakt"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-10"
  >
    <!-- Breadcrumb -->
    <a
      href="/library"
      class="inline-flex items-center gap-1.5
        text-xs text-white/30
        hover:text-white/50 transition-colors mb-6"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M15 19l-7-7 7-7" />
      </svg>
      Library
    </a>

    <!-- Header -->
    <div class="mb-10">
      <h1
        class="text-3xl font-black text-white mb-2"
        style="font-family:
          var(--font-display, 'Outfit');"
      >
        Movies
      </h1>
      <p class="text-sm text-white/35">
        Film diary — synced from Trakt automatically.
      </p>
    </div>

    <!-- Quick Navigation -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a
        href="/library/movies-watched"
        class="text-[10px] px-3 py-1.5 rounded-full
          bg-teal-500/10 text-teal-400
          border border-teal-500/20
          hover:bg-teal-500/20
          transition-colors font-semibold
          uppercase tracking-wider"
      >
        All Watched ({movieCount})
      </a>
      <a
        href="/library/movies-rated"
        class="text-[10px] px-3 py-1.5 rounded-full
          bg-amber-500/10 text-amber-400
          border border-amber-500/20
          hover:bg-amber-500/20
          transition-colors font-semibold
          uppercase tracking-wider"
      >
        Top Rated
      </a>
      <a
        href="/library/movies-watchlist"
        class="text-[10px] px-3 py-1.5 rounded-full
          bg-rose-500/10 text-rose-400
          border border-rose-500/20
          hover:bg-rose-500/20
          transition-colors font-semibold
          uppercase tracking-wider"
      >
        Watchlist ({watchlist.length})
      </a>
    </div>

    <!-- Stats Grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-14"
    >
      {[
        {
          label: 'Total Movies',
          value: movieCount,
          color: 'text-teal-400',
        },
        {
          label: 'Avg Rating',
          value: avgMovieRating,
          color: 'text-amber-400',
        },
        {
          label: 'Watchlist',
          value: watchlist.length,
          color: 'text-rose-400',
        },
        {
          label: 'Top Genre',
          value: topGenres[0] || 'N/A',
          color: 'text-sky-400',
        },
      ].map((stat) => (
        <div
          class="p-4 rounded-xl bg-white/[0.015]
            border border-white/5 text-center"
        >
          <div
            class={`text-2xl font-black ${stat.color} truncate`}
            style="font-family:
              var(--font-display, 'Outfit');"
          >
            {stat.value}
          </div>
          <div
            class="text-[9px] text-white/25
              uppercase tracking-widest mt-1
              font-semibold"
          >
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- ═══ RECENT MOVIES ═══ -->
    <section class="mb-16 reveal-stagger">
      <div
        class="flex items-center justify-between mb-6"
      >
        <div class="flex items-center gap-2">
          <span class="text-lg">🎬</span>
          <h2
            class="text-xl font-bold text-white"
            style="font-family:
              var(--font-display, 'Outfit');"
          >
            Recently Watched
          </h2>
        </div>
      </div>

      <div class="space-y-2 mb-6">
        {recentMovies.map((movie) => (
          <div
            class="group flex items-center gap-4
              p-3 rounded-xl bg-white/[0.01]
              border border-white/[0.03]
              hover:border-white/8
              hover:bg-white/[0.02]
              transition-all duration-200"
          >
            <div
              class="flex items-center
                justify-center h-8 w-8
                rounded-lg bg-white/[0.03]
                text-xs font-bold text-white/20
                flex-shrink-0"
            >
              {movie.rating ? (
                <span class="text-teal-400/70">
                  {movie.rating}
                </span>
              ) : (
                <span>—</span>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <h4
                class="text-sm font-medium
                  text-white/70 truncate
                  group-hover:text-white/90
                  transition-colors"
              >
                {movie.title}
              </h4>
              <p class="text-[10px] text-white/20">
                {movie.year}
                {(movie.genres || [])[0] &&
                  ` · ${(movie.genres || [])[0]}`}
              </p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="flex justify-center">
        <a href="/library/movies-watched" class="text-xs px-4 py-2 rounded-lg bg-white/[0.03] border border-white/5 hover:bg-white/[0.05] text-white/60 hover:text-white transition-colors">
          View all history
        </a>
      </div>
    </section>

    <!-- ═══ TOP RATED ═══ -->
    {topRatedMovies.length > 0 && (
      <section class="mb-16 reveal-stagger">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-2">
            <span class="text-lg">⭐</span>
            <h2 class="text-xl font-bold text-white" style="font-family: var(--font-display, 'Outfit');">
              Top Rated
            </h2>
          </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
          {topRatedMovies.map((movie) => (
            <div class="group p-4 rounded-xl bg-white/[0.015] border border-white/5 hover:border-amber-500/15 transition-all duration-200">
              <div class="flex items-center gap-2 mb-2">
                <span class="flex items-center justify-center h-7 w-7 rounded-lg bg-amber-500/10 text-amber-400 text-xs font-black">
                  {movie.rating}
                </span>
                <span class="text-[9px] text-white/20 uppercase tracking-wider">/10</span>
              </div>
              <h4 class="text-sm font-semibold text-white/80 mb-1 line-clamp-2 group-hover:text-amber-300 transition-colors leading-tight">
                {movie.title}
              </h4>
              <p class="text-[10px] text-white/20">
                {movie.year}
                {(movie.genres || [])[0] && ` · ${(movie.genres || [])[0]}`}
              </p>
            </div>
          ))}
        </div>
        
        <div class="flex justify-center">
          <a href="/library/movies-rated" class="text-xs px-4 py-2 rounded-lg bg-white/[0.03] border border-white/5 hover:bg-white/[0.05] text-white/60 hover:text-white transition-colors">
            View all top rated
          </a>
        </div>
      </section>
    )}

    <!-- Trakt Profile Link -->
    <div class="mt-20 p-6 rounded-2xl bg-gradient-to-br from-red-500/5 to-rose-500/5 border border-red-500/10 text-center flex flex-col items-center">
      <div class="h-12 w-12 rounded-full bg-red-500/10 text-red-400 flex items-center justify-center text-xl mb-4">
        📽️
      </div>
      <h3 class="text-lg font-bold text-white mb-2">Complete Profile</h3>
      <p class="text-sm text-white/40 mb-6 max-w-md">
        For the complete, unfiltered history of everything I've watched, rated, and reviewed.
      </p>
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500/10 text-red-400 font-semibold text-sm hover:bg-red-500/20 hover:scale-105 transition-all outline-none focus:ring-2 focus:ring-red-500/50">
        View Trakt Profile
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
