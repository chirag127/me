---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db = {
  watched: [] as any[],
  watchlist: [] as any[],
  shows: [] as any[],
  stats: { totalWatched: 0, totalShows: 0 },
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn(
    '[Movies Hub] movies.json not found. Run pnpm run fetch-data first.',
  );
}

const watched = db.watched || [];
const wantToWatch = db.watchlist || [];
const _currentlyWatching =
  db.shows?.filter((s) => s.category === 'watching') || [];
const topRated = [...watched]
  .sort((a, b) => (b.rating || 0) - (a.rating || 0))
  .slice(0, 8);
const shows = db.shows || [];

const genreCounts: Record<string, number> = {};
watched.forEach((m) => {
  if (m.genres && m.genres.length > 0) {
    const genre = m.genres[0];
    genreCounts[genre] = (genreCounts[genre] || 0) + 1;
  }
});
const favoriteGenres = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map((g) => g[0]);
const validRatings = watched.filter((w) => w.rating);
const avgRating =
  validRatings.length > 0
    ? (
        validRatings.reduce((s, m) => s + m.rating, 0) / validRatings.length
      ).toFixed(1)
    : '0.0';

const fallbackGradients = [
  'linear-gradient(135deg, #0c1445, #1a237e)',
  'linear-gradient(135deg, #1b3a2d, #2e7d32)',
  'linear-gradient(135deg, #4a148c, #e91e63)',
  'linear-gradient(135deg, #795548, #d7ccc8)',
  'linear-gradient(135deg, #1e3a5f, #0f4c75)',
  'linear-gradient(135deg, #bf360c, #e65100)',
];
const fallbackEmojis = ['🎬', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Movies & TV" description="Chirag Singhal's movie and TV show diary - curated picks, ratings, and watchlist">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-medium text-emerald-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
          <span class="text-xl">🎬</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Movies & TV</h1>
      </div>
      <p class="text-white/40">Film diary - synced from Trakt automatically.</p>
    </div>

    <!-- Sub-page Navigation -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href="/library/movies-watched" class="text-xs px-3 py-1.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 transition-colors">All Watched</a>
      <a href="/library/movies-rated" class="text-xs px-3 py-1.5 rounded-full bg-teal-500/10 text-teal-400 border border-teal-500/20 hover:bg-teal-500/20 transition-colors">Top Rated</a>
      <a href="/library/movies-watchlist" class="text-xs px-3 py-1.5 rounded-full bg-rose-500/10 text-rose-400 border border-rose-500/20 hover:bg-rose-500/20 transition-colors">Watchlist</a>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-emerald-400">{db.stats.totalWatched || watched.length}</div>
        <div class="text-xs text-white/30">Films Watched</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-sky-400">{db.stats.totalShows || shows.length}</div>
        <div class="text-xs text-white/30">Shows</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-rose-400">{wantToWatch.length}</div>
        <div class="text-xs text-white/30">Watchlist Queue</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{avgRating}</div>
        <div class="text-xs text-white/30">Avg Rating /10</div>
      </div>
      <div>
        <div class="text-lg font-bold text-violet-400 truncate max-w-[150px] sm:max-w-none">{favoriteGenres.join(', ') || 'N/A'}</div>
        <div class="text-xs text-white/30">Top Genres</div>
      </div>
    </div>

    <!-- Shows / Currently Watching -->
    <section class="mb-16">
      <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
        Tracking Shows
        <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {shows.slice(0, 4).map((show, i) => {
          const vis = getVisuals(show.title);
          return (
          <div class="glass-strong p-5 flex gap-5 items-center rounded-2xl border border-white/10" style={`animation-delay: ${i * 80}ms`}>
            <div class="h-24 w-24 rounded-xl flex items-center justify-center text-4xl shrink-0 relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-black/10"></div>
              <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-white">{show.title}</h3>
              <p class="text-xs text-white/30 mt-0.5">{show.year} · {(show.genres||[])[0]}</p>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-xs text-sky-400 font-medium">Plays: {show.episodesWatched || 0}</span>
              </div>
            </div>
            {show.rating && (
              <div class="shrink-0 bg-sky-500/10 text-sky-400 text-xs font-semibold px-2.5 py-1 rounded-full">
                {show.rating}/10
              </div>
            )}
          </div>
        )})}
      </div>
    </section>

    <hr class="border-white/5 mb-16" />

    <!-- Top Rated -->
    {topRated.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Top Rated
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {topRated.map((movie, i) => {
            const vis = getVisuals(movie.title);
            return (
            <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 60}ms`}>
              <div class="aspect-[2/3] rounded-t-2xl mb-3 flex items-center justify-center text-4xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                {movie.posterUrl ? (
                  <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover relative z-10" />
                ) : (
                  <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
                )}
                <div class="absolute top-2 right-2 z-20 bg-black/50 backdrop-blur-sm rounded-full px-2 py-0.5">
                  <span class="text-xs font-semibold" style={`color: ${movie.rating >= 9 ? '#34d399' : '#2dd4bf'}`}>{movie.rating}</span>
                </div>
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-sm font-semibold text-white truncate group-hover:text-emerald-400 transition-colors">{movie.title}</h3>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-xs text-white/30">{movie.year}</span>
                  <span class="w-1 h-1 rounded-full bg-white/20"></span>
                  <span class="text-xs text-white/30 truncate">{(movie.genres||[])[0]}</span>
                </div>
              </div>
            </div>
          )})}
        </div>
      </section>
    )}

    {topRated.length > 0 && <hr class="border-white/5 mb-16" />}

    <!-- Recently Watched -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-semibold text-white relative inline-block">
          Recently Watched
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
        </h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        {watched.slice(0, 12).map((movie, i) => {
          const vis = getVisuals(movie.title);
          return (
          <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 50}ms`}>
            <div class="aspect-[2/3] rounded-t-2xl mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              {movie.rating && (
                <div class="absolute top-1.5 right-1.5 z-20 bg-black/50 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                  <span class="text-[0.6rem] font-semibold text-teal-400">{movie.rating}</span>
                </div>
              )}
            </div>
            <div class="px-3 pb-3">
              <h3 class="text-xs font-semibold text-white truncate group-hover:text-emerald-400 transition-colors">{movie.title}</h3>
              <span class="text-[0.65rem] text-white/20 truncate max-w-full block">{movie.year} · {(movie.genres||[])[0]}</span>
            </div>
          </div>
        )})}
      </div>
    </section>

    <hr class="border-white/5 mb-16" />

    <!-- Watchlist -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-semibold text-white relative inline-block">
          Watchlist
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-rose-400 to-transparent rounded-full"></span>
        </h2>
        <span class="text-xs text-white/20">{wantToWatch.length} queued</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {wantToWatch.slice(0, 8).map((movie, i) => {
          const vis = getVisuals(movie.title);
          return (
          <div class="glass rounded-2xl border border-white/5 hover:border-rose-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 60}ms`}>
            <div class="aspect-[2/3] rounded-t-2xl mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
            </div>
            <div class="px-3 pb-3">
              <h3 class="text-xs font-semibold text-white truncate group-hover:text-rose-400 transition-colors">{movie.title}</h3>
              <span class="text-[0.65rem] text-white/20 block truncate max-w-full">{movie.year} · {(movie.genres||[])[0]}</span>
            </div>
          </div>
        )})}
      </div>
    </section>
  </main>
</Layout>
