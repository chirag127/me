---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import AIChat from '../../components/islands/AIChat';

interface Movie {
  title: string;
  year: string;
  genre: string;
  rating: number;
  emoji: string;
  gradient: string;
  category: 'watched' | 'watching' | 'want-to-watch';
  episodes?: string;
}

const movies: Movie[] = [
  { title: 'Interstellar', year: '2014', genre: 'Sci-Fi', rating: 9.5, emoji: '🌌', gradient: 'linear-gradient(135deg, #0c1445, #1a237e)', category: 'watched' },
  { title: 'The Shawshank Redemption', year: '1994', genre: 'Drama', rating: 10, emoji: '🔒', gradient: 'linear-gradient(135deg, #1b3a2d, #2e7d32)', category: 'watched' },
  { title: 'Inception', year: '2010', genre: 'Sci-Fi', rating: 9, emoji: '🌀', gradient: 'linear-gradient(135deg, #1a1a2e, #16213e)', category: 'watched' },
  { title: 'Parasite', year: '2019', genre: 'Thriller', rating: 9, emoji: '🏠', gradient: 'linear-gradient(135deg, #2d1b00, #5d4037)', category: 'watched' },
  { title: 'The Dark Knight', year: '2008', genre: 'Action', rating: 9, emoji: '🦇', gradient: 'linear-gradient(135deg, #0d0d0d, #37474f)', category: 'watched' },
  { title: 'Spirited Away', year: '2001', genre: 'Animation', rating: 10, emoji: '🏯', gradient: 'linear-gradient(135deg, #1a237e, #7b1fa2)', category: 'watched' },
  { title: 'The Prestige', year: '2006', genre: 'Mystery', rating: 9, emoji: '🎩', gradient: 'linear-gradient(135deg, #1a1a1a, #4a148c)', category: 'watched' },
  { title: 'Whiplash', year: '2014', genre: 'Drama', rating: 9, emoji: '🥁', gradient: 'linear-gradient(135deg, #b71c1c, #e65100)', category: 'watched' },
  { title: 'Oppenheimer', year: '2023', genre: 'Biography', rating: 8.5, emoji: '💥', gradient: 'linear-gradient(135deg, #bf360c, #e65100)', category: 'watched' },
  { title: 'Dune: Part Two', year: '2024', genre: 'Sci-Fi', rating: 8.5, emoji: '🏜️', gradient: 'linear-gradient(135deg, #795548, #d7ccc8)', category: 'watched' },
  { title: 'Poor Things', year: '2023', genre: 'Comedy', rating: 8, emoji: '🧪', gradient: 'linear-gradient(135deg, #4a148c, #e91e63)', category: 'watched' },
  { title: 'Past Lives', year: '2023', genre: 'Romance', rating: 8.5, emoji: '💫', gradient: 'linear-gradient(135deg, #1a237e, #0d47a1)', category: 'watched' },
  { title: 'The Holdovers', year: '2023', genre: 'Drama', rating: 8, emoji: '🎄', gradient: 'linear-gradient(135deg, #3e2723, #795548)', category: 'watched' },
  { title: 'Killers of the Flower Moon', year: '2023', genre: 'Crime', rating: 7.5, emoji: '🌾', gradient: 'linear-gradient(135deg, #1b5e20, #33691e)', category: 'watched' },
  { title: 'Severance', year: '2022', genre: 'Sci-Fi', rating: 9, emoji: '🏢', gradient: 'linear-gradient(135deg, #1e3a5f, #0f4c75)', category: 'watching', episodes: 'S2 · E7' },
  { title: 'Shogun', year: '2024', genre: 'Drama', rating: 9, emoji: '⚔️', gradient: 'linear-gradient(135deg, #78350f, #b45309)', category: 'watching', episodes: 'S1 · E8' },
  { title: 'The Substance', year: '2024', genre: 'Horror', rating: 0, emoji: '💉', gradient: 'linear-gradient(135deg, #880e4f, #ad1457)', category: 'want-to-watch' },
  { title: 'Anora', year: '2024', genre: 'Drama', rating: 0, emoji: '💎', gradient: 'linear-gradient(135deg, #f57f17, #ff6f00)', category: 'want-to-watch' },
  { title: 'Conclave', year: '2024', genre: 'Thriller', rating: 0, emoji: '⛪', gradient: 'linear-gradient(135deg, #b71c1c, #880e4f)', category: 'want-to-watch' },
  { title: 'The Brutalist', year: '2024', genre: 'Drama', rating: 0, emoji: '🏗️', gradient: 'linear-gradient(135deg, #37474f, #263238)', category: 'want-to-watch' },
  { title: 'Nosferatu', year: '2024', genre: 'Horror', rating: 0, emoji: '🧛', gradient: 'linear-gradient(135deg, #1a1a1a, #212121)', category: 'want-to-watch' },
  { title: 'Challengers', year: '2024', genre: 'Drama', rating: 0, emoji: '🎾', gradient: 'linear-gradient(135deg, #1b5e20, #2e7d32)', category: 'want-to-watch' },
];

const currentlyWatching = movies.filter(m => m.category === 'watching');
const watched = movies.filter(m => m.category === 'watched');
const wantToWatch = movies.filter(m => m.category === 'want-to-watch');
const topRated = [...watched].sort((a, b) => b.rating - a.rating).slice(0, 8);

const genreCounts: Record<string, number> = {};
watched.forEach(m => { genreCounts[m.genre] = (genreCounts[m.genre] || 0) + 1; });
const favoriteGenres = Object.entries(genreCounts).sort((a, b) => b[1] - a[1]).slice(0, 3).map(g => g[0]);
const avgRating = (watched.reduce((s, m) => s + m.rating, 0) / watched.length).toFixed(1);
---

<Layout title="Movies" description="Chirag Singhal's movie diary — curated picks, ratings, and watchlist">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-sage)]/10 flex items-center justify-center">
        <span class="text-xl">🎬</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Movies & TV</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Film diary — everything I've watched, rated, and queued up.</p>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sage)]">{watched.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Watched</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{currentlyWatching.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Watching</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-rose)]">{wantToWatch.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Watchlist</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{avgRating}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Avg Rating</div>
      </div>
      <div>
        <div class="text-lg font-bold text-[var(--color-accent-violet)]">{favoriteGenres.join(', ')}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Top Genres</div>
      </div>
    </div>

    <!-- Currently Watching -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Currently Watching</h2>
        <div class="dot-live"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {currentlyWatching.map((movie, i) => (
          <div class="glass-strong p-5 flex gap-5 items-center" style={`animation-delay: ${i * 80}ms`}>
            <div class="h-24 w-24 rounded-xl flex items-center justify-center text-4xl shrink-0 relative overflow-hidden" style={`background: ${movie.gradient}`}>
              <div class="absolute inset-0 bg-black/10"></div>
              <span class="relative z-10 drop-shadow-lg">{movie.emoji}</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-white">{movie.title}</h3>
              <p class="text-xs text-[var(--color-text-muted)] mt-0.5">{movie.year} · {movie.genre}</p>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-xs text-[var(--color-accent-sky)] font-medium">{movie.episodes}</span>
              </div>
              <div class="mt-2 h-1.5 bg-white/5 rounded-full overflow-hidden">
                <div class="h-full bg-[var(--color-accent-sky)] rounded-full" style="width: 65%"></div>
              </div>
            </div>
            <div class="shrink-0 bg-[var(--color-accent-sky)]/10 text-[var(--color-accent-sky)] text-xs font-semibold px-2.5 py-1 rounded-full">
              {movie.rating}/10
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Top Rated -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">Top Rated</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {topRated.map((movie, i) => (
          <div class="card group cursor-default" style={`animation-delay: ${i * 60}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-3 flex items-center justify-center text-4xl relative overflow-hidden" style={`background: ${movie.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              <span class="relative z-10 drop-shadow-lg">{movie.emoji}</span>
              <div class="absolute top-2 right-2 z-10 bg-black/50 backdrop-blur-sm rounded-full px-2 py-0.5">
                <span class="text-xs font-semibold" style={`color: ${movie.rating >= 9 ? 'var(--color-success)' : 'var(--color-primary)'}`}>{movie.rating}</span>
              </div>
            </div>
            <h3 class="text-sm font-semibold text-white truncate group-hover:text-[var(--color-success)] transition-colors">{movie.title}</h3>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs text-[var(--color-text-muted)]">{movie.year}</span>
              <span class="w-1 h-1 rounded-full bg-[var(--color-text-faint)]"></span>
              <span class="text-xs text-[var(--color-text-muted)]">{movie.genre}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Recently Watched -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Recently Watched</h2>
        <span class="text-xs text-[var(--color-text-faint)]">{watched.length} films total</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        {watched.map((movie, i) => (
          <div class="card group cursor-default" style={`animation-delay: ${i * 50}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${movie.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <span class="relative z-10 drop-shadow-lg">{movie.emoji}</span>
              <div class="absolute top-1.5 right-1.5 z-10 bg-black/50 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                <span class="text-[0.6rem] font-semibold text-[var(--color-primary)]">{movie.rating}</span>
              </div>
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-sage)] transition-colors">{movie.title}</h3>
            <span class="text-[0.65rem] text-[var(--color-text-faint)]">{movie.year} · {movie.genre}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Watchlist -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Watchlist</h2>
        <span class="text-xs text-[var(--color-text-faint)]">{wantToWatch.length} queued</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {wantToWatch.map((movie, i) => (
          <div class="card group cursor-default" style={`animation-delay: ${i * 60}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${movie.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <span class="relative z-10 drop-shadow-lg">{movie.emoji}</span>
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-rose)] transition-colors">{movie.title}</h3>
            <span class="text-[0.65rem] text-[var(--color-text-faint)]">{movie.year} · {movie.genre}</span>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
  <AIChat client:load />
  <ChatWidget client:load />
</Layout>
