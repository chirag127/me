---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';

// Fallback data structure
let db = { read: [] as any[], reading: [] as any[], wantToRead: [] as any[] };

try {
  const raw = await fs.readFile(path.resolve('./src/data/generated/books.json'), 'utf-8');
  db = JSON.parse(raw);
} catch (e) {
  console.warn('[Books Hub] books.json not found. Run pnpm run fetch-data first.');
}

const currentlyReading = db.reading || [];
const read = db.read || [];
const wantToRead = db.wantToRead || [];

const fallbackGradients = [
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #92400e, #b45309)',
  'linear-gradient(135deg, #4a148c, #7b1fa2)',
  'linear-gradient(135deg, #1a237e, #283593)',
  'linear-gradient(135deg, #1a1a1a, #37474f)',
  'linear-gradient(135deg, #0c1445, #1565c0)',
];
const fallbackEmojis = ['📚', '📖', '📘', '📕', '📗', '📙', '🔖', '📓'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length]
  };
}
---

<Layout title="Books" description="Chirag Singhal's reading list — currently reading, completed, and want-to-read synced from OpenLibrary">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center">
        <span class="text-xl">📚</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Books</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Reading diary — synced automatically from OpenLibrary.</p>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-success)]">{read.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Books Read</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{currentlyReading.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Currently Reading</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-rose)]">{wantToRead.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Want to Read</div>
      </div>
    </div>

    <!-- Currently Reading -->
    {currentlyReading.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-8">
          <h2 class="section-heading text-xl font-semibold text-white">Currently Reading</h2>
          <div class="dot-live" style="background: var(--color-primary); box-shadow: 0 0 8px rgba(245, 158, 11, 0.5);"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {currentlyReading.map((book, i) => {
            const vis = getVisuals(book.title);
            return (
            <div class="glass-strong p-5 flex gap-5 items-center" style={`animation-delay: ${i * 80}ms`}>
              <div class="h-24 w-20 rounded-xl flex items-center justify-center text-4xl shrink-0 relative overflow-hidden" style={`background: ${vis.gradient}`}>
                <div class="absolute inset-0 bg-black/10"></div>
                {book.coverUrl ? (
                  <img src={book.coverUrl} alt={book.title} class="w-full h-full object-cover relative z-10" loading="lazy" />
                ) : (
                  <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-white">{book.title}</h3>
                <p class="text-xs text-[var(--color-text-muted)] mt-0.5">{(book.authors || []).join(', ')}</p>
                {book.firstPublishYear && <p class="text-[0.65rem] text-[var(--color-text-faint)] mt-0.5">{book.firstPublishYear}</p>}
                <div class="mt-2 flex items-center gap-3">
                  <div class="flex-1 h-1.5 bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full bg-[var(--color-primary)] rounded-full w-full animate-pulse opacity-50"></div>
                  </div>
                </div>
              </div>
            </div>
          )})}
        </div>
      </section>
    )}

    {currentlyReading.length > 0 && <div class="divider-warm mb-16"></div>}

    <!-- Read -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Read</h2>
        <span class="text-xs text-[var(--color-text-faint)]">{read.length} books</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {read.map((book, i) => {
          const vis = getVisuals(book.title);
          return (
          <div class="card group cursor-default" style={`animation-delay: ${i * 50}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              {book.coverUrl ? (
                <img src={book.coverUrl} alt={book.title} class="w-full h-full object-cover relative z-10 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-success)] transition-colors">{book.title}</h3>
            <p class="text-[0.65rem] text-[var(--color-text-faint)] truncate max-w-full block">{(book.authors || []).join(', ')}</p>
          </div>
        )})}
      </div>
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Want to Read -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Want to Read</h2>
        <span class="text-xs text-[var(--color-text-faint)]">{wantToRead.length} queued</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {wantToRead.map((book, i) => {
          const vis = getVisuals(book.title);
          return (
          <div class="card group cursor-default" style={`animation-delay: ${i * 60}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              {book.coverUrl ? (
                <img src={book.coverUrl} alt={book.title} class="w-full h-full object-cover relative z-10 opacity-80" loading="lazy" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-rose)] transition-colors">{book.title}</h3>
            <p class="text-[0.65rem] text-[var(--color-text-faint)] truncate block max-w-full">{(book.authors || []).join(', ')}</p>
          </div>
        )})}
      </div>
    </section>
  </main>
  <Footer />
  <ChatWidget client:load />
</Layout>
