---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { watched: [], stats: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Movies Watched] movies.json not found.');
}

const watched = db.watched || [];
const sortedByDate = [...watched].sort(
  (a: any, b: any) =>
    new Date(b.watchedAt || 0).getTime() - new Date(a.watchedAt || 0).getTime(),
);

const genreCounts: Record<string, number> = {};
watched.forEach((m: any) => {
  if (m.genres?.[0])
    genreCounts[m.genres[0]] = (genreCounts[m.genres[0]] || 0) + 1;
});
const topGenres = Object.entries(genreCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const validRatings = watched.filter((m: any) => m.rating);
const avgRating =
  validRatings.length > 0
    ? (
        validRatings.reduce((s: number, m: any) => s + m.rating, 0) /
        validRatings.length
      ).toFixed(1)
    : 'N/A';

const totalRuntime = watched.reduce(
  (s: number, m: any) => s + (m.runtime || 0),
  0,
);
const totalHours = Math.round(totalRuntime / 60);

const fallbackGradients = [
  'linear-gradient(135deg, #0c1445, #1a237e)',
  'linear-gradient(135deg, #1b3a2d, #2e7d32)',
  'linear-gradient(135deg, #4a148c, #e91e63)',
  'linear-gradient(135deg, #795548, #d7ccc8)',
  'linear-gradient(135deg, #1e3a5f, #0f4c75)',
  'linear-gradient(135deg, #bf360c, #e65100)',
];
const fallbackEmojis = ['🎬', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Watched Movies" description="All movies Chirag Singhal has watched">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/movies" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Movies
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-sage)]/10 flex items-center justify-center">
        <span class="text-xl">✅</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Watched Movies</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">All {watched.length} films I've watched — sorted by most recent.</p>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-6">
      <div>
        <div class="text-2xl font-bold text-[var(--color-success)]">{watched.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Films</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{avgRating}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Avg Rating</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{totalHours}h</div>
        <div class="text-xs text-[var(--color-text-muted)]">Watch Time</div>
      </div>
      {topGenres.slice(0, 3).map(([genre, count]) => (
        <div>
          <div class="text-lg font-bold text-[var(--color-accent-violet)]">{count}</div>
          <div class="text-xs text-[var(--color-text-muted)]">{genre}</div>
        </div>
      ))}
    </div>

    {sortedByDate.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {sortedByDate.map((movie: any, i: number) => {
          const vis = getVisuals(movie.title);
          return (
          <div class="card group cursor-default" style={`animation-delay: ${i * 30}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              {movie.posterUrl ? (
                <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover relative z-10 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
              {movie.rating && (
                <div class="absolute top-1.5 right-1.5 z-20 bg-black/50 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                  <span class="text-[0.6rem] font-semibold" style={`color: ${movie.rating >= 8 ? 'var(--color-success)' : 'var(--color-primary)'}`}>{movie.rating}</span>
                </div>
              )}
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-sage)] transition-colors">{movie.title}</h3>
            <span class="text-[0.65rem] text-[var(--color-text-faint)] truncate max-w-full block">{movie.year} · {(movie.genres||[])[0]}</span>
          </div>
        )})}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-[var(--color-text-muted)]">No watched movies found.</p>
      </div>
    )}
  </main>
  <Footer />
</Layout>
