---import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db = { wantToRead: [] as any[] };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/books.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Books Want to Read] books.json not found.');
}

const wantToRead = db.wantToRead || [];

const fallbackGradients = [
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #92400e, #b45309)',
  'linear-gradient(135deg, #4a148c, #7b1fa2)',
  'linear-gradient(135deg, #1a237e, #283593)',
  'linear-gradient(135deg, #1a1a1a, #37474f)',
  'linear-gradient(135deg, #0c1445, #1565c0)',
];
const fallbackEmojis = ['📚', '📖', '📘', '📕', '📗', '📙', '🔖', '📓'];

function _getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Want to Read" description="Books Chirag Singhal wants to read">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/books" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Books
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-rose)]/10 flex items-center justify-center">
        <span class="text-xl">📋</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Want to Read</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Reading queue — {wantToRead.length} books.</p>

    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-rose)]">{wantToRead.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Queued</div>
      </div>
    </div>

    {wantToRead.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {wantToRead.map((book: any, i: number) => {
          const vis = getVisuals(book.title);
          return (
          <div class="card group cursor-default" style={`animation-delay: ${i * 40}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              {book.coverUrl ? (
                <img src={book.coverUrl} alt={book.title} class="w-full h-full object-cover relative z-10 opacity-80" loading="lazy" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-rose)] transition-colors">{book.title}</h3>
            <p class="text-[0.65rem] text-[var(--color-text-faint)] truncate block max-w-full">{(book.authors || []).join(', ')}</p>
          </div>
        )})}
      </div>
    ) : (
      <div class="glass p-12 text-center"><p class="text-[var(--color-text-muted)]">Reading queue is empty.</p></div>
    )}
  </main>
  <Footer />
</Layout>
