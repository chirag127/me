---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Anime Completed] anime.json not found.');
}

const completed = db.anime?.completed || [];

function _scoreColor(score: number | null): string {
  if (!score) return 'var(--color-text-faint)';
  if (score >= 8) return 'var(--color-success)';
  if (score >= 6) return 'var(--color-primary)';
  return 'var(--color-accent-warm)';
}

const sorted = [...completed].sort(
  (a: any, b: any) => (b.score || 0) - (a.score || 0),
);
const avgScore =
  sorted.filter((a: any) => a.score).length > 0
    ? (
        sorted
          .filter((a: any) => a.score)
          .reduce((s: number, a: any) => s + a.score, 0) /
        sorted.filter((a: any) => a.score).length
      ).toFixed(1)
    : 'N/A';
const totalEps = sorted.reduce(
  (s: number, a: any) => s + (a.episodes || 0),
  0,
);
---

<Layout title="Completed Anime" description="All anime Chirag Singhal has completed">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-success)]/10 flex items-center justify-center">
        <span class="text-xl">✅</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Completed Anime</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">All {sorted.length} completed anime — sorted by score.</p>

    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-success)]">{sorted.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Completed</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{avgScore}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Mean Score</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{totalEps.toLocaleString()}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Total Episodes</div>
      </div>
    </div>

    {sorted.length > 0 ? (
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
        {sorted.map((entry: any, i: number) => (
          <div class="card group cursor-default" style={`animation-delay: ${i * 30}ms`}>
            <div class="relative rounded-lg overflow-hidden mb-2">
              {entry.coverUrl ? (
                <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
              ) : (
                <div class="w-full aspect-[3/4] bg-[var(--color-accent-sky)]/10 flex items-center justify-center text-3xl">🌸</div>
              )}
              {entry.score && (
                <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                  <span class="text-[0.6rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                </div>
              )}
            </div>
            <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-[var(--color-success)] transition-colors">{entry.title}</h3>
            <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.episodes || '?'} eps</p>
          </div>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center"><p class="text-[var(--color-text-muted)]">No completed anime found.</p></div>
    )}
  </main>
  <Footer />
</Layout>
