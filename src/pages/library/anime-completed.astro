---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Anime Completed] anime.json not found.');
}

const completed = db.anime?.completed || [];

function scoreColor(score: number | null): string {
  if (!score) return '#52525b';
  if (score >= 8) return '#34d399';
  if (score >= 6) return '#2dd4bf';
  return '#fbbf24';
}

const sorted = [...completed].sort(
  (a: any, b: any) => (b.score || 0) - (a.score || 0),
);
const avgScore =
  sorted.filter((a: any) => a.score).length > 0
    ? (
        sorted
          .filter((a: any) => a.score)
          .reduce((s: number, a: any) => s + a.score, 0) /
        sorted.filter((a: any) => a.score).length
      ).toFixed(1)
    : 'N/A';
const totalEps = sorted.reduce(
  (s: number, a: any) => s + (a.episodes || 0),
  0,
);
---

<Layout title="Completed Anime" description="All anime Chirag Singhal has completed">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-xs font-medium text-sky-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
          <span class="text-xl">✅</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Completed Anime</h1>
      </div>
      <p class="text-white/40">All {sorted.length} completed anime - sorted by score.</p>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-emerald-400">{sorted.length}</div>
        <div class="text-xs text-white/30">Completed</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{avgScore}</div>
        <div class="text-xs text-white/30">Mean Score</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-sky-400">{totalEps.toLocaleString()}</div>
        <div class="text-xs text-white/30">Total Episodes</div>
      </div>
    </div>

    {sorted.length > 0 ? (
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
        {sorted.map((entry: any, i: number) => (
          <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
            <div class="relative rounded-t-2xl overflow-hidden mb-2">
              {entry.coverUrl ? (
                <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
              ) : (
                <div class="w-full aspect-[3/4] bg-sky-500/10 flex items-center justify-center text-3xl">🌸</div>
              )}
              {entry.score && (
                <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                  <span class="text-[0.6rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                </div>
              )}
            </div>
            <div class="px-3 pb-3">
              <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-emerald-400 transition-colors">{entry.title}</h3>
              <p class="text-[0.6rem] text-white/20">{entry.episodes || '?'} eps</p>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center rounded-2xl border border-white/5"><p class="text-white/30">No completed anime found.</p></div>
    )}
  </main>
</Layout>
