---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import AIChat from '../../components/islands/AIChat';

interface CuratedAnime {
  title: string;
  genre: string;
  rating: number;
  emoji: string;
  gradient: string;
  episodes: number;
  year: string;
}

let db: any = { anime: { watching: [], completed: [] } };

try {
  const raw = await fs.readFile(path.resolve('./src/data/generated/anime.json'), 'utf-8');
  db = JSON.parse(raw);
} catch (e) {
  console.warn('[Anime Hub] anime.json not found. Run pnpm run fetch-data first.');
}

const currentlyWatching = db.anime?.watching || [];
const completedAnime = db.anime?.completed || [];

const curatedFallback: CuratedAnime[] = [
  { title: 'Fullmetal Alchemist: Brotherhood', genre: 'Action', rating: 10, emoji: '⚗️', gradient: 'linear-gradient(135deg, #b91c1c, #dc2626)', episodes: 64, year: '2009' },
  { title: 'Attack on Titan', genre: 'Action', rating: 9.5, emoji: '⚔️', gradient: 'linear-gradient(135deg, #365314, #4d7c0f)', episodes: 87, year: '2013' },
  { title: 'Steins;Gate', genre: 'Sci-Fi', rating: 9.5, emoji: '🔬', gradient: 'linear-gradient(135deg, #065f46, #047857)', episodes: 24, year: '2011' },
  { title: 'Death Note', genre: 'Thriller', rating: 9, emoji: '📓', gradient: 'linear-gradient(135deg, #1a1a1a, #292524)', episodes: 37, year: '2006' },
  { title: 'Your Name', genre: 'Romance', rating: 9.5, emoji: '🌠', gradient: 'linear-gradient(135deg, #1e3a5f, #0369a1)', episodes: 1, year: '2016' },
  { title: 'Cowboy Bebop', genre: 'Sci-Fi', rating: 9, emoji: '🚀', gradient: 'linear-gradient(135deg, #78350f, #b45309)', episodes: 26, year: '1998' },
  { title: 'Violet Evergarden', genre: 'Drama', rating: 9, emoji: '✉️', gradient: 'linear-gradient(135deg, #6d28d9, #8b5cf6)', episodes: 13, year: '2018' },
  { title: 'Demon Slayer', genre: 'Action', rating: 8.5, emoji: '🔥', gradient: 'linear-gradient(135deg, #166534, #15803d)', episodes: 44, year: '2019' },
  { title: 'Spy x Family', genre: 'Comedy', rating: 8.5, emoji: '🕵️', gradient: 'linear-gradient(135deg, #eab308, #facc15)', episodes: 37, year: '2022' },
  { title: 'Jujutsu Kaisen', genre: 'Action', rating: 8.5, emoji: '👁️', gradient: 'linear-gradient(135deg, #7c2d12, #9a3412)', episodes: 47, year: '2020' },
];

function scoreColor(score: number | null): string {
  if (!score) return 'var(--color-text-faint)';
  if (score >= 8) return 'var(--color-success)';
  if (score >= 6) return 'var(--color-primary)';
  return 'var(--color-accent-warm)';
}

const hasApiData = currentlyWatching.length > 0 || completedAnime.length > 0;
const totalWatched = completedAnime.length || curatedFallback.length;
const totalWatching = currentlyWatching.length || 2;
const meanScore = hasApiData && completedAnime.length > 0
  ? (completedAnime.reduce((s: number, e: any) => s + (e.score || 0), 0) / completedAnime.filter((e: any) => e.score).length).toFixed(1)
  : (curatedFallback.reduce((s, a) => s + a.rating, 0) / curatedFallback.length).toFixed(1);
---

<Layout title="Anime" description="Chirag Singhal's anime watchlist — currently watching and completed">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-sky)]/10 flex items-center justify-center">
        <span class="text-xl">🌸</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Anime</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Watching, completed, and rated — from AniList automatically.</p>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{totalWatching}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Watching</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-success)]">{totalWatched}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Completed</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{meanScore}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Mean Score</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-violet)]">
          {hasApiData
            ? currentlyWatching.reduce((sum: number, e: any) => sum + (e.progress || 0), 0) + completedAnime.reduce((sum: number, e: any) => sum + (e.episodes || 0), 0)
            : curatedFallback.reduce((s, a) => s + a.episodes, 0)}
        </div>
        <div class="text-xs text-[var(--color-text-muted)]">Total Episodes</div>
      </div>
    </div>

    <!-- Currently Watching -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Currently Watching</h2>
        <div class="dot-live"></div>
      </div>

      {hasApiData && currentlyWatching.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">
          {currentlyWatching.map((entry: any, i: number) => {
            const pct = entry.episodes ? Math.round((entry.progress / entry.episodes) * 100) : 0;
            return (
              <div class="card group cursor-default" style={`animation-delay: ${i * 60}ms`}>
                <div class="relative rounded-lg overflow-hidden mb-3">
                  <img
                    src={entry.coverUrl}
                    alt={entry.title}
                    class="w-full aspect-[3/4] object-cover"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 h-1 bg-black/40">
                    <div class="h-full bg-[var(--color-accent-sky)] transition-all" style={`width: ${pct}%`}></div>
                  </div>
                  {entry.score && (
                    <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-full px-2 py-0.5">
                      <span class="text-[0.65rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                    </div>
                  )}
                </div>
                <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-sky)] transition-colors">{entry.title}</h3>
                <p class="text-[0.65rem] text-[var(--color-text-faint)] mt-0.5">
                  {entry.progress}{entry.episodes ? ` / ${entry.episodes}` : ''} eps
                </p>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {curatedFallback.slice(0, 2).map((anime, i) => (
            <div class="glass-strong p-5 flex gap-5 items-center" style={`animation-delay: ${i * 80}ms`}>
              <div class="h-24 w-20 rounded-xl flex items-center justify-center text-4xl shrink-0 relative overflow-hidden" style={`background: ${anime.gradient}`}>
                <div class="absolute inset-0 bg-black/10"></div>
                <span class="relative z-10 drop-shadow-lg">{anime.emoji}</span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-white">{anime.title}</h3>
                <p class="text-xs text-[var(--color-text-muted)] mt-0.5">{anime.year} · {anime.genre}</p>
                <div class="mt-2 h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-[var(--color-accent-sky)] rounded-full" style={`width: ${Math.round(60 + i * 20)}%`}></div>
                </div>
                <p class="text-[0.65rem] text-[var(--color-text-faint)] mt-1">{Math.round(anime.episodes * 0.6)}/{anime.episodes} eps</p>
              </div>
              <div class="shrink-0 bg-[var(--color-accent-sky)]/10 text-[var(--color-accent-sky)] text-xs font-semibold px-2.5 py-1 rounded-full">
                {anime.rating}
              </div>
            </div>
          ))}
        </div>
      )}
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Completed / Curated -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">
        {hasApiData ? 'Completed' : 'Favorites'}
      </h2>

      {hasApiData && completedAnime.length > 0 ? (
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
          {completedAnime.map((entry: any, i: number) => {
            return (
              <div class="card group cursor-default" style={`animation-delay: ${i * 40}ms`}>
                <div class="relative rounded-lg overflow-hidden mb-2">
                  <img
                    src={entry.coverUrl}
                    alt={entry.title}
                    class="w-full aspect-[3/4] object-cover"
                    loading="lazy"
                  />
                  {entry.score && (
                    <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                      <span class="text-[0.6rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                    </div>
                  )}
                </div>
                <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-[var(--color-success)] transition-colors">{entry.title}</h3>
                <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.episodes || '?'} eps</p>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
          {curatedFallback.map((anime, i) => (
            <div class="card group cursor-default" style={`animation-delay: ${i * 50}ms`}>
              <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${anime.gradient}`}>
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                <span class="relative z-10 drop-shadow-lg">{anime.emoji}</span>
                <div class="absolute top-1.5 right-1.5 z-10 bg-black/50 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                  <span class="text-[0.6rem] font-semibold" style={`color: ${anime.rating >= 9 ? 'var(--color-success)' : 'var(--color-primary)'}`}>{anime.rating}</span>
                </div>
              </div>
              <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-success)] transition-colors">{anime.title}</h3>
              <span class="text-[0.65rem] text-[var(--color-text-faint)]">{anime.year} · {anime.genre}</span>
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- Source note -->
    <div class="glass p-6 flex items-center gap-4">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-sky)]/10 flex items-center justify-center shrink-0">
        <svg class="h-5 w-5 text-[var(--color-accent-sky)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-white font-medium">{hasApiData ? 'Data fetched from AniList at Build Time' : 'Curated picks'}</p>
        <p class="text-xs text-[var(--color-text-muted)]">{hasApiData ? 'Stats refreshed automatically during site build via GitHub Actions.' : 'AniList data unavailable at build — showing hand-curated favorites.'}</p>
      </div>
    </div>
  </main>
  <Footer />
  <AIChat client:load />
  <ChatWidget client:load />
</Layout>
