---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: { watching: [], completed: [] } };

try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn(
    '[Anime Hub] anime.json not found. Run pnpm run fetch-data first.',
  );
}

const currentlyWatching = db.anime?.watching || [];
const completedAnime = db.anime?.completed || [];

function scoreColor(score: number | null): string {
  if (!score) return '#52525b';
  if (score >= 8) return '#34d399';
  if (score >= 6) return '#2dd4bf';
  return '#fbbf24';
}

const hasApiData = currentlyWatching.length > 0 || completedAnime.length > 0;
const totalWatched = completedAnime.length;
const totalWatching = currentlyWatching.length;
const meanScore =
  hasApiData && completedAnime.length > 0
    ? (
        completedAnime.reduce((s: number, e: any) => s + (e.score || 0), 0) /
        completedAnime.filter((e: any) => e.score).length
      ).toFixed(1)
    : '—';
---

<Layout title="Anime" description="Chirag Singhal's anime watchlist - currently watching and completed">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-xs font-medium text-sky-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-sky-500/10 flex items-center justify-center">
          <span class="text-xl">🌸</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Anime</h1>
      </div>
      <p class="text-white/40">Watching, completed, and rated - from AniList automatically.</p>
    </div>

    <!-- Sub-page Navigation -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href="/library/anime-completed" class="text-xs px-3 py-1.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 transition-colors">Completed</a>
      <a href="/library/anime-plan-to-watch" class="text-xs px-3 py-1.5 rounded-full bg-rose-500/10 text-rose-400 border border-rose-500/20 hover:bg-rose-500/20 transition-colors">Plan to Watch</a>
      <a href="/library/manga" class="text-xs px-3 py-1.5 rounded-full bg-violet-500/10 text-violet-400 border border-violet-500/20 hover:bg-violet-500/20 transition-colors">Manga</a>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-sky-400">{totalWatching}</div>
        <div class="text-xs text-white/30">Watching</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-emerald-400">{totalWatched}</div>
        <div class="text-xs text-white/30">Completed</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{meanScore}</div>
        <div class="text-xs text-white/30">Mean Score</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-violet-400">
          {hasApiData
            ? currentlyWatching.reduce((sum: number, e: any) => sum + (e.progress || 0), 0) + completedAnime.reduce((sum: number, e: any) => sum + (e.episodes || 0), 0)
            : 0}
        </div>
        <div class="text-xs text-white/30">Total Episodes</div>
      </div>
    </div>

    <!-- Currently Watching -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xl font-semibold text-white relative inline-block">
          Currently Watching
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
        </h2>
        <span class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
      </div>

      {currentlyWatching.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">
          {currentlyWatching.map((entry: any, i: number) => {
            const pct = entry.episodes ? Math.round((entry.progress / entry.episodes) * 100) : 0;
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-sky-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 60}ms`}>
                <div class="relative rounded-t-2xl overflow-hidden mb-3">
                  <img
                    src={entry.coverUrl}
                    alt={entry.title}
                    class="w-full aspect-[3/4] object-cover"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 h-1 bg-black/40">
                    <div class="h-full bg-sky-400 transition-all" style={`width: ${pct}%`}></div>
                  </div>
                  {entry.score && (
                    <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-full px-2 py-0.5">
                      <span class="text-[0.65rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                    </div>
                  )}
                </div>
                <div class="px-4 pb-4">
                  <h3 class="text-xs font-semibold text-white truncate group-hover:text-sky-400 transition-colors">{entry.title}</h3>
                  <p class="text-[0.65rem] text-white/25 mt-0.5">
                    {entry.progress}{entry.episodes ? ` / ${entry.episodes}` : ''} eps
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12 text-white/30 text-sm border border-white/5 rounded-2xl">
          Not currently watching any anime.
        </div>
      )}
    </section>

    <hr class="border-white/5 mb-16" />

    <!-- Completed -->
    <section class="mb-16">
      <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
        Completed
        <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
      </h2>

      {completedAnime.length > 0 ? (
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
          {completedAnime.map((entry: any, i: number) => {
            return (
              <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 40}ms`}>
                <div class="relative rounded-t-2xl overflow-hidden mb-2">
                  <img
                    src={entry.coverUrl}
                    alt={entry.title}
                    class="w-full aspect-[3/4] object-cover"
                    loading="lazy"
                  />
                  {entry.score && (
                    <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                      <span class="text-[0.6rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                    </div>
                  )}
                </div>
                <div class="px-3 pb-3">
                  <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-emerald-400 transition-colors">{entry.title}</h3>
                  <p class="text-[0.6rem] text-white/20">{entry.episodes || '?'} eps</p>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12 text-white/30 text-sm border border-white/5 rounded-2xl">
          No completed anime tracked on AniList.
        </div>
      )}
    </section>

    <!-- AniList Profile Link -->
    <div class="mt-20 p-6 rounded-2xl bg-gradient-to-br from-sky-500/5 to-blue-500/5 border border-sky-500/10 text-center flex flex-col items-center">
      <div class="h-12 w-12 rounded-full bg-sky-500/10 text-sky-500 flex items-center justify-center text-xl mb-4">
        🌸
      </div>
      <h3 class="text-lg font-bold text-white mb-2">Complete Profile</h3>
      <p class="text-sm text-white/40 mb-6 max-w-md">
        For the complete, unfiltered history of every anime and manga I've rated and reviewed.
      </p>
      <a href="https://anilist.co/user/chirag127" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-sky-500/10 text-sky-500 hover:text-sky-400 hover:bg-sky-500/20 font-semibold text-sm transition-all outline-none focus:ring-2 focus:ring-sky-500/50">
        View AniList Profile
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </main>
</Layout>
