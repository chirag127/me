---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

interface VideoRec {
  title: string;
  channel: string;
  category: string;
  emoji: string;
  gradient: string;
  embedId: string | null;
}

const featured: VideoRec[] = [
  {
    title: '3Blue1Brown — Essence of Linear Algebra',
    channel: '3Blue1Brown',
    category: 'Math',
    emoji: '📐',
    gradient: 'linear-gradient(135deg, #1e3a5f, #1e40af)',
    embedId: 'kjBOesZCoqc',
  },
  {
    title: 'Kurzgesagt — The Most Satisfying Video',
    channel: 'Kurzgesagt',
    category: 'Science',
    emoji: '🌍',
    gradient: 'linear-gradient(135deg, #065f46, #059669)',
    embedId: 'JnEHpk5B1zE',
  },
  {
    title: 'Fireship — 100 Seconds of Code',
    channel: 'Fireship',
    category: 'Tech',
    emoji: '🔥',
    gradient: 'linear-gradient(135deg, #dc2626, #f97316)',
    embedId: null,
  },
  {
    title: 'Veritasium — The Most Useful Science Videos',
    channel: 'Veritasium',
    category: 'Science',
    emoji: '🔬',
    gradient: 'linear-gradient(135deg, #4338ca, #6366f1)',
    embedId: null,
  },
];

const playlists = [
  {
    name: 'Tech Deep Dives',
    count: 42,
    emoji: '💻',
    color: 'var(--color-primary)',
  },
  {
    name: 'Physics & Math',
    count: 28,
    emoji: '🧮',
    color: 'var(--color-accent-sky)',
  },
  {
    name: 'Music Production',
    count: 15,
    emoji: '🎹',
    color: 'var(--color-accent-rose)',
  },
  {
    name: 'Film Analysis',
    count: 20,
    emoji: '🎞️',
    color: 'var(--color-accent-sage)',
  },
  {
    name: 'Vlogs & Travel',
    count: 12,
    emoji: '✈️',
    color: 'var(--color-accent-warm)',
  },
  {
    name: 'Philosophy',
    count: 18,
    emoji: '🤔',
    color: 'var(--color-accent-violet)',
  },
];

const channels = [
  { name: '3Blue1Brown', subs: '5.8M', category: 'Math', color: '#3b82f6' },
  { name: 'Kurzgesagt', subs: '22M', category: 'Science', color: '#10b981' },
  { name: 'Fireship', subs: '3.2M', category: 'Tech', color: '#f97316' },
  { name: 'Veritasium', subs: '16M', category: 'Science', color: '#6366f1' },
  {
    name: 'Mark Rober',
    subs: '28M',
    category: 'Engineering',
    color: '#ef4444',
  },
  {
    name: 'The Coding Train',
    subs: '1.6M',
    category: 'Coding',
    color: '#ec4899',
  },
  {
    name: 'Lex Fridman',
    subs: '4.5M',
    category: 'Interviews',
    color: '#8b5cf6',
  },
  {
    name: 'ColdFusion',
    subs: '4M',
    category: 'Tech/Business',
    color: '#06b6d4',
  },
  { name: 'Oversimplified', subs: '9M', category: 'History', color: '#f59e0b' },
  { name: 'Wisecrack', subs: '3.3M', category: 'Philosophy', color: '#a855f7' },
];
---

<Layout title="Videos" description="Chirag Singhal's video picks — curated YouTube content and recommendations">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-warm)]/10 flex items-center justify-center">
        <span class="text-xl">▶️</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Videos</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Curated YouTube content — channels, playlists, and recommendations.</p>

    <!-- Featured Videos -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">Featured Videos</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featured.map((video, i) => (
          <div class="card group cursor-default" style={`animation-delay: ${i * 80}ms`}>
            {video.embedId ? (
              <div class="aspect-video rounded-lg mb-4 overflow-hidden relative">
                <iframe
                  src={`https://www.youtube.com/embed/${video.embedId}`}
                  title={video.title}
                  class="w-full h-full"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            ) : (
              <div class="aspect-video rounded-lg mb-4 flex items-center justify-center text-5xl relative overflow-hidden" style={`background: ${video.gradient}`}>
                <div class="absolute inset-0 bg-black/20"></div>
                <div class="absolute top-3 left-3 bg-black/50 backdrop-blur-sm rounded-full px-3 py-1">
                  <span class="text-xs text-white/80">{video.category}</span>
                </div>
                <span class="relative z-10 drop-shadow-lg">{video.emoji}</span>
              </div>
            )}
            <h3 class="text-sm font-semibold text-white group-hover:text-[var(--color-accent-warm)] transition-colors">{video.title}</h3>
            <p class="text-xs text-[var(--color-text-muted)] mt-1">{video.channel}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Playlists -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">Watch Later Playlists</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        {playlists.map((pl, i) => (
          <div class="card group cursor-default text-center" style={`animation-delay: ${i * 50}ms`}>
            <div class="h-14 w-14 mx-auto rounded-2xl mb-3 flex items-center justify-center text-2xl" style={`background: ${pl.color}12`}>
              {pl.emoji}
            </div>
            <h3 class="text-xs font-semibold text-white group-hover:transition-colors" style={`--tw-hover-text-opacity: 1;`}>{pl.name}</h3>
            <p class="text-[0.65rem] text-[var(--color-text-faint)]">{pl.count} videos</p>
          </div>
        ))}
      </div>
    </section>

    <div class="divider-warm mb-16"></div>

    <!-- Favorite Channels -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">Favorite Channels</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {channels.map((ch, i) => (
          <div class="card group cursor-default" style={`animation-delay: ${i * 40}ms`}>
            <div class="w-14 h-14 rounded-full mb-3 flex items-center justify-center text-xl font-bold text-white" style={`background: ${ch.color}`}>
              {ch.name.charAt(0)}
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:transition-colors" style={`color: ${ch.color}; --tw-hover-text-opacity: 1;`}>{ch.name}</h3>
            <div class="flex items-center gap-1.5 mt-1">
              <span class="text-[0.6rem] text-[var(--color-text-faint)]">{ch.subs} subs</span>
              <span class="w-1 h-1 rounded-full bg-[var(--color-text-faint)]"></span>
              <span class="text-[0.6rem] text-[var(--color-text-faint)]">{ch.category}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Viewing Stats -->
    <div class="glass p-8 mb-16">
      <h2 class="text-lg font-semibold text-white mb-6">Viewing Habits</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-3xl font-bold text-[var(--color-accent-warm)] mb-1">10+</div>
          <div class="text-xs text-[var(--color-text-muted)]">Channels Followed</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-[var(--color-accent-sky)] mb-1">6</div>
          <div class="text-xs text-[var(--color-text-muted)]">Playlists</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-[var(--color-primary)] mb-1">Tech</div>
          <div class="text-xs text-[var(--color-text-muted)]">Top Category</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-[var(--color-success)] mb-1">Daily</div>
          <div class="text-xs text-[var(--color-text-muted)]">Watching</div>
        </div>
      </div>
    </div>

    <!-- Source note -->
    <div class="glass p-6 flex items-center gap-4">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-warm)]/10 flex items-center justify-center shrink-0">
        <svg class="h-5 w-5 text-[var(--color-accent-warm)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-white font-medium">Curated video recommendations</p>
        <p class="text-xs text-[var(--color-text-muted)]">Channels and videos I enjoy. Updated periodically with new finds.</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
