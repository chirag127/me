---import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { watched: [], rated: [], stats: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Movies Rated] movies.json not found.');
}

const rated = (db.watched || [])
  .filter((m: any) => m.rating)
  .sort((a: any, b: any) => b.rating - a.rating);

const fallbackGradients = [
  'linear-gradient(135deg, #0c1445, #1a237e)',
  'linear-gradient(135deg, #1b3a2d, #2e7d32)',
  'linear-gradient(135deg, #4a148c, #e91e63)',
  'linear-gradient(135deg, #795548, #d7ccc8)',
  'linear-gradient(135deg, #1e3a5f, #0f4c75)',
  'linear-gradient(135deg, #bf360c, #e65100)',
];
const fallbackEmojis = ['🎬', '🍿', '🎟️', '📽️', '🎞️', '🌌', '💥', '🎭'];

function _getVisuals(title: string) {
  const idx = [...title].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}

const highRated = rated.filter((m: any) => m.rating >= 8);
const midRated = rated.filter((m: any) => m.rating >= 6 && m.rating < 8);
const lowRated = rated.filter((m: any) => m.rating < 6);
---

<Layout title="Rated Movies" description="Movies rated by Chirag Singhal — sorted by rating">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/movies" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Movies
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center">
        <span class="text-xl">⭐</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Rated Movies</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Every movie I've rated — sorted from highest to lowest.</p>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-success)]">{highRated.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Rated 8+</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{midRated.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Rated 6-7</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-rose)]">{lowRated.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Rated &lt;6</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{rated.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Total Rated</div>
      </div>
    </div>

    {rated.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {rated.map((movie: any, i: number) => {
          const vis = getVisuals(movie.title);
          return (
          <div class="card group cursor-default" style={`animation-delay: ${i * 40}ms`}>
            <div class="aspect-[2/3] rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              {movie.posterUrl ? (
                <img src={movie.posterUrl} alt={movie.title} class="w-full h-full object-cover relative z-10" loading="lazy" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
              <div class="absolute top-2 right-2 z-20 bg-black/50 backdrop-blur-sm rounded-full px-2 py-0.5">
                <span class="text-xs font-semibold" style={`color: ${movie.rating >= 8 ? 'var(--color-success)' : movie.rating >= 6 ? 'var(--color-primary)' : 'var(--color-accent-rose)'}`}>{movie.rating}</span>
              </div>
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-primary)] transition-colors">{movie.title}</h3>
            <div class="flex items-center gap-1 mt-0.5">
              <span class="text-[0.65rem] text-[var(--color-text-faint)]">{movie.year}</span>
              {movie.ratedAt && (
                <>
                  <span class="w-1 h-1 rounded-full bg-[var(--color-text-faint)]"></span>
                  <span class="text-[0.6rem] text-[var(--color-text-faint)]">{new Date(movie.ratedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
                </>
              )}
            </div>
          </div>
        )})}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-[var(--color-text-muted)]">No rated movies found. Run fetch-data first.</p>
      </div>
    )}
  </main>
  <Footer />
</Layout>
