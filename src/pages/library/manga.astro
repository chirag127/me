---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: { manga: [] } };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Manga] anime.json not found.');
}

const manga = db.anime?.manga || db.manga || [];
const reading = manga.filter((m: any) => m.status === 'CURRENT');
const completed = manga.filter((m: any) => m.status === 'COMPLETED');
const planning = manga.filter((m: any) => m.status === 'PLANNING');

function scoreColor(score: number | null): string {
  if (!score) return '#52525b';
  if (score >= 8) return '#34d399';
  if (score >= 6) return '#2dd4bf';
  return '#fbbf24';
}
---

<Layout title="Manga" description="Chirag Singhal's manga list - from AniList">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">📕</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Manga</h1>
      </div>
      <p class="text-white/40">Manga reading list - synced from AniList.</p>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-emerald-400">{completed.length}</div>
        <div class="text-xs text-white/30">Completed</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-sky-400">{reading.length}</div>
        <div class="text-xs text-white/30">Reading</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{planning.length}</div>
        <div class="text-xs text-white/30">Plan to Read</div>
      </div>
    </div>

    {reading.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Currently Reading
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {reading.map((entry: any, i: number) => (
            <div class="glass rounded-2xl border border-white/5 hover:border-sky-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-t-2xl overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-sky-500/10 flex items-center justify-center text-3xl">📖</div>
                )}
                <div class="absolute bottom-0 left-0 right-0 h-1 bg-black/40">
                  <div class="h-full bg-sky-400" style={`width: ${entry.chapters ? Math.round((entry.progress / entry.chapters) * 100) : 0}%`}></div>
                </div>
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
                <p class="text-[0.6rem] text-white/20">{entry.progress || 0}/{entry.chapters || '?'} ch</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {completed.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Completed
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-emerald-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {completed.map((entry: any, i: number) => (
            <div class="glass rounded-2xl border border-white/5 hover:border-emerald-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-t-2xl overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-emerald-500/10 flex items-center justify-center text-3xl">✅</div>
                )}
                {entry.score && (
                  <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                    <span class="text-[0.6rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                  </div>
                )}
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
                <p class="text-[0.6rem] text-white/20">{entry.chapters || '?'} ch</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {planning.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Plan to Read
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-teal-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {planning.map((entry: any, i: number) => (
            <div class="glass rounded-2xl border border-white/5 opacity-70 cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-t-2xl overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-teal-500/10 flex items-center justify-center text-3xl">📋</div>
                )}
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
                <p class="text-[0.6rem] text-white/20">{entry.chapters || '?'} ch</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {manga.length === 0 && (
      <div class="glass p-12 text-center rounded-2xl border border-white/5"><p class="text-white/30">No manga data found. Run fetch-data first.</p></div>
    )}
  </main>
</Layout>
