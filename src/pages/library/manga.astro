---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: { manga: [] } };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Manga] anime.json not found.');
}

const manga = db.anime?.manga || db.manga || [];
const reading = manga.filter((m: any) => m.status === 'CURRENT');
const completed = manga.filter((m: any) => m.status === 'COMPLETED');
const planning = manga.filter((m: any) => m.status === 'PLANNING');

function _scoreColor(score: number | null): string {
  if (!score) return 'var(--color-text-faint)';
  if (score >= 8) return 'var(--color-success)';
  if (score >= 6) return 'var(--color-primary)';
  return 'var(--color-accent-warm)';
}
---

<Layout title="Manga" description="Chirag Singhal's manga list — from AniList">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-violet)]/10 flex items-center justify-center">
        <span class="text-xl">📕</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Manga</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Manga reading list — synced from AniList.</p>

    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-success)]">{completed.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Completed</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{reading.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Reading</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{planning.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Plan to Read</div>
      </div>
    </div>

    {reading.length > 0 && (
      <section class="mb-16">
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Currently Reading</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {reading.map((entry: any, i: number) => (
            <div class="card group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-lg overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-[var(--color-accent-sky)]/10 flex items-center justify-center text-3xl">📖</div>
                )}
                <div class="absolute bottom-0 left-0 right-0 h-1 bg-black/40">
                  <div class="h-full bg-[var(--color-accent-sky)]" style={`width: ${entry.chapters ? Math.round((entry.progress / entry.chapters) * 100) : 0}%`}></div>
                </div>
              </div>
              <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
              <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.progress || 0}/{entry.chapters || '?'} ch</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {completed.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Completed</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {completed.map((entry: any, i: number) => (
            <div class="card group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-lg overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-[var(--color-success)]/10 flex items-center justify-center text-3xl">✅</div>
                )}
                {entry.score && (
                  <div class="absolute top-1.5 right-1.5 bg-black/60 backdrop-blur-sm rounded-full px-1.5 py-0.5">
                    <span class="text-[0.6rem] font-semibold" style={`color: ${scoreColor(entry.score)}`}>{entry.score}</span>
                  </div>
                )}
              </div>
              <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
              <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.chapters || '?'} ch</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {planning.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Plan to Read</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {planning.map((entry: any, i: number) => (
            <div class="card group cursor-default opacity-70" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-lg overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-[var(--color-primary)]/10 flex items-center justify-center text-3xl">📋</div>
                )}
              </div>
              <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
              <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.chapters || '?'} ch</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {manga.length === 0 && (
      <div class="glass p-12 text-center"><p class="text-[var(--color-text-muted)]">No manga data found. Run fetch-data first.</p></div>
    )}
  </main>
  <Footer />
</Layout>
