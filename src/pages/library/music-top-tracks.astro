---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';

let db: any = { lastfm: {}, listenbrainz: {} };
try {
  const raw = await fs.readFile(path.resolve('./src/data/generated/music.json'), 'utf-8');
  db = JSON.parse(raw);
} catch (e) {
  console.warn('[Music Top Tracks] music.json not found.');
}

const topTracks = db.lastfm?.topTracks || [];
const lbTracks = db.listenbrainz?.topTracks || [];
const topAlbums = db.lastfm?.topAlbums || [];

const fallbackGradients = [
  'linear-gradient(135deg, #e11d48, #881337)',
  'linear-gradient(135deg, #1e3a5f, #7c3aed)',
  'linear-gradient(135deg, #d97706, #b91c1c)',
  'linear-gradient(135deg, #7c3aed, #db2777)',
  'linear-gradient(135deg, #0c4a6e, #1e40af)',
  'linear-gradient(135deg, #065f46, #047857)',
];
const fallbackEmojis = ['🎵', '🎶', '🎤', '🎧', '🎸', '🎹'];

function getVisuals(name: string) {
  if (!name) return { gradient: fallbackGradients[0], emoji: fallbackEmojis[0] };
  const idx = [...name].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length]
  };
}
---

<Layout title="Top Tracks" description="Chirag Singhal's most played tracks">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/music" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Music
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center">
        <span class="text-xl">🎵</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Top Tracks & Albums</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Most played tracks and albums — weekly data.</p>

    <!-- Top Tracks -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">Top Tracks (7 Days)</h2>
      {topTracks.length > 0 ? (
        <div class="space-y-2">
          {topTracks.map((track: any, i: number) => (
            <a href={track.url} target="_blank" rel="noopener noreferrer" class="glass p-4 flex items-center gap-4 hover:border-white/10 transition-colors group">
              <span class="text-sm font-bold text-[var(--color-primary)] w-8 text-right">{i + 1}</span>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg shrink-0" style={`background: ${getVisuals(track.name).gradient}`}>
                {track.imageUrl ? (
                  <img src={track.imageUrl} alt={track.name} class="w-full h-full object-cover rounded-lg" />
                ) : (
                  <span>{getVisuals(track.name).emoji}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate group-hover:text-[var(--color-primary)] transition-colors">{track.name}</h3>
                <p class="text-xs text-[var(--color-text-muted)] truncate">{track.artist}</p>
              </div>
              <span class="text-xs text-[var(--color-accent-rose)] font-medium shrink-0">{track.playcount} plays</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center"><p class="text-[var(--color-text-muted)]">No track data available.</p></div>
      )}
    </section>

    <!-- Top Albums -->
    {topAlbums.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Top Albums (7 Days)</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
          {topAlbums.map((album: any, i: number) => {
            const vis = getVisuals(album.name);
            return (
            <a href={album.url} target="_blank" rel="noopener noreferrer" class="card group cursor-default block" style={`animation-delay: ${i * 40}ms`}>
              <div class="aspect-square rounded-lg mb-2.5 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
                {album.imageUrl ? (
                  <img src={album.imageUrl} alt={album.name} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <span class="drop-shadow-lg">{vis.emoji}</span>
                )}
              </div>
              <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-primary)] transition-colors">{album.name}</h3>
              <p class="text-[0.65rem] text-[var(--color-text-faint)] truncate">{album.artist} · {album.playcount} plays</p>
            </a>
          )})}
        </div>
      </section>
    )}

    <!-- ListenBrainz Top Tracks -->
    {lbTracks.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">ListenBrainz — Top Tracks</h2>
        <div class="space-y-2">
          {lbTracks.map((track: any, i: number) => (
            <div class="glass p-4 flex items-center gap-4">
              <span class="text-sm font-bold text-[var(--color-accent-warm)] w-8 text-right">{i + 1}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate">{track.name}</h3>
                <p class="text-xs text-[var(--color-text-muted)] truncate">{track.artist}</p>
              </div>
              <span class="text-xs text-[var(--color-accent-warm)] font-medium shrink-0">{track.listenCount} listens</span>
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
  <ChatWidget client:load />
</Layout>
