---import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db = {
  lastfm: {
    stats: { playcount: 0 },
    topArtists: [] as any[],
    recentTracks: [] as any[],
    topTracks: [] as any[],
  },
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/music.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Music Hub] music.json not found.');
}

const numPlays = db.lastfm?.stats?.playcount || 0;
const artists = db.lastfm?.topArtists || [];
const recentTracks = db.lastfm?.recentTracks || [];

const fallbackGradients = [
  'linear-gradient(135deg, #e11d48, #881337)',
  'linear-gradient(135deg, #1e3a5f, #7c3aed)',
  'linear-gradient(135deg, #d97706, #b91c1c)',
  'linear-gradient(135deg, #7c3aed, #db2777)',
  'linear-gradient(135deg, #0c4a6e, #1e40af)',
  'linear-gradient(135deg, #065f46, #047857)',
  'linear-gradient(135deg, #365314, #3f6212)',
];
const fallbackEmojis = ['🎵', '🎶', '🎤', '🎧', '🎸', '🎹', '🥁'];

function _getVisuals(name: string) {
  if (!name)
    return { gradient: fallbackGradients[0], emoji: fallbackEmojis[0] };
  const idx = [...name].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}

const currentTrack = recentTracks[0];
---

<Layout title="Music" description="Chirag Singhal's music taste — top artists, tracks, and listening habits synced from Last.fm">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library Drive
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-rose)]/10 flex items-center justify-center">
        <span class="text-xl">🎵</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Music</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-6">Top artists and listening habits — synced automatically from Last.fm.</p>

    <!-- Sub-page Navigation -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href="/library/music-top-artists" class="text-xs px-3 py-1.5 rounded-full bg-[var(--color-accent-rose)]/10 text-[var(--color-accent-rose)] border border-[var(--color-accent-rose)]/20 hover:bg-[var(--color-accent-rose)]/20 transition-colors">Top Artists</a>
      <a href="/library/music-top-tracks" class="text-xs px-3 py-1.5 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20 hover:bg-[var(--color-primary)]/20 transition-colors">Top Tracks</a>
      <a href="/library/music-recent" class="text-xs px-3 py-1.5 rounded-full bg-[var(--color-accent-sky)]/10 text-[var(--color-accent-sky)] border border-[var(--color-accent-sky)]/20 hover:bg-[var(--color-accent-sky)]/20 transition-colors">Recent</a>
      <a href="/library/mixcloud" class="text-xs px-3 py-1.5 rounded-full bg-[#5000ff]/10 text-[#5000ff] border border-[#5000ff]/20 hover:bg-[#5000ff]/20 transition-colors">Mixcloud</a>
    </div>

    <!-- Now Playing / Last Played -->
    {currentTrack && (
    <div class="glass-strong p-8 mb-12 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full blur-3xl opacity-10 bg-[var(--color-accent-rose)]"></div>
      <div class="relative z-10 flex items-center gap-6">
        <div class="h-20 w-20 rounded-2xl bg-gradient-to-br from-[var(--color-accent-rose)]/20 to-[var(--color-primary)]/20 flex items-center justify-center shrink-0 relative overflow-hidden">
          {currentTrack.imageUrl ? (
            <img src={currentTrack.imageUrl} alt="Album Art" class="w-full h-full object-cover" />
          ) : (
            <div class="flex items-end gap-[3px] h-8 relative z-10">
              <div class="w-[3px] bg-[var(--color-accent-rose)] rounded-full animate-[bounce_0.8s_ease-in-out_infinite]" style="height: 60%"></div>
              <div class="w-[3px] bg-[var(--color-accent-rose)] rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.1s]" style="height: 100%"></div>
              <div class="w-[3px] bg-[var(--color-accent-rose)] rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.2s]" style="height: 40%"></div>
              <div class="w-[3px] bg-[var(--color-accent-rose)] rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.3s]" style="height: 80%"></div>
              <div class="w-[3px] bg-[var(--color-accent-rose)] rounded-full animate-[bounce_0.8s_ease-in-out_infinite_0.15s]" style="height: 50%"></div>
            </div>
          )}
        </div>
        <div>
          <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1">
            {currentTrack.nowPlaying ? 'Now Playing' : 'Last Played'}
          </p>
          <p class="text-lg text-white font-semibold">{currentTrack.name}</p>
          <p class="text-sm text-[var(--color-text-secondary)]">{currentTrack.artist}</p>
        </div>
      </div>
    </div>
    )}

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{numPlays.toLocaleString()}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Total Scrobbles</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-rose)]">{artists.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Top Artists Tracked</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{recentTracks.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Recent Tracks</div>
      </div>
    </div>

    <!-- Top Artists -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-heading text-xl font-semibold text-white">Top Artists</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-4 gap-4">
        {artists.map((artist, i) => {
          const vis = getVisuals(artist.name);
          return (
          <a href={artist.url} target="_blank" rel="noopener noreferrer" class="card group cursor-default text-center block" style={`animation-delay: ${i * 40}ms`}>
            <div class="w-20 h-20 mx-auto rounded-full mb-3 flex items-center justify-center text-3xl relative overflow-hidden" style={`background: ${vis.gradient}`}>
              <div class="absolute inset-0 bg-black/10"></div>
              {artist.imageUrl ? (
                <img src={artist.imageUrl} alt={artist.name} class="w-full h-full object-cover relative z-10" />
              ) : (
                <span class="relative z-10 drop-shadow-lg">{vis.emoji}</span>
              )}
            </div>
            <h3 class="text-xs font-semibold text-white truncate group-hover:text-[var(--color-accent-rose)] transition-colors">{artist.name}</h3>
            <div class="mt-1">
              <span class="text-[0.65rem] text-[var(--color-accent-rose)] font-medium">{artist.playcount.toLocaleString()} plays</span>
            </div>
          </a>
        )})}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  @keyframes bounce {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1); }
  }
</style>
