---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { lastfm: {}, listenbrainz: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/music.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Music Recent] music.json not found.');
}

const recentTracks = db.lastfm?.recentTracks || [];
const lbRecent = db.listenbrainz?.recentListens || [];

const fallbackGradients = [
  'linear-gradient(135deg, #e11d48, #881337)',
  'linear-gradient(135deg, #1e3a5f, #7c3aed)',
  'linear-gradient(135deg, #d97706, #b91c1c)',
  'linear-gradient(135deg, #7c3aed, #db2777)',
];
const fallbackEmojis = ['🎵', '🎶', '🎤', '🎧'];

function getVisuals(name: string) {
  if (!name)
    return { gradient: fallbackGradients[0], emoji: fallbackEmojis[0] };
  const idx = [...name].reduce((acc, char) => acc + char.charCodeAt(0), 0);
  return {
    gradient: fallbackGradients[idx % fallbackGradients.length],
    emoji: fallbackEmojis[idx % fallbackEmojis.length],
  };
}
---

<Layout title="Recent Tracks" description="Recently played music — from Last.fm and ListenBrainz">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/music" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Music
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-sky)]/10 flex items-center justify-center">
        <span class="text-xl">🎧</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Recent Tracks</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Recently played songs — live scrobble history.</p>

    <!-- Last.fm Recent -->
    <section class="mb-16">
      <h2 class="section-heading text-xl font-semibold text-white mb-8">Last.fm — Recent Tracks</h2>
      {recentTracks.length > 0 ? (
        <div class="space-y-2">
          {recentTracks.map((track: any, i: number) => (
            <a href={track.url} target="_blank" rel="noopener noreferrer" class="glass p-4 flex items-center gap-4 hover:border-white/10 transition-colors group" style={`animation-delay: ${i * 30}ms`}>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg shrink-0" style={`background: ${getVisuals(track.name).gradient}`}>
                {track.imageUrl ? (
                  <img src={track.imageUrl} alt={track.name} class="w-full h-full object-cover rounded-lg" />
                ) : (
                  <span>{getVisuals(track.name).emoji}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate group-hover:text-[var(--color-accent-sky)] transition-colors">{track.name}</h3>
                <p class="text-xs text-[var(--color-text-muted)] truncate">{track.artist}</p>
              </div>
              {track.nowPlaying && (
                <span class="text-[0.6rem] text-[var(--color-success)] font-medium uppercase animate-pulse">Now Playing</span>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center"><p class="text-[var(--color-text-muted)]">No recent tracks.</p></div>
      )}
    </section>

    <!-- ListenBrainz Recent -->
    {lbRecent.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">ListenBrainz — Recent Listens</h2>
        <div class="space-y-2">
          {lbRecent.map((listen: any, i: number) => (
            <div class="glass p-4 flex items-center gap-4" style={`animation-delay: ${i * 30}ms`}>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-white truncate">{listen.name}</h3>
                <p class="text-xs text-[var(--color-text-muted)] truncate">{listen.artist}</p>
              </div>
              {listen.listenedAt && (
                <span class="text-[0.6rem] text-[var(--color-text-faint)] shrink-0">{new Date(listen.listenedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>
