---
/**
 * TV Shows Hub — Redesigned with only TV show contents.
 * No colored image placeholders.
 */
import Layout from '../../layouts/Layout.astro';
import CommandPalette from
  '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

interface Show {
  title: string;
  year: number;
  rating: number | null;
  genres: string[];
  episodesWatched: number;
  category?: string;
}

let db = {
  shows: [] as Show[],
};

try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/movies.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch {
  console.warn(
    '[Shows] movies.json not found.',
  );
}

const shows = db.shows || [];

// Show stats
const showCount = shows.length;
const totalEpisodes = shows.reduce(
  (s, sh) => s + (sh.episodesWatched || 0),
  0,
);

const recentShows = [...shows].slice(0, 8);
---

<Layout
  title="TV Shows"
  description="TV show diary — tracked via Trakt"
>
  <CommandPalette />

  <div
    class="mx-auto max-w-[var(--content-max-width)]
      px-6 py-10"
  >
    <!-- Breadcrumb -->
    <a
      href="/library"
      class="inline-flex items-center gap-1.5
        text-xs text-white/30
        hover:text-white/50 transition-colors mb-6"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M15 19l-7-7 7-7" />
      </svg>
      Library
    </a>

    <!-- Header -->
    <div class="mb-10">
      <h1
        class="text-3xl font-black text-white mb-2"
        style="font-family:
          var(--font-display, 'Outfit');"
      >
        TV Shows
      </h1>
      <p class="text-sm text-white/35">
        TV diary — synced from Trakt automatically.
      </p>
    </div>

    <!-- Quick Navigation -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a
        href="/library/shows-watched"
        class="text-[10px] px-3 py-1.5 rounded-full
          bg-violet-500/10 text-violet-400
          border border-violet-500/20
          hover:bg-violet-500/20
          transition-colors font-semibold
          uppercase tracking-wider"
      >
        All Tracked ({showCount})
      </a>
    </div>

    <!-- Stats Grid -->
    <div
      class="grid grid-cols-2 gap-3 mb-14 max-w-sm"
    >
      {[
        {
          label: 'Tracked Shows',
          value: showCount,
          color: 'text-violet-400',
        },
        {
          label: 'Total Episodes',
          value: totalEpisodes,
          color: 'text-sky-400',
        },
      ].map((stat) => (
        <div
          class="p-4 rounded-xl bg-white/[0.015]
            border border-white/5 text-center"
        >
          <div
            class={`text-2xl font-black ${stat.color} truncate`}
            style="font-family:
              var(--font-display, 'Outfit');"
          >
            {stat.value}
          </div>
          <div
            class="text-[9px] text-white/25
              uppercase tracking-widest mt-1
              font-semibold"
          >
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- ═══ TRACKED SHOWS ═══ -->
    <section class="mb-16 reveal-stagger">
      <div
        class="flex items-center justify-between mb-6"
      >
        <div class="flex items-center gap-2">
          <span class="text-lg">📺</span>
          <h2
            class="text-xl font-bold text-white"
            style="font-family:
              var(--font-display, 'Outfit');"
          >
            Tracked Shows
          </h2>
        </div>
      </div>

      <div class="space-y-2 mb-6">
        {recentShows.map((show) => (
          <div
            class="group flex items-center gap-4
              p-4 rounded-xl bg-white/[0.015]
              border border-white/5
              hover:border-violet-500/15
              hover:bg-white/[0.025]
              transition-all duration-200"
          >
            <div class="relative h-14 w-10 flex-shrink-0 overflow-hidden rounded-lg bg-violet-500/5">
              {show.posterUrl ? (
                <img src={show.posterUrl} alt={show.title} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-lg text-violet-400/60">📺</div>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <h4
                class="text-sm font-semibold
                  text-white/80
                  group-hover:text-violet-300
                  transition-colors"
              >
                {show.title}
              </h4>
              <div
                class="flex items-center gap-2
                  text-[10px] text-white/20 mt-0.5"
              >
                <span>{show.year}</span>
                {(show.genres || [])[0] && (
                  <>
                    <span
                      class="h-0.5 w-0.5 rounded-full
                        bg-white/10"
                    ></span>
                    <span>
                      {(show.genres || [])[0]}
                    </span>
                  </>
                )}
              </div>
            </div>
            <div class="flex items-center gap-3
              flex-shrink-0">
              <div class="text-right">
                <div
                  class="text-xs font-bold
                    text-violet-400/60"
                >
                  {show.episodesWatched || 0}
                </div>
                <div
                  class="text-[8px] text-white/15
                    uppercase tracking-wider"
                >
                  episodes
                </div>
              </div>
              {show.rating && (
                <div
                  class="px-2 py-0.5 rounded-md
                    bg-violet-500/10 text-violet-400
                    text-[10px] font-bold"
                >
                  {show.rating}/10
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
      
      <div class="flex justify-center">
        <a href="/library/shows-watched" class="text-xs px-4 py-2 rounded-lg bg-white/[0.03] border border-white/5 hover:bg-white/[0.05] text-white/60 hover:text-white transition-colors">
          View all tracked shows
        </a>
      </div>
    </section>

    <!-- Trakt Profile Link -->
    <div class="mt-20 p-6 rounded-2xl bg-gradient-to-br from-red-500/5 to-rose-500/5 border border-red-500/10 text-center flex flex-col items-center">
      <div class="h-12 w-12 rounded-full bg-red-500/10 text-red-400 flex items-center justify-center text-xl mb-4">
        📽️
      </div>
      <h3 class="text-lg font-bold text-white mb-2">Complete Profile</h3>
      <p class="text-sm text-white/40 mb-6 max-w-md">
        For the complete, unfiltered history of every episode I've watched, rated, and reviewed.
      </p>
      <a href="https://trakt.tv" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-500/10 text-red-400 font-semibold text-sm hover:bg-red-500/20 hover:scale-105 transition-all outline-none focus:ring-2 focus:ring-red-500/50">
        View Trakt Profile
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

  </div>
</Layout>
