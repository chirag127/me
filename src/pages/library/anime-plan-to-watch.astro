---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Anime Plan to Watch] anime.json not found.');
}

const planning = db.anime?.planning || [];
const dropped = db.anime?.dropped || [];
const paused = db.anime?.paused || [];
---

<Layout title="Plan to Watch" description="Anime Chirag Singhal plans to watch, paused, or dropped">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-xs font-medium text-sky-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-rose-500/10 flex items-center justify-center">
          <span class="text-xl">📋</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Plan to Watch</h1>
      </div>
      <p class="text-white/40">Anime queue - planning, paused, and dropped.</p>
    </div>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8 rounded-2xl border border-white/10">
      <div>
        <div class="text-2xl font-bold text-sky-400">{planning.length}</div>
        <div class="text-xs text-white/30">Planning</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-teal-400">{paused.length}</div>
        <div class="text-xs text-white/30">Paused</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-rose-400">{dropped.length}</div>
        <div class="text-xs text-white/30">Dropped</div>
      </div>
    </div>

    {planning.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Planning to Watch
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-sky-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {planning.map((entry: any, i: number) => (
            <div class="glass rounded-2xl border border-white/5 hover:border-sky-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-t-2xl overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover opacity-80" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-sky-500/10 flex items-center justify-center text-3xl">📋</div>
                )}
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-sky-400 transition-colors">{entry.title}</h3>
                <p class="text-[0.6rem] text-white/20">{entry.episodes || '?'} eps</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {paused.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Paused
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-teal-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {paused.map((entry: any, i: number) => (
            <div class="glass rounded-2xl border border-white/5 hover:border-teal-500/15 transition-all group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-t-2xl overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-teal-500/10 flex items-center justify-center text-3xl">⏸️</div>
                )}
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-teal-400 transition-colors">{entry.title}</h3>
                <p class="text-[0.6rem] text-white/20">{entry.progress || 0}/{entry.episodes || '?'} eps</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {dropped.length > 0 && (
      <section class="mb-16">
        <hr class="border-white/5 mb-16" />
        <h2 class="text-xl font-semibold text-white mb-8 relative inline-block">
          Dropped
          <span class="absolute bottom-[-0.5rem] left-0 w-8 h-0.5 bg-gradient-to-r from-rose-400 to-transparent rounded-full"></span>
        </h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {dropped.map((entry: any, i: number) => (
            <div class="glass rounded-2xl border border-white/5 opacity-70 cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-t-2xl overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover grayscale" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-rose-500/10 flex items-center justify-center text-3xl">❌</div>
                )}
              </div>
              <div class="px-3 pb-3">
                <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
                <p class="text-[0.6rem] text-white/20">{entry.progress || 0}/{entry.episodes || '?'} eps</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {planning.length === 0 && paused.length === 0 && dropped.length === 0 && (
      <div class="glass p-12 text-center rounded-2xl border border-white/5"><p class="text-white/30">No anime in queue.</p></div>
    )}
  </main>
</Layout>
