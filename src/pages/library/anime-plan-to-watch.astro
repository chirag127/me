---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { anime: {} };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/anime.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Anime Plan to Watch] anime.json not found.');
}

const _planning = db.anime?.planning || [];
const _dropped = db.anime?.dropped || [];
const _paused = db.anime?.paused || [];
---

<Layout title="Plan to Watch" description="Anime Chirag Singhal plans to watch, paused, or dropped">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/library/anime" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Anime
    </a>

    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[var(--color-accent-rose)]/10 flex items-center justify-center">
        <span class="text-xl">📋</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Plan to Watch</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Anime queue — planning, paused, and dropped.</p>

    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-sky)]">{planning.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Planning</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-primary)]">{paused.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Paused</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-[var(--color-accent-rose)]">{dropped.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Dropped</div>
      </div>
    </div>

    {planning.length > 0 && (
      <section class="mb-16">
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Planning to Watch</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {planning.map((entry: any, i: number) => (
            <div class="card group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-lg overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover opacity-80" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-[var(--color-accent-sky)]/10 flex items-center justify-center text-3xl">📋</div>
                )}
              </div>
              <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-[var(--color-accent-sky)] transition-colors">{entry.title}</h3>
              <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.episodes || '?'} eps</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {paused.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Paused</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {paused.map((entry: any, i: number) => (
            <div class="card group cursor-default" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-lg overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-[var(--color-primary)]/10 flex items-center justify-center text-3xl">⏸️</div>
                )}
              </div>
              <h3 class="text-[0.65rem] font-semibold text-white truncate group-hover:text-[var(--color-primary)] transition-colors">{entry.title}</h3>
              <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.progress || 0}/{entry.episodes || '?'} eps</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {dropped.length > 0 && (
      <section class="mb-16">
        <div class="divider-warm mb-16"></div>
        <h2 class="section-heading text-xl font-semibold text-white mb-8">Dropped</h2>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
          {dropped.map((entry: any, i: number) => (
            <div class="card group cursor-default opacity-70" style={`animation-delay: ${i * 30}ms`}>
              <div class="relative rounded-lg overflow-hidden mb-2">
                {entry.coverUrl ? (
                  <img src={entry.coverUrl} alt={entry.title} class="w-full aspect-[3/4] object-cover grayscale" loading="lazy" />
                ) : (
                  <div class="w-full aspect-[3/4] bg-[var(--color-accent-rose)]/10 flex items-center justify-center text-3xl">❌</div>
                )}
              </div>
              <h3 class="text-[0.65rem] font-semibold text-white truncate">{entry.title}</h3>
              <p class="text-[0.6rem] text-[var(--color-text-faint)]">{entry.progress || 0}/{entry.episodes || '?'} eps</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {planning.length === 0 && paused.length === 0 && dropped.length === 0 && (
      <div class="glass p-12 text-center"><p class="text-[var(--color-text-muted)]">No anime in queue.</p></div>
    )}
  </main>
  <Footer />
</Layout>
