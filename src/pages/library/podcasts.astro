---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

const podcasts = [
  {
    name: 'Lex Fridman Podcast',
    category: 'AI & Tech',
    frequency: 'Weekly',
    icon: '🎙️',
  },
  {
    name: 'The Changelog',
    category: 'Open Source',
    frequency: 'Daily',
    icon: '🔔',
  },
  { name: 'Syntax FM', category: 'Web Dev', frequency: 'Weekly', icon: '💻' },
  { name: 'JS Party', category: 'JavaScript', frequency: 'Weekly', icon: '⚡' },
  {
    name: 'Acquired',
    category: 'Business',
    frequency: 'Bi-weekly',
    icon: '📈',
  },
  {
    name: 'Darknet Diaries',
    category: 'Security',
    frequency: 'Weekly',
    icon: '🕵️',
  },
];
---

<Layout title="Podcasts" description="Podcast subscriptions and listening habits">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <a href="/library" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Library
    </a>

    <!-- Page header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-medium text-violet-400 mb-4">
        LIBRARY
      </div>
      <div class="flex items-center gap-3 mb-2">
        <div class="h-10 w-10 rounded-xl bg-violet-500/10 flex items-center justify-center">
          <span class="text-xl">🎙️</span>
        </div>
        <h1 class="text-4xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Podcasts</h1>
      </div>
      <p class="text-white/40">Podcast subscriptions and episodes I recommend.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {podcasts.map((podcast) => (
        <div class="glass p-6 rounded-2xl hover:bg-white/[0.04] transition-colors border border-white/5 hover:border-violet-500/15">
          <div class="flex items-start gap-4">
            <div class="text-3xl">{podcast.icon}</div>
            <div>
              <h3 class="font-semibold text-white">{podcast.name}</h3>
              <p class="text-sm text-white/40 mt-1">{podcast.category}</p>
              <span class="text-xs text-violet-400 mt-2 inline-block">{podcast.frequency}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 glass p-8 text-center rounded-2xl border border-white/5">
      <p class="text-white/40">More podcast integrations coming soon...</p>
    </div>
  </main>
</Layout>
