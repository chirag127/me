---
import Layout from '../layouts/Layout.astro';

---

<Layout title="Cookie Policy" description="Cookie Policy for Chirag Singhal's Digital Identity">
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Header -->
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-300/80 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        Legal
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Cookie Policy</h1>
      <p class="text-lg text-white/40 max-w-2xl">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    </div>

    <!-- Content -->
    <div class="space-y-10 text-white/60 leading-relaxed">
      <section>
        <h2 class="text-xl font-semibold text-white mb-4" style="font-family: 'Outfit', sans-serif;">1. What Are Cookies</h2>
        <p>Cookies are small text files that are stored on your device (computer or mobile device) when you visit a website. They are widely used to make websites work more efficiently and to provide information to the website owners.</p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-white mb-4" style="font-family: 'Outfit', sans-serif;">2. How We Use Cookies</h2>
        <p class="mb-4">We use cookies for the following purposes:</p>
        <ul class="space-y-3 ml-4">
          <li class="flex items-start gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-teal-400 mt-2 shrink-0"></span>
            <span><strong class="text-white/80">Essential Cookies:</strong> Required for the optimal functioning of the site and features like theme toggles.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-teal-400 mt-2 shrink-0"></span>
            <span><strong class="text-white/80">Analytics/Performance:</strong> Tracking behavior to allow us to update the website to suit user needs.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-teal-400 mt-2 shrink-0"></span>
            <span><strong class="text-white/80">Advertising/AdSense:</strong> Displaying personalized advertisements from Google AdSense and identifying frequency/views.</span>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-white mb-4" style="font-family: 'Outfit', sans-serif;">3. Managing Consents and Disabling Cookies</h2>
        <p>You can easily manage your cookie consent by accepting or declining via the banner across the site. Additionally, you can restrict or block cookies through your browser settings. Beware that disabling certain cookies might impact site functionality.</p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-white mb-4" style="font-family: 'Outfit', sans-serif;">4. More Information</h2>
        <p>If you are looking for more information, you may contact us through: <a href="mailto:hi@chirag127.in" class="text-teal-400 hover:text-teal-300 hover:underline ml-1 transition-colors">hi@chirag127.in</a></p>
      </section>
    </div>
  </main>
</Layout>
