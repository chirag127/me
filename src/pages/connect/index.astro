---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import { socialLinks } from '../../data/social';

const devLinks = socialLinks.filter(l => ['GitHub', 'LinkedIn', 'Dev.to', 'LeetCode', 'Codewars'].includes(l.name));
const socialPlatformLinks = socialLinks.filter(l => ['Bluesky', 'Mastodon', 'Reddit'].includes(l.name));
const entertainmentLinks = socialLinks.filter(l => ['Lichess', 'Last.fm', 'AniList', 'Letterboxd'].includes(l.name));

