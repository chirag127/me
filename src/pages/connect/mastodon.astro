---import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { account: null, statuses: [] };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/mastodon.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Mastodon] mastodon.json not found.');
}

const account = db.account;
const statuses = db.statuses || [];

function _stripHtml(html: string) {
  return html?.replace(/<[^>]*>/g, '') || '';
}
---

<Layout title="Mastodon" description="Chirag Singhal on Mastodon — recent posts and profile">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[#6364ff]/10 flex items-center justify-center">
        <span class="text-xl">🐘</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Mastodon</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">My Mastodon presence — from {account?.username || 'chirag127'}.</p>

    {account && (
      <div class="glass-strong p-8 mb-12">
        {account.header && (
          <div class="h-32 rounded-lg mb-6 overflow-hidden">
            <img src={account.header} alt="Header" class="w-full h-full object-cover" />
          </div>
        )}
        <div class="flex items-center gap-4 mb-4">
          {account.avatar && <img src={account.avatar} alt="Avatar" class="w-16 h-16 rounded-full" />}
          <div>
            <h2 class="text-xl font-bold text-white">{account.displayName}</h2>
            <p class="text-sm text-[var(--color-text-muted)]">@{account.username}@mastodon.social</p>
          </div>
        </div>
        <div class="flex gap-6 mb-4">
          <div><span class="text-lg font-bold text-[#6364ff]">{account.statusesCount?.toLocaleString()}</span> <span class="text-xs text-[var(--color-text-muted)]">Posts</span></div>
          <div><span class="text-lg font-bold text-white">{account.followersCount?.toLocaleString()}</span> <span class="text-xs text-[var(--color-text-muted)]">Followers</span></div>
          <div><span class="text-lg font-bold text-white">{account.followingCount?.toLocaleString()}</span> <span class="text-xs text-[var(--color-text-muted)]">Following</span></div>
        </div>
        {account.fields?.length > 0 && (
          <div class="flex flex-wrap gap-4 pt-4 border-t border-white/5">
            {account.fields.map((f: any) => (
              <div>
                <div class="text-[0.6rem] text-[var(--color-text-muted)] uppercase">{f.name}</div>
                <div class="text-sm text-white" set:html={f.value}></div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <h2 class="text-xl font-semibold text-white mb-6">Recent Posts</h2>
    {statuses.length > 0 ? (
      <div class="space-y-4">
        {statuses.map((status: any) => (
          <a href={status.url} target="_blank" rel="noopener noreferrer" class="glass p-5 block hover:border-white/10 transition-colors group">
            <p class="text-sm text-white/90 mb-3 leading-relaxed" set:html={status.content}></p>
            {status.mediaAttachments?.length > 0 && (
              <div class="grid grid-cols-2 gap-2 mb-3">
                {status.mediaAttachments.slice(0, 4).map((media: any) => (
                  <img src={media.previewUrl || media.url} alt={media.description || 'Media'} class="rounded-lg w-full h-32 object-cover" loading="lazy" />
                ))}
              </div>
            )}
            <div class="flex items-center gap-4 text-xs text-[var(--color-text-muted)]">
              <span>{new Date(status.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>🔁 {status.reblogsCount}</span>
              <span>⭐ {status.favouritesCount}</span>
              <span>💬 {status.repliesCount}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-[var(--color-text-muted)]">No Mastodon posts found. Run fetch-data first.</p>
      </div>
    )}

    <div class="mt-12 glass p-6 text-center">
      <a href="https://mastodon.social/@chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-[#6364ff] hover:underline">View on Mastodon →</a>
    </div>
  </main>
  <Footer />
</Layout>
