---import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { bluesky: null };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/social.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[Bluesky] social.json not found.');
}

const bluesky = db.bluesky;
const posts = bluesky?.posts || [];
---

<Layout title="Bluesky" description="Chirag Singhal on Bluesky — recent posts">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[#0085ff]/10 flex items-center justify-center">
        <span class="text-xl">🦋</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">Bluesky</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">{CONFIG.user.bluesky} — thoughts and updates.</p>

    <!-- Profile -->
    <div class="glass-strong p-8 mb-12">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-16 h-16 rounded-full bg-[#0085ff]/20 flex items-center justify-center">
          <span class="text-3xl">🦋</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">{CONFIG.user.bluesky}</h2>
          <p class="text-sm text-[var(--color-text-muted)]">@{CONFIG.user.bluesky}</p>
        </div>
      </div>
      <p class="text-sm text-[var(--color-text-muted)]">Posts on Bluesky — the decentralized social network.</p>
    </div>

    <!-- Posts -->
    <h2 class="text-xl font-semibold text-white mb-6">Recent Posts</h2>
    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map((post: any) => (
          <a href={post.uri} target="_blank" rel="noopener noreferrer" class="glass p-5 block hover:border-white/10 transition-colors group">
            <p class="text-sm text-white/90 mb-3 leading-relaxed">{post.text}</p>
            <div class="flex items-center gap-4 text-xs text-[var(--color-text-muted)]">
              <span>{new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>❤️ {post.likeCount}</span>
              <span>🔁 {post.repostCount}</span>
              <span>💬 {post.replyCount}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-[var(--color-text-muted)]">No Bluesky posts found. Run fetch-data first.</p>
      </div>
    )}

    <div class="mt-12 glass p-6 text-center">
      <a href={`https://bsky.app/profile/${CONFIG.user.bluesky}`} target="_blank" rel="noopener noreferrer" class="text-sm text-[#0085ff] hover:underline">View on Bluesky →</a>
    </div>
  </main>
  <Footer />
</Layout>
