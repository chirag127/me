---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import { CONFIG } from '../../lib/config';
---

<Layout title="Pixelfed" description="Chirag Singhal on Pixelfed">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12 relative">
    <div class="absolute top-0 right-0 w-80 h-80 bg-blue-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Back link -->
    <a href="/connect" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-teal-400 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Connect
    </a>

    <!-- Header -->
    <div class="mb-10 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        CONNECT
      </div>
      <div class="flex items-center gap-3 mb-3">
        <div class="h-10 w-10 rounded-xl bg-blue-500/10 flex items-center justify-center">
          <span class="text-xl">&#x1F4F8;</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">Pixelfed</h1>
      </div>
      <p class="text-lg text-white/40">Decentralized photo sharing — {CONFIG.user.pixelfed}.</p>
    </div>

    <!-- Profile Hero -->
    <div class="glass-strong p-8 mb-10 reveal">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-blue-500/20 flex items-center justify-center flex-shrink-0">
          <span class="text-3xl">&#x1F4F8;</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">@{CONFIG.user.pixelfed}</h2>
          <p class="text-sm text-white/40">on pixelfed.social</p>
        </div>
      </div>
      <p class="text-sm text-white/40 leading-relaxed">
        Pixelfed is a free, ethical, federated photo sharing platform. It's part of the Fediverse,
        connected to Mastodon and other ActivityPub services.
      </p>
    </div>

    <!-- Features -->
    <div class="glass p-8 mb-10 reveal">
      <h2 class="text-xl font-bold text-white mb-6">About Pixelfed</h2>
      <ul class="space-y-3 text-sm text-white/40">
        <li class="flex items-center gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
          Federated — part of the Fediverse
        </li>
        <li class="flex items-center gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
          Open source and privacy-focused
        </li>
        <li class="flex items-center gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
          No algorithmic manipulation
        </li>
        <li class="flex items-center gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
          Interoperable with Mastodon
        </li>
      </ul>
    </div>

    <!-- External Link -->
    <div class="glass p-6 text-center reveal">
      <a href={`https://pixelfed.social/${CONFIG.user.pixelfed}`} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-400 hover:text-blue-300 hover:underline">View on Pixelfed &rarr;</a>
    </div>
  </main>
</Layout>
