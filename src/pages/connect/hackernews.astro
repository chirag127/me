---import { CONFIG } from '../../lib/config';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

import * as fs from 'node:fs/promises';
import * as path from 'node:path';

let db: any = { hackernews: null };
try {
  const raw = await fs.readFile(
    path.resolve('./src/data/generated/social.json'),
    'utf-8',
  );
  db = JSON.parse(raw);
} catch (_e) {
  console.warn('[HackerNews] social.json not found.');
}

const hnStats = db.hackernews;
---

<Layout title="HackerNews" description="Chirag Singhal on HackerNews — karma and activity">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[#ff6600]/10 flex items-center justify-center">
        <span class="text-xl font-bold text-[#ff6600]">Y</span>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">HackerNews</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">My HackerNews profile — {CONFIG.user.hackernews}.</p>

    <div class="glass-strong p-8 mb-12">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 rounded-full bg-[#ff6600]/20 flex items-center justify-center">
          <span class="text-3xl font-bold text-[#ff6600]">Y</span>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">{CONFIG.user.hackernews}</h2>
          <p class="text-sm text-[var(--color-text-muted)]">HackerNews contributor</p>
        </div>
      </div>

      {hnStats ? (
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center p-4 rounded-lg bg-white/[0.02]">
            <div class="text-2xl font-bold text-[#ff6600]">{hnStats.karma?.toLocaleString()}</div>
            <div class="text-xs text-[var(--color-text-muted)]">Karma</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-white/[0.02]">
            <div class="text-2xl font-bold text-white">{hnStats.submittedCount}</div>
            <div class="text-xs text-[var(--color-text-muted)]">Submissions</div>
          </div>
        </div>
      ) : (
        <div class="text-center py-8">
          <p class="text-[var(--color-text-muted)]">HackerNews data not available. Run fetch-data first.</p>
        </div>
      )}
    </div>

    <div class="glass p-8 mb-12">
      <h2 class="text-xl font-bold text-white mb-4">About HackerNews</h2>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
        HackerNews is a social news website focusing on computer science and entrepreneurship.
        It's run by Y Combinator and is a hub for the tech community.
      </p>
    </div>

    <div class="glass p-6 text-center">
      <a href={`https://news.ycombinator.com/user?id=${CONFIG.user.hackernews}`} target="_blank" rel="noopener noreferrer" class="text-sm text-[#ff6600] hover:underline">View on HackerNews →</a>
    </div>
  </main>
  <Footer />
</Layout>
