---
import Layout from '../layouts/Layout.astro';
import CommandPalette from '../components/CommandPalette.astro';
---

<Layout title="404" description="Page not found">
  <CommandPalette />
  <main class="min-h-[calc(100vh-8rem)] flex items-center justify-center relative overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-teal-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-violet-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="text-center px-6 relative z-10">
      <!-- 404 gradient text -->
      <div class="text-8xl sm:text-9xl font-black mb-6 bg-gradient-to-br from-teal-400 via-teal-300 to-violet-400 bg-clip-text text-transparent select-none" style="font-family: 'Outfit', sans-serif;">
        404
      </div>

      <!-- Animated ring decoration -->
      <div class="flex items-center justify-center gap-4 mb-8">
        <span class="block h-px w-12 bg-gradient-to-r from-transparent to-white/20"></span>
        <div class="h-2 w-2 rounded-full bg-teal-400/60 animate-pulse"></div>
        <span class="block h-px w-12 bg-gradient-to-l from-transparent to-white/20"></span>
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Page Not Found</h1>
      <p class="text-white/40 mb-10 max-w-md mx-auto">This drive doesn't exist in the system. Maybe it was moved or never created.</p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white bg-gradient-to-r from-teal-500 to-violet-500 hover:shadow-lg hover:shadow-teal-500/20 transition-all duration-300 hover:scale-[1.02]"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
          </svg>
          Return Home
        </a>
        <a
          href="/me"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white/60 border border-white/10 hover:border-white/20 hover:text-white hover:bg-white/5 transition-all duration-300"
        >
          Chirag Singhal
        </a>
      </div>
    </div>
  </main>
</Layout>
