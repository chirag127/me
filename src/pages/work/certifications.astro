---
import { honors } from '../../data/resume';
import { certifications } from '../../data/resume';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

---

<Layout title="Certifications & Honors" description="Professional certifications and honors of Chirag Singhal">  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Work Drive</a>

    <div class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Certifications & Honors</h1>
      <p class="text-lg text-white/40">{honors.length} honors and {certifications.length} professional certifications</p>
    </div>

    <!-- Honors Grid -->
    <h2 class="text-xl font-bold text-white mb-6">Honors & Awards</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {honors.map((honor) => (
        <div class="glass p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="h-10 w-10 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center flex-shrink-0">
              <svg class="h-5 w-5 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">{honor.title}</h3>
              <p class="text-xs text-white/40">{honor.location} · {honor.year}</p>
            </div>
          </div>
          <p class="text-sm text-white/50 pl-[3.25rem]">{honor.description}</p>
        </div>
      ))}
    </div>

    <!-- Professional Certifications -->
    <h2 class="text-xl font-bold text-white mb-6">Professional Certifications</h2>
    <div class="space-y-4 mb-12">
      {certifications.map((cert) => (
        <div class="glass p-6 flex items-center gap-4">
          <div class="h-10 w-10 rounded-lg bg-[var(--color-accent-sage)]/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-[var(--color-accent-sage)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
          </div>
          <div>
            <div class="text-sm font-medium text-white">{cert}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="glass p-5 text-center">
        <div class="text-2xl font-bold text-[var(--color-primary)]">{honors.length}</div>
        <div class="text-xs text-white/40 mt-1">Honors</div>
      </div>
      <div class="glass p-5 text-center">
        <div class="text-2xl font-bold text-[var(--color-primary)]">{certifications.length}</div>
        <div class="text-xs text-white/40 mt-1">Certifications</div>
      </div>
      <div class="glass p-5 text-center">
        <div class="text-2xl font-bold text-[var(--color-primary)]">8.81</div>
        <div class="text-xs text-white/40 mt-1">CGPA</div>
      </div>
      <div class="glass p-5 text-center">
        <div class="text-2xl font-bold text-[var(--color-primary)]">AIR 11870</div>
        <div class="text-xs text-white/40 mt-1">JEE Advanced</div>
      </div>
    </div>
  </main></Layout>
