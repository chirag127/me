---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import { projects } from '../../data/resume';

const featuredProjects = projects.filter(p => p.featured);
const otherProjects = projects.filter(p => !p.featured);
const allTechs = [...new Set(projects.flatMap(p => p.tech.split(', ')))];
---

<Layout title="Projects" description="All 8 projects by Chirag Singhal — Oriz, NexusAI, TubeDigest, Olivia, and more">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 relative">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--color-accent-sage)]/5 rounded-full blur-[120px] pointer-events-none"></div>

    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Back to Work Drive
    </a>

    <div class="mb-12 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/40 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-sage)]"></span>
        WORK / Projects
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Projects</h1>
      <p class="text-lg text-white/40">{featuredProjects.length} featured + {otherProjects.length} additional projects — {projects.length} total</p>
    </div>

    <!-- Featured Projects -->
    <div class="space-y-10 mb-16">
      <div class="flex items-center gap-3 mb-2">
        <svg class="h-5 w-5 text-[var(--color-primary)]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <h2 class="text-xl font-bold text-white">Featured Projects</h2>
      </div>

      {featuredProjects.map((project, i) => (
        <div class="glass-strong p-8 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-40 h-40 bg-[var(--color-primary)]/3 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="relative">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-bold text-[var(--color-primary)] bg-[var(--color-primary)]/10 px-2.5 py-1 rounded-md">0{i + 1}</span>
                  <h2 class="text-2xl sm:text-3xl font-bold text-white">{project.name}</h2>
                </div>
              </div>
              <span class="px-2.5 py-1 text-[10px] font-bold rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20 uppercase tracking-widest">Featured</span>
            </div>

            <div class="flex flex-wrap gap-2 mb-5">
              {project.tech.split(', ').map((t) => (
                <span class="px-2.5 py-1 text-[11px] rounded-lg bg-white/5 text-white/50 border border-white/5 font-medium">{t}</span>
              ))}
            </div>

            <ul class="space-y-3">
              {project.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-white/60 leading-relaxed">
                  <svg class="h-4 w-4 text-[var(--color-accent-sage)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Other Projects -->
    {otherProjects.length > 0 && (
      <div class="mb-16">
        <h2 class="text-xl font-bold text-white mb-6">More Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {otherProjects.map((project) => (
            <div class="glass p-6 relative overflow-hidden group hover:border-white/10 transition-colors">
              <div class="absolute top-0 right-0 w-24 h-24 bg-white/2 rounded-full blur-[60px] pointer-events-none"></div>
              <div class="relative">
                <h3 class="text-lg font-bold text-white mb-3">{project.name}</h3>
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {project.tech.split(', ').map((t) => (
                    <span class="px-2 py-0.5 text-[10px] rounded-full bg-white/5 text-white/40 border border-white/5">{t}</span>
                  ))}
                </div>
                <ul class="space-y-2.5">
                  {project.items.map((item) => (
                    <li class="flex items-start gap-2.5 text-sm text-white/50 leading-relaxed">
                      <svg class="h-3.5 w-3.5 text-[var(--color-accent-sage)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Tech Used Across Projects -->
    <div class="glass p-8">
      <h2 class="text-lg font-bold text-white mb-4">Technologies Across All Projects</h2>
      <div class="flex flex-wrap gap-2">
        {allTechs.map((tech) => (
          <span class="px-3 py-1.5 text-xs rounded-lg bg-white/5 text-white/50 border border-white/5 hover:border-white/10 transition-colors">{tech}</span>
        ))}
      </div>
      <div class="mt-4 pt-4 border-t border-white/5 text-xs text-white/25">{allTechs.length} unique technologies across {projects.length} projects</div>
    </div>
  </main>
  <Footer />
  <ChatWidget client:load />
</Layout>
