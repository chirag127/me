---
import { education } from '../../data/resume';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

const milestones = [
  {
    year: '2020',
    label: 'JEE Advanced',
    detail: 'AIR 11870 — Top 1% in India',
  },
  { year: '2020', label: 'CBSE Board', detail: '97% — School Topper (Rank 1)' },
  {
    year: '2024',
    label: 'B.Tech Graduation',
    detail: 'CGPA 8.81 — College Topper (Rank 1)',
  },
];
---

<Layout title="Education" description="Academic background of Chirag Singhal — AKTU B.Tech CSE, JEE Advanced Rank Holder">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/work" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Work Drive</a>

    <div class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Education</h1>
      <p class="text-lg text-white/40">Academic excellence and competitive exam achievements</p>
    </div>

    <!-- Key Milestones -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
      {milestones.map((m) => (
        <div class="glass p-5 text-center">
          <div class="text-xs text-[var(--color-primary)] font-medium mb-1">{m.year}</div>
          <div class="text-base font-bold text-white">{m.label}</div>
          <div class="text-xs text-white/40 mt-1">{m.detail}</div>
        </div>
      ))}
    </div>

    <!-- Education Timeline -->
    <div class="relative pl-8 border-l border-[var(--color-border)]">
      {education.map((edu) => (
        <div class="mb-12 relative reveal">
          <div class="absolute -left-[2.55rem] h-4 w-4 rounded-full bg-[var(--color-accent-violet)] border-4 border-[var(--color-surface)]"></div>
          <div class="glass p-8">
            <span class="text-sm text-[var(--color-accent-violet)] font-semibold">{edu.date}</span>
            <h2 class="text-xl font-bold text-white mt-1 mb-1">{edu.degree}</h2>
            <p class="text-sm text-[var(--color-primary)] font-medium mb-1">{edu.institution}</p>
            <p class="text-xs text-white/40 mb-5">{edu.location}</p>
            <ul class="space-y-3">
              {edu.items.map((item) => (
                <li class="flex items-start gap-3 text-sm text-white/60">
                  <svg class="h-4 w-4 text-[var(--color-accent-sage)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Academic Highlights -->
    <div class="glass p-8 mt-4">
      <h2 class="text-lg font-bold text-white mb-4">Academic Highlights</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <svg class="h-5 w-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          <div>
            <div class="text-sm font-medium text-white">College Topper</div>
            <div class="text-xs text-white/40">Rank 1 in CSE batch (2020-2024) at AKTU</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="h-5 w-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <div>
            <div class="text-sm font-medium text-white">JEE Advanced 2020</div>
            <div class="text-xs text-white/40">AIR 11870 — Top 1% nationwide</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="h-5 w-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          <div>
            <div class="text-sm font-medium text-white">School Topper</div>
            <div class="text-xs text-white/40">97% in CBSE Class 12th</div>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="h-5 w-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          <div>
            <div class="text-sm font-medium text-white">Coding Competition</div>
            <div class="text-xs text-white/40">Rank 1 in College Coding Competition (2022)</div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
