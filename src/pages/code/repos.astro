---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import AIChat from '../../components/islands/AIChat';
import { fetchGitHubRepos } from '../../lib/api';

const repos = await fetchGitHubRepos();
const sortedRepos = repos.sort((a, b) => b.stargazers_count - a.stargazers_count);
const languages = [...new Set(repos.filter(r => r.language).map(r => r.language))].sort();
const totalStars = repos.reduce((sum, r) => sum + r.stargazers_count, 0);
const totalForks = repos.reduce((sum, r) => sum + r.forks_count, 0);
---

<Layout title="Repository Explorer" description={`${sortedRepos.length} public GitHub repositories by Chirag Singhal`}>
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/code" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">← Back to Code Drive</a>

    <div class="mb-8">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Repository Explorer</h1>
      <p class="text-lg text-white/40">{sortedRepos.length} repos · {totalStars} stars · {totalForks} forks · {languages.length} languages</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-8">
      <input type="text" id="repo-search" placeholder="Search repos by name or description..." class="flex-1 min-w-[200px] px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/30 focus:outline-none focus:border-[var(--color-primary)]/50 transition-colors" />
      <select id="lang-filter" class="px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none transition-colors cursor-pointer">
        <option value="all">All Languages ({languages.length})</option>
        {languages.map((lang) => (<option value={lang}>{lang}</option>))}
      </select>
      <select id="sort-filter" class="px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none transition-colors cursor-pointer">
        <option value="stars">Most Stars</option>
        <option value="forks">Most Forks</option>
        <option value="updated">Recently Updated</option>
        <option value="name">Name A-Z</option>
      </select>
    </div>

    <!-- Repo Count -->
    <div class="text-sm text-white/30 mb-4" id="repo-count">Showing {sortedRepos.length} repos</div>

    <!-- Repos Grid -->
    <div id="repos-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedRepos.map((repo) => (
        <div class="repo-card card group cursor-pointer" data-lang={repo.language || 'unknown'} data-stars={repo.stargazers_count} data-forks={repo.forks_count} data-updated={repo.updated_at} data-name={repo.name.toLowerCase()}>
          <div class="flex items-start justify-between mb-2">
            <h3 class="text-base font-semibold text-white group-hover:text-[var(--color-primary)] transition-colors truncate mr-3">{repo.name}</h3>
            <div class="flex items-center gap-3 text-xs text-white/30 flex-shrink-0">
              <span class="flex items-center gap-1" title="Stars">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                {repo.stargazers_count}
              </span>
              <span class="flex items-center gap-1" title="Forks">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
                {repo.forks_count}
              </span>
            </div>
          </div>
          {repo.description && <p class="text-xs text-white/40 mb-3 line-clamp-2">{repo.description}</p>}
          <div class="flex items-center gap-2 flex-wrap">
            {repo.language && (
              <span class="inline-flex items-center gap-1.5 text-xs text-white/50">
                <span class="h-2 w-2 rounded-full bg-[var(--color-primary)]"></span>
                {repo.language}
              </span>
            )}
            {repo.topics?.slice(0, 4).map((topic) => (
              <span class="px-2 py-0.5 text-[10px] rounded-full bg-white/5 text-white/30 border border-white/5">{topic}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-16">
      <div class="text-4xl mb-3">🔍</div>
      <h3 class="text-lg font-semibold text-white mb-1">No repos found</h3>
      <p class="text-sm text-white/40">Try a different search or filter</p>
    </div>
  </main>
  <Footer />
  <AIChat client:load />
  <ChatWidget client:load />

  <script is:inline>
    const searchInput = document.getElementById('repo-search');
    const langFilter = document.getElementById('lang-filter');
    const sortFilter = document.getElementById('sort-filter');
    const grid = document.getElementById('repos-grid');
    const repoCount = document.getElementById('repo-count');
    const emptyState = document.getElementById('empty-state');

    function filterRepos() {
      const search = searchInput?.value.toLowerCase() || '';
      const lang = langFilter?.value || 'all';
      const sort = sortFilter?.value || 'stars';

      const cards = [...document.querySelectorAll('.repo-card')];
      let visible = 0;

      cards.forEach(card => {
        const name = card.dataset.name || '';
        const cardLang = card.dataset.lang || '';
        const desc = card.textContent?.toLowerCase() || '';
        const matchesSearch = !search || name.includes(search) || desc.includes(search);
        const matchesLang = lang === 'all' || cardLang === lang;
        const show = matchesSearch && matchesLang;
        card.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });

      if (repoCount) repoCount.textContent = `Showing ${visible} repos`;
      if (emptyState) emptyState.classList.toggle('hidden', visible > 0);

      const visibleCards = cards.filter(c => c.style.display !== 'none');
      visibleCards.sort((a, b) => {
        if (sort === 'stars') return parseInt(b.dataset.stars || '0') - parseInt(a.dataset.stars || '0');
        if (sort === 'forks') return parseInt(b.dataset.forks || '0') - parseInt(a.dataset.forks || '0');
        if (sort === 'updated') return (b.dataset.updated || '').localeCompare(a.dataset.updated || '');
        return (a.dataset.name || '').localeCompare(b.dataset.name || '');
      });
      visibleCards.forEach(card => grid?.appendChild(card));
    }

    searchInput?.addEventListener('input', filterRepos);
    langFilter?.addEventListener('change', filterRepos);
    sortFilter?.addEventListener('change', filterRepos);
  </script>
</Layout>
