---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

let db: any = { stackoverflow: { user: null, tags: [] } };
try {
  const raw = await fs.readFile(path.resolve('./src/data/generated/dev-stats.json'), 'utf-8');
  db = JSON.parse(raw);
} catch (e) {
  console.warn('[StackOverflow] dev-stats.json not found.');
}

const user = db.stackoverflow?.user;
const tags = db.stackoverflow?.tags || [];
---

<Layout title="StackOverflow" description="Chirag Singhal's StackOverflow profile — reputation, badges, and tags">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[#f48024]/10 flex items-center justify-center">
        <svg class="h-5 w-5 text-[#f48024]" viewBox="0 0 120 120" fill="currentColor"><path d="M84.4 93.8V70.6h7.7v30.9H22.6V70.6h7.7v23.2z"/><path d="M38.8 68.4l37.8 7.9 1.6-7.6-37.8-7.9-1.6 7.6zm5-18l35 16.3 3.2-7-35-16.4-3.2 7.1zm9.7-17.2l29.7 24.7 4.9-5.9-29.7-24.7-4.9 5.9zm19.2-18.3l-6.2 4.6 23 31 6.2-4.6-23-31zM38 86h38.6v-7.7H38V86z"/></svg>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">StackOverflow</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Developer reputation and community contributions.</p>

    {user ? (
      <>
        <div class="glass-strong p-8 mb-12">
          <div class="flex items-center gap-4 mb-6">
            {user.profileImage && <img src={user.profileImage} alt="Avatar" class="w-16 h-16 rounded-full" />}
            <div>
              <h2 class="text-xl font-bold text-white">{user.displayName}</h2>
              <p class="text-sm text-[var(--color-text-muted)]">Member since {new Date(user.creationDate * 1000).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="text-center p-4 rounded-lg bg-white/[0.02]">
              <div class="text-2xl font-bold text-[#f48024]">{user.reputation?.toLocaleString()}</div>
              <div class="text-xs text-[var(--color-text-muted)]">Reputation</div>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/[0.02]">
              <div class="text-2xl font-bold text-yellow-400">{user.badgeCounts?.gold}</div>
              <div class="text-xs text-[var(--color-text-muted)]">Gold Badges</div>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/[0.02]">
              <div class="text-2xl font-bold text-gray-300">{user.badgeCounts?.silver}</div>
              <div class="text-xs text-[var(--color-text-muted)]">Silver Badges</div>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/[0.02]">
              <div class="text-2xl font-bold text-amber-600">{user.badgeCounts?.bronze}</div>
              <div class="text-xs text-[var(--color-text-muted)]">Bronze Badges</div>
            </div>
          </div>
        </div>

        {tags.length > 0 && (
          <div class="glass p-8 mb-12">
            <h2 class="text-xl font-bold text-white mb-6">Top Tags</h2>
            <div class="flex flex-wrap gap-3">
              {tags.map((tag: any) => (
                <a href={`https://stackoverflow.com/questions/tagged/${tag.name}`} target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg bg-white/[0.02] border border-white/5 hover:border-[#f48024]/30 transition-colors">
                  <span class="text-sm text-white font-medium">{tag.name}</span>
                  <span class="text-xs text-[#f48024] ml-2">× {tag.count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-[var(--color-text-muted)]">StackOverflow data not available. Run fetch-data first.</p>
      </div>
    )}

    <div class="glass p-6 text-center">
      <a href="https://stackoverflow.com/users/18901471/chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-[#f48024] hover:underline">View on StackOverflow →</a>
    </div>
  </main>
  <Footer />
</Layout>
