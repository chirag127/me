---
import {
  fetchCodewarsUser,
  fetchGitHubRepos,
  fetchGitHubUser,
  fetchLeetCodeStats,
} from '../../lib/api';

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import StatsCounter from '../../components/islands/StatsCounter';
import Footer from '../../components/Footer.astro';

const [githubUser, githubRepos, leetcodeStats, _codewarsUser] =
  await Promise.all([
    fetchGitHubUser(),
    fetchGitHubRepos(),
    fetchLeetCodeStats(),
    fetchCodewarsUser(),
  ]);

const _totalStars = githubRepos.reduce((sum, r) => sum + r.stargazers_count, 0);
const _totalForks = githubRepos.reduce((sum, r) => sum + r.forks_count, 0);

// Top languages by repo count
const langMap = new Map<string, number>();
githubRepos
  .filter((r) => r.language)
  .forEach((r) =>
    langMap.set(r.language!, (langMap.get(r.language!) || 0) + 1),
  );
const _topLanguages = [...langMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

// Recent repos (last 10 updated)
const _recentRepos = [...githubRepos]
  .sort(
    (a, b) =>
      new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime(),
  )
  .slice(0, 10);

// Account age
const _accountAge = githubUser
  ? new Date().getFullYear() - new Date(githubUser.created_at).getFullYear()
  : 0;

// LeetCode percentages
const _lecEasyPct = leetcodeStats
  ? Math.round((leetcodeStats.totalEasySolved / leetcodeStats.totalEasy) * 100)
  : 0;
const _lecMedPct = leetcodeStats
  ? Math.round(
      (leetcodeStats.totalMediumSolved / leetcodeStats.totalMedium) * 100,
    )
  : 0;
const _lecHardPct = leetcodeStats
  ? Math.round((leetcodeStats.totalHardSolved / leetcodeStats.totalHard) * 100)
  : 0;
---

<Layout title="Code Drive" description="GitHub stats, LeetCode progress, Codewars rank, and coding activity — all inline">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 relative">
    <div class="absolute top-0 right-0 w-96 h-96 bg-amber-500/4 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-64 h-64 bg-violet-500/4 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Header -->
    <div class="mb-12 relative reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/40 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        CODE Drive
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Coding Stats</h1>
      <p class="text-lg text-white/40 max-w-2xl">All data fetched live at build time from GitHub, LeetCode, and Codewars.</p>
    </div>

    <!-- Main Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="glass p-6 text-center"><StatsCounter client:visible value={githubUser?.public_repos || 0} label="Public Repos" icon="📦" /></div>
      <div class="glass p-6 text-center"><StatsCounter client:visible value={totalStars} label="Total Stars" icon="⭐" /></div>
      <div class="glass p-6 text-center"><StatsCounter client:visible value={githubUser?.followers || 0} label="Followers" icon="👥" /></div>
      <div class="glass p-6 text-center"><StatsCounter client:visible value={leetcodeStats?.totalSolved || 0} label="LeetCode Solved" icon="🧩" /></div>
    </div>

    <!-- Secondary Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 reveal-stagger">
      <div class="glass p-5 text-center hover:border-white/10 transition-colors">
        <div class="text-xl font-bold text-white">{totalForks}</div>
        <div class="text-xs text-white/40 mt-1">Total Forks</div>
      </div>
      <div class="glass p-5 text-center hover:border-white/10 transition-colors">
        <div class="text-xl font-bold text-white">{topLanguages.length}</div>
        <div class="text-xs text-white/40 mt-1">Languages Used</div>
      </div>
      <div class="glass p-5 text-center hover:border-white/10 transition-colors">
        <div class="text-xl font-bold text-white">{accountAge}+</div>
        <div class="text-xs text-white/40 mt-1">Years on GitHub</div>
      </div>
      <div class="glass p-5 text-center hover:border-white/10 transition-colors">
        <div class="text-xl font-bold text-white">{codewarsUser?.codeChallenges?.totalCompleted || 0}</div>
        <div class="text-xs text-white/40 mt-1">Codewars Challenges</div>
      </div>
    </div>

    <!-- GitHub Profile Inline -->
    {githubUser && (
      <div class="glass p-8 mb-8 reveal">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-10 w-10 rounded-lg bg-white/5 flex items-center justify-center">
            <svg class="h-5 w-5 text-white/70" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white">GitHub Profile</h2>
            <p class="text-xs text-white/40">@{githubUser.login} · {githubUser.name}</p>
          </div>
        </div>
        {githubUser.bio && <p class="text-sm text-white/50 mb-5 leading-relaxed">{githubUser.bio}</p>}
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="p-3 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-lg font-bold text-white">{githubUser.public_repos}</div>
            <div class="text-[10px] text-white/30 uppercase tracking-wider">Repos</div>
          </div>
          <div class="p-3 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-lg font-bold text-white">{githubUser.followers}</div>
            <div class="text-[10px] text-white/30 uppercase tracking-wider">Followers</div>
          </div>
          <div class="p-3 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-lg font-bold text-white">{githubUser.following}</div>
            <div class="text-[10px] text-white/30 uppercase tracking-wider">Following</div>
          </div>
          <div class="p-3 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-lg font-bold text-white">{accountAge}+</div>
            <div class="text-[10px] text-white/30 uppercase tracking-wider">Years Active</div>
          </div>
        </div>
      </div>
    )}

    <!-- LeetCode Section -->
    {leetcodeStats && (
      <div class="glass p-8 mb-8 reveal">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-10 w-10 rounded-lg bg-amber-500/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white">LeetCode Progress</h2>
            <p class="text-xs text-white/40">@{githubUser?.login || 'chirag127'} · {leetcodeStats.totalSolved} solved out of {leetcodeStats.totalEasy + leetcodeStats.totalMedium + leetcodeStats.totalHard} total</p>
          </div>
        </div>

        <!-- Difficulty Progress Bars -->
        <div class="space-y-5 mb-6">
          <div>
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                <span class="text-sm text-emerald-400 font-medium">Easy</span>
              </div>
              <span class="text-sm text-white/50 font-medium">{leetcodeStats.totalEasySolved} <span class="text-white/25">/ {leetcodeStats.totalEasy}</span></span>
            </div>
            <div class="h-3 rounded-full bg-white/5 overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r from-emerald-500 to-emerald-400 transition-all duration-700" style={`width: ${lecEasyPct}%`}></div>
            </div>
            <div class="text-xs text-white/25 mt-1">{lecEasyPct}% completed</div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
                <span class="text-sm text-amber-400 font-medium">Medium</span>
              </div>
              <span class="text-sm text-white/50 font-medium">{leetcodeStats.totalMediumSolved} <span class="text-white/25">/ {leetcodeStats.totalMedium}</span></span>
            </div>
            <div class="h-3 rounded-full bg-white/5 overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r from-amber-500 to-amber-400 transition-all duration-700" style={`width: ${lecMedPct}%`}></div>
            </div>
            <div class="text-xs text-white/25 mt-1">{lecMedPct}% completed</div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
                <span class="text-sm text-red-400 font-medium">Hard</span>
              </div>
              <span class="text-sm text-white/50 font-medium">{leetcodeStats.totalHardSolved} <span class="text-white/25">/ {leetcodeStats.totalHard}</span></span>
            </div>
            <div class="h-3 rounded-full bg-white/5 overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r from-red-500 to-red-400 transition-all duration-700" style={`width: ${lecHardPct}%`}></div>
            </div>
            <div class="text-xs text-white/25 mt-1">{lecHardPct}% completed</div>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-4 pt-4 border-t border-white/5">
          <div class="text-center">
            <div class="text-xl font-bold text-[var(--color-primary)]">{leetcodeStats.acceptanceRate?.toFixed(1)}%</div>
            <div class="text-xs text-white/40">Acceptance Rate</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white">{leetcodeStats.totalSolved}</div>
            <div class="text-xs text-white/40">Total Solved</div>
          </div>
          <div class="text-center">
            <div class="text-xl font-bold text-white">{leetcodeStats.ranking > 0 ? `#${leetcodeStats.ranking.toLocaleString()}` : 'N/A'}</div>
            <div class="text-xs text-white/40">Global Rank</div>
          </div>
        </div>
      </div>
    )}

    <!-- Codewars Section -->
    {codewarsUser && (
      <div class="glass p-8 mb-8 reveal">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-10 w-10 rounded-lg bg-red-500/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white">Codewars</h2>
            <p class="text-xs text-white/40">@{codewarsUser.username} · {codewarsUser.clan || 'No clan'}</p>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-2xl font-bold text-[var(--color-primary)]">{codewarsUser.ranks.overall.name}</div>
            <div class="text-xs text-white/40">Overall Rank</div>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-2xl font-bold text-white">{codewarsUser.honor}</div>
            <div class="text-xs text-white/40">Honor Points</div>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-2xl font-bold text-white">{codewarsUser.codeChallenges.totalCompleted}</div>
            <div class="text-xs text-white/40">Completed</div>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-2xl font-bold text-white">{codewarsUser.codeChallenges.totalAuthored}</div>
            <div class="text-xs text-white/40">Authored</div>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 text-center">
            <div class="text-2xl font-bold text-white">#{codewarsUser.leaderboardPosition}</div>
            <div class="text-xs text-white/40">Leaderboard</div>
          </div>
        </div>

        {codewarsUser.ranks.languages && Object.keys(codewarsUser.ranks.languages).length > 0 && (
          <div class="pt-4 border-t border-white/5">
            <h3 class="text-sm font-medium text-white/50 mb-3">Language Ranks</h3>
            <div class="flex flex-wrap gap-2">
              {Object.entries(codewarsUser.ranks.languages).map(([lang, rank]) => (
                <span class="px-3 py-1.5 text-xs rounded-lg bg-white/5 text-white/50 border border-white/5 font-medium">
                  {lang}: <span class="text-[var(--color-primary)]">{rank.name}</span> ({rank.score})
                </span>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    <!-- Top Languages -->
    <div class="glass p-8 mb-8 reveal">
      <h2 class="text-xl font-bold text-white mb-5">Top Languages</h2>
      <div class="space-y-4">
        {topLanguages.map(([lang, count], i) => {
          const pct = Math.round((count / githubRepos.filter(r => r.language).length) * 100);
          const colors = ['from-amber-500 to-orange-400', 'from-sky-500 to-blue-400', 'from-emerald-500 to-green-400', 'from-violet-500 to-purple-400', 'from-rose-500 to-pink-400', 'from-cyan-500 to-teal-400', 'from-yellow-500 to-amber-400', 'from-indigo-500 to-blue-400', 'from-lime-500 to-green-400', 'from-fuchsia-500 to-pink-400'];
          return (
            <div>
              <div class="flex items-center justify-between text-sm mb-1.5">
                <span class="text-white/70 font-medium">{lang}</span>
                <span class="text-white/40">{count} repos · {pct}%</span>
              </div>
              <div class="h-2.5 rounded-full bg-white/5 overflow-hidden">
                <div class={`h-full rounded-full bg-gradient-to-r ${colors[i % colors.length]} transition-all duration-500`} style={`width: ${pct}%`}></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Recent Repos -->
    <div class="glass p-8 mb-8 reveal">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-white">Recently Updated Repos</h2>
        <span class="text-xs text-white/30">{recentRepos.length} most recent</span>
      </div>
      <div class="space-y-3">
        {recentRepos.map((repo) => (
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/5 hover:border-white/10 transition-colors">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-white truncate">{repo.name}</h3>
                {repo.description && <p class="text-xs text-white/40 mt-1 line-clamp-2">{repo.description}</p>}
              </div>
              <div class="flex items-center gap-3 text-xs text-white/30 flex-shrink-0">
                {repo.stargazers_count > 0 && (
                  <span class="flex items-center gap-1">
                    <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/></svg>
                    {repo.stargazers_count}
                  </span>
                )}
                {repo.forks_count > 0 && (
                  <span class="flex items-center gap-1">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
                    {repo.forks_count}
                  </span>
                )}
              </div>
            </div>
            <div class="flex items-center gap-2 mt-2">
              {repo.language && <span class="inline-flex items-center gap-1 text-[10px] text-white/40"><span class="h-2 w-2 rounded-full bg-[var(--color-primary)]"></span>{repo.language}</span>}
              {repo.topics?.slice(0, 3).map((t) => <span class="px-1.5 py-0.5 text-[9px] rounded-full bg-white/5 text-white/30">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- All Repos Count -->
    <div class="glass p-6 text-center mb-8">
      <div class="text-2xl font-bold text-white mb-1">{githubRepos.length}</div>
      <div class="text-xs text-white/40">Total Public Repositories</div>
    </div>

    <!-- Other Dev Platforms -->
    <h2 class="text-xl font-bold text-white mb-6">Other Dev Platforms</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <a href="/code/npm" class="glass p-6 border border-white/5 hover:border-[#cb3837]/30 transition-colors group">
        <div class="h-10 w-10 rounded-xl bg-[#cb3837]/10 flex items-center justify-center mb-3">
          <svg class="h-5 w-5 text-[#cb3837]" viewBox="0 0 24 24" fill="currentColor"><path d="M1.765 11.184h1.785v2.632h1.362V8.552H1.765v2.632zm5.338-2.632H5.74v7.895h2.725v-5.264h1.362v5.264h1.363V8.552H7.103zm6.7 0h-1.363v7.895h4.088v-2.632h-2.725V8.552zm5.338 0h-1.363v7.895h1.363v-5.263h1.362v5.263h1.363V8.552h-2.725z"/></svg>
        </div>
        <h3 class="text-base font-semibold text-white group-hover:text-[#cb3837] transition-colors">NPM</h3>
        <p class="text-xs text-white/40 mt-1">Published packages and download stats</p>
      </a>
      <a href="/code/stackoverflow" class="glass p-6 border border-white/5 hover:border-[#f48024]/30 transition-colors group">
        <div class="h-10 w-10 rounded-xl bg-[#f48024]/10 flex items-center justify-center mb-3">
          <svg class="h-5 w-5 text-[#f48024]" viewBox="0 0 120 120" fill="currentColor"><path d="M84.4 93.8V70.6h7.7v30.9H22.6V70.6h7.7v23.2z"/><path d="M38.8 68.4l37.8 7.9 1.6-7.6-37.8-7.9-1.6 7.6zm5-18l35 16.3 3.2-7-35-16.4-3.2 7.1zm9.7-17.2l29.7 24.7 4.9-5.9-29.7-24.7-4.9 5.9zm19.2-18.3l-6.2 4.6 23 31 6.2-4.6-23-31zM38 86h38.6v-7.7H38V86z"/></svg>
        </div>
        <h3 class="text-base font-semibold text-white group-hover:text-[#f48024] transition-colors">StackOverflow</h3>
        <p class="text-xs text-white/40 mt-1">Reputation, badges, and contributions</p>
      </a>
      <a href="/code/holopin" class="glass p-6 border border-white/5 hover:border-[#2b6cb0]/30 transition-colors group">
        <div class="h-10 w-10 rounded-xl bg-[#2b6cb0]/10 flex items-center justify-center mb-3">
          <span class="text-xl">🏷️</span>
        </div>
        <h3 class="text-base font-semibold text-white group-hover:text-[#2b6cb0] transition-colors">Holopin</h3>
        <p class="text-xs text-white/40 mt-1">Open source contribution badges</p>
      </a>
    </div>
  </main>
  <Footer />
</Layout>
