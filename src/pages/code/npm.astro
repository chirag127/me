---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import CONFIG from '../../lib/config';

let db: any = { npm: { packages: [] } };
try {
  const raw = await fs.readFile(path.resolve('./src/data/generated/dev-stats.json'), 'utf-8');
  db = JSON.parse(raw);
} catch (e) {
  console.warn('[NPM] dev-stats.json not found.');
}

const packages = db.npm?.packages || [];
const totalDownloads = packages.reduce((s: number, p: any) => s + (p.downloads || 0), 0);
---

<Layout title="NPM Packages" description="Chirag Singhal's NPM packages — download stats and details">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-3 mb-2">
      <div class="h-10 w-10 rounded-xl bg-[#cb3837]/10 flex items-center justify-center">
        <svg class="h-5 w-5 text-[#cb3837]" viewBox="0 0 24 24" fill="currentColor"><path d="M1.765 11.184h1.785v2.632h1.362V8.552H1.765v2.632zm5.338-2.632H5.74v7.895h2.725v-5.264h1.362v5.264h1.363V8.552H7.103zm6.7 0h-1.363v7.895h4.088v-2.632h-2.725V8.552zm5.338 0h-1.363v7.895h1.363v-5.263h1.362v5.263h1.363V8.552h-2.725z"/></svg>
      </div>
      <h1 class="text-4xl font-bold font-[var(--font-display)] text-white">NPM Packages</h1>
    </div>
    <p class="text-[var(--color-text-secondary)] mb-10">Published packages by @{CONFIG.user.username} — with download stats.</p>

    <!-- Stats -->
    <div class="glass-strong p-6 mb-12 flex flex-wrap gap-8">
      <div>
        <div class="text-2xl font-bold text-[#cb3837]">{packages.length}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Packages</div>
      </div>
      <div>
        <div class="text-2xl font-bold text-white">{totalDownloads.toLocaleString()}</div>
        <div class="text-xs text-[var(--color-text-muted)]">Monthly Downloads</div>
      </div>
    </div>

    {packages.length > 0 ? (
      <div class="space-y-4">
        {packages.map((pkg: any) => (
          <div class="glass p-6 hover:border-white/10 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-base font-semibold text-white">{pkg.name}</h3>
                  {pkg.version && <span class="text-[0.6rem] px-2 py-0.5 rounded-full bg-[#cb3837]/10 text-[#cb3837]">v{pkg.version}</span>}
                </div>
                {pkg.description && <p class="text-sm text-[var(--color-text-muted)] mb-3">{pkg.description}</p>}
                <div class="flex items-center gap-3">
                  {pkg.downloads !== undefined && (
                    <span class="text-xs text-[var(--color-primary)] font-medium">{pkg.downloads.toLocaleString()} monthly downloads</span>
                  )}
                  {pkg.keywords?.length > 0 && (
                    <div class="flex gap-1 flex-wrap">
                      {pkg.keywords.slice(0, 5).map((kw: string) => (
                        <span class="text-[0.55rem] px-1.5 py-0.5 rounded-full bg-white/5 text-white/30">{kw}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
              <a href={`https://www.npmjs.com/package/${pkg.name}`} target="_blank" rel="noopener noreferrer" class="shrink-0">
                <svg class="h-5 w-5 text-white/20 hover:text-[#cb3837] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="glass p-12 text-center">
        <p class="text-[var(--color-text-muted)]">No NPM packages found. Run fetch-data first.</p>
        <p class="text-xs text-[var(--color-text-faint)] mt-2">Or check <a href={`https://www.npmjs.com/~${CONFIG.user.username}`} target="_blank" class="text-[#cb3837] hover:underline">NPM profile</a></p>
      </div>
    )}

    <div class="mt-12 glass p-6 text-center">
      <a href={`https://www.npmjs.com/~${CONFIG.user.username}`} target="_blank" rel="noopener noreferrer" class="text-sm text-[#cb3837] hover:underline">View NPM Profile →</a>
    </div>
  </main>
  <Footer />
  <ChatWidget client:load />
</Layout>
