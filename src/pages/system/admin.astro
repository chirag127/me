---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import AdminDashboard from '../../components/islands/AdminDashboard';
---

<Layout title="Admin Panel" description="Admin dashboard — Firestore analytics">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Breadcrumb -->
    <a href="/system" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to System Drive
    </a>

    <!-- Header -->
    <div class="mb-8">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs text-violet-300/80 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-violet-400 animate-pulse"></span>
        Admin Panel
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Admin Dashboard</h1>
      <p class="text-lg text-white/40 max-w-2xl">Firestore analytics and chat history management</p>
    </div>

    <!-- Admin Dashboard Island -->
    <AdminDashboard client:only="react" />
  </main>
</Layout>
