---
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

---

<Layout title="Changelog" description="Version history of Chirag Singhal">
  <CommandPalette />
  <main class="mx-auto max-w-[var(--content-max-width)] px-6 py-12">
    <!-- Breadcrumb -->
    <a href="/system" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/60 mb-8 transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to System Drive
    </a>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-500/10 border border-teal-500/20 text-xs text-teal-300/80 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        Changelog
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Version History</h1>
      <p class="text-lg text-white/40 max-w-2xl">All notable changes to the platform</p>
    </div>

    <!-- Timeline -->
    <div class="relative border-l border-white/10 ml-3 space-y-8">
      <!-- v1.0.0 -->
      <div class="relative pl-8">
        <!-- Timeline dot -->
        <div class="absolute -left-1.5 top-2 h-3 w-3 rounded-full bg-teal-400 ring-4 ring-[#030303]"></div>
        <div class="glass p-8 border-l-2 border-teal-400">
          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 text-xs font-bold rounded-full bg-teal-500/20 text-teal-400">v1.0.0</span>
            <span class="text-xs text-white/40">March 2026</span>
          </div>
          <h2 class="text-lg font-semibold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Initial Release</h2>
          <ul class="space-y-2 text-sm text-white/50">
            <li>✨ Chirag Singhal — Dashboard, Story, Philosophy, Journal, Interests, Gear, Finance</li>
            <li>💼 WORK Drive — Career timeline, Skills, Projects, Education, Certifications</li>
            <li>💻 CODE Drive — GitHub analytics, Repository explorer, LeetCode stats</li>
            <li>📚 LIBRARY Drive — Movies, Anime, Books, Music, Videos</li>
            <li>🎮 GAMING Drive — Chess (Lichess), Game tracking (Backloggd), Speedruns</li>
            <li>🌐 CONNECT Drive — Social profiles, Contact info</li>
            <li>⚙️ SYSTEM Drive — Theme switcher, Changelog, Admin panel</li>
            <li>🔐 Firebase Authentication — Google sign-in, Email/Password</li>
            <li>💬 Chat widget with Firestore storage</li>
            <li>🔍 Command palette (Cmd+K) for global search</li>
            <li>🎨 Dark mode with glassmorphism design system</li>
            <li>📱 Fully responsive mobile design</li>
            <li>☁️ Cloudflare Pages deployment</li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</Layout>
