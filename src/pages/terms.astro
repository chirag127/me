---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Service" description="Terms of Service for Chirag Singhal's Digital Identity">
  <main class="container mx-auto max-w-4xl px-4 py-24 pb-32">
    <div class="prose prose-invert max-w-none">
      <h1 class="text-4xl font-bold mb-8">Terms of Service</h1>
      <p class="text-[var(--color-text-secondary)] mb-8">Last Updated: {new Date().toLocaleDateString()}</p>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4">1. Acceptance of Terms</h2>
        <p>
          By accessing or using our services, you agree to be bound by these Terms of Service. 
          If you do not agree with any part of these terms, you may not use our services.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4">2. Intellectual Property Rights</h2>
        <p>
          Unless otherwise stated, we or our licensors own the intellectual property rights for all material 
          on this website. All intellectual property rights are reserved. 
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4">3. User Obligations</h2>
        <p>
          You agree not to use the website in a way that may cause damage to the website or impairment of 
          the availability or accessibility of the website; or in any way which is unlawful, illegal, 
          fraudulent, or harmful. Code provided by the AI agent should be verified before use in production.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4">4. Limitation of Liability</h2>
        <p>
          We will not be held responsible or liable for any content, bugs, or errors arising from your use of the website or the generated AI content.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4">5. Contact Information</h2>
        <p>
          For any legal or Terms of Service related inquiries, please contact:
          <a href="mailto:hi@chirag127.in" class="text-[var(--color-primary)] hover:underline ml-1">hi@chirag127.in</a>
        </p>
      </section>
    </div>
  </main>
</Layout>
