---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import AIChat from '../../components/islands/AIChat';
import { skills } from '../../data/resume';
---

<Layout title="Interests" description="The things that excite Chirag Singhal — AI, chess, cinema, music, and more">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/me" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors group">
      <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      ME Drive
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gradient mb-3" style="font-family: 'Outfit', sans-serif;">Interests</h1>
      <p class="text-[var(--color-text-secondary)] text-lg">The things that keep me up at night — in the best way possible.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- AI & ML -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-amber-400/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors">AI & Machine Learning</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Building intelligent systems with LLMs, RAG pipelines, and autonomous agents. From NexusAI's multi-agent orchestration to Olivia's edge-first voice assistant — I'm obsessed with making AI actually useful, not just impressive demos.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tag">LangChain</span>
          <span class="tag">RAG</span>
          <span class="tag">Hugging Face</span>
          <span class="tag">Gemini</span>
        </div>
      </div>

      <!-- System Design -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-violet-400/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-violet-400 transition-colors">System Design</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Distributed systems, microservices, event-driven architectures. StreamGuard handles 10k+ events/sec. OmniPublish unifies 17+ platforms. The art of building systems that scale gracefully while remaining maintainable is endlessly fascinating to me.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tag">Microservices</span>
          <span class="tag">Kafka</span>
          <span class="tag">Event-Driven</span>
          <span class="tag">HLD/LLD</span>
        </div>
      </div>

      <!-- Music -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-rose-400/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-rose-400 transition-colors">Music</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Always listening. My Last.fm scrobbles tell the story — from late-night electronic coding sessions to afternoon lo-fi. Music is the background process that makes everything else better. Track what I'm listening to on Last.fm (username: lastfmwhy).</p>
        <a href="https://last.fm/user/lastfmwhy" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-rose-400/70 hover:text-rose-400 transition-colors mt-1">
          Last.fm profile
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      </div>

      <!-- Cinema -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-amber-500 transition-colors">Cinema</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Tracking everything on Letterboxd and AniList. I appreciate storytelling in all its forms — from Nolan's time-bending narratives to Studio Ghibli's quiet beauty. Anime, films, series — if it tells a good story, I'm watching it.</p>
        <div class="flex gap-3">
          <a href="https://letterboxd.com/chirag127" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-amber-500/70 hover:text-amber-500 transition-colors">
            Letterboxd
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
          <a href="https://anilist.co/user/chirag127" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-sky-400/70 hover:text-sky-400 transition-colors">
            AniList
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>

      <!-- Reading -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-emerald-400/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-emerald-400 transition-colors">Reading</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Always have a book going. From technical papers and system design case studies to fiction that stretches the imagination. Reading is how you download decades of someone else's experience into your brain in a weekend.</p>
      </div>

      <!-- Chess -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-sky-400/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-sky-400" viewBox="0 0 24 24" fill="currentColor"><path d="M6 3h12v2H6V3zm5.5 4C12.88 7 14 8.12 14 9.5c0 .48-.13.92-.35 1.3l.65.7h.7c.83 0 1.5.67 1.5 1.5v4c0 .83-.67 1.5-1.5 1.5h-9c-.83 0-1.5-.67-1.5-1.5v-4c0-.83.67-1.5 1.5-1.5h.7l.65-.7A2.49 2.49 0 017 9.5C7 8.12 8.12 7 9.5 7h2z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-sky-400 transition-colors">Chess</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Playing on Lichess regularly. The intersection of pattern recognition, strategic thinking, and calculation appeals to my engineering brain. Every game is a system design problem — except your opponent is actively trying to break your architecture.</p>
        <a href="https://lichess.org/@/chirag127" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-sky-400/70 hover:text-sky-400 transition-colors mt-1">
          Lichess profile
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      </div>

      <!-- Security -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-rose-500/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-rose-500 transition-colors">Security</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Cryptography, OWASP, secure coding practices. Implemented 40+ hash algorithms and client-side encryption in Oriz. Kinde Auth with PKCE. reCAPTCHA v3. I believe security should be invisible to users but impenetrable to attackers.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tag">OWASP</span>
          <span class="tag">OAuth 2.0</span>
          <span class="tag">PKCE</span>
          <span class="tag">40+ Hash Algos</span>
        </div>
      </div>

      <!-- Cloud Native -->
      <div class="glass-strong p-8 group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-10 w-10 rounded-xl bg-sky-500/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
          </div>
          <h2 class="text-lg font-bold text-white group-hover:text-sky-500 transition-colors">Cloud Native</h2>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">Cloudflare Workers, serverless architectures, edge computing. Chirag Singhal runs on Cloudflare Pages for ₹0. Oriz's 8 serverless edge functions handle comments, payments, and file uploads. Building for the modern internet means building at the edge — close to the user, far from the bill.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tag">Cloudflare</span>
          <span class="tag">Serverless</span>
          <span class="tag">Docker</span>
          <span class="tag">Kubernetes</span>
        </div>
      </div>
    </div>
  </main>
  <Footer />
  <AIChat client:load />
  <ChatWidget client:load />
</Layout>
