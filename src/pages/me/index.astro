---import { summary } from '../../data/resume';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';

---

<Layout title="Chirag Singhal" description="Who is Chirag Singhal — story, philosophy, interests, and personal data">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero -->
    <div class="relative mb-16">
      <div class="glow-ambient glow-amber -top-20 -left-20"></div>
      <div class="relative">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 text-white font-bold text-lg" style="font-family: 'Outfit', sans-serif;">CS</div>
          <div>
            <h1 class="text-4xl font-bold text-gradient" style="font-family: 'Outfit', sans-serif;">Chirag Singhal</h1>
            <p class="text-sm text-[var(--color-text-muted)] mt-0.5">The person behind the code</p>
          </div>
        </div>
        <p class="text-[var(--color-text-secondary)] max-w-2xl leading-relaxed mt-4" set:html={summary} />
      </div>
    </div>

    <!-- Navigation Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <a href="/me/story" class="card group">
        <div class="flex items-start gap-4">
          <div class="h-11 w-11 rounded-xl bg-amber-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-amber-400 transition-colors">Story</h2>
            <p class="text-sm text-white/40 mt-1">Ghaziabad → JEE Advanced → AKTU → QRsay → TCS. The journey so far.</p>
          </div>
        </div>
      </a>

      <a href="/me/philosophy" class="card group">
        <div class="flex items-start gap-4">
          <div class="h-11 w-11 rounded-xl bg-violet-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-violet-400 transition-colors">Philosophy</h2>
            <p class="text-sm text-white/40 mt-1">Principles that guide how I build software and live life.</p>
          </div>
        </div>
      </a>

      <a href="/me/journal" class="card group">
        <div class="flex items-start gap-4">
          <div class="h-11 w-11 rounded-xl bg-amber-600/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-amber-500 transition-colors">Journal</h2>
            <p class="text-sm text-white/40 mt-1">Private thoughts. Stored only in your browser. Never leaves your device.</p>
          </div>
        </div>
      </a>

      <a href="/me/interests" class="card group">
        <div class="flex items-start gap-4">
          <div class="h-11 w-11 rounded-xl bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition-colors">Interests</h2>
            <p class="text-sm text-white/40 mt-1">AI/ML, chess, cinema, music, system design, and the things that excite me.</p>
          </div>
        </div>
      </a>

      <a href="/me/gear" class="card group">
        <div class="flex items-start gap-4">
          <div class="h-11 w-11 rounded-xl bg-sky-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-sky-400 transition-colors">Gear</h2>
            <p class="text-sm text-white/40 mt-1">Dev setup, products, gadgets, and everything I own and use daily.</p>
          </div>
        </div>
      </a>

      <a href="/me/finance" class="card group">
        <div class="flex items-start gap-4">
          <div class="h-11 w-11 rounded-xl bg-rose-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="h-5 w-5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-white group-hover:text-rose-400 transition-colors">Finance</h2>
            <p class="text-sm text-white/40 mt-1">Private financial data. Stored locally. Nothing leaves this device.</p>
          </div>
        </div>
      </a>
    </div>

    <!-- Quick Stats -->
    <div class="mt-16 glass p-8">
      <h2 class="text-lg font-semibold text-white mb-6">Quick Facts</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-2xl font-bold text-amber-400">JEE</div>
          <div class="text-xs text-white/40 mt-1">AIR 11870</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-emerald-400">8.81</div>
          <div class="text-xs text-white/40 mt-1">CGPA (Rank 1)</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-sky-400">2+</div>
          <div class="text-xs text-white/40 mt-1">Years Experience</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-violet-400">100+</div>
          <div class="text-xs text-white/40 mt-1">GitHub Repos</div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
