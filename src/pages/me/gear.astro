---
const _categoryIcons: Record<string, { icon: string; color: string }> = {
  'Development Environment': {
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    color: 'text-amber-400',
  },
  'Languages & Frameworks': {
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    color: 'text-violet-400',
  },
  'AI & ML Tools': {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    color: 'text-amber-500',
  },
  'Cloud & Hosting': {
    icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
    color: 'text-sky-400',
  },
  Databases: {
    icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4',
    color: 'text-emerald-400',
  },
};
---

<Layout title="Gear & Setup" description="The tools, languages, and infrastructure Chirag uses to build software">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/me" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors group">
      <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Chirag Singhal
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gradient mb-3" style="font-family: 'Outfit', sans-serif;">Gear & Setup</h1>
      <p class="text-[var(--color-text-secondary)] text-lg">The tools I reach for every day. No sponsorships, no fluff — just what actually works.</p>
    </div>

    <div class="space-y-10">
      {usesData.map((category) => {
        const meta = categoryIcons[category.category] || { icon: "M5 13l4 4L19 7", color: "text-amber-400" };
        return (
          <section>
            <div class="flex items-center gap-3 mb-5">
              <div class={`h-9 w-9 rounded-lg bg-white/5 flex items-center justify-center`}>
                <svg class={`h-4 w-4 ${meta.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={meta.icon} /></svg>
              </div>
              <h2 class="section-heading text-lg font-bold text-white">{category.category}</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {category.items.map((item) => (
                <div class="glass p-5 flex items-start gap-4">
                  <div class="h-2 w-2 rounded-full bg-amber-400/60 mt-2 flex-shrink-0"></div>
                  <div>
                    <h3 class="text-sm font-semibold text-white">{item.name}</h3>
                    <p class="text-xs text-[var(--color-text-muted)] mt-1">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </div>

    <div class="mt-16 glass p-6 flex items-center gap-4">
      <svg class="h-5 w-5 text-amber-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <p class="text-xs text-[var(--color-text-muted)]">This page is inspired by <a href="https://uses.tech" target="_blank" rel="noopener noreferrer" class="text-amber-400/70 hover:text-amber-400 transition-colors">uses.tech</a>. Updated periodically as my stack evolves.</p>
    </div>
  </main>
  <Footer />
</Layout>
