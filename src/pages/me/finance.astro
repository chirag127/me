---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import ChatWidget from '../../components/islands/ChatWidget';
import AIChat from '../../components/islands/AIChat';
---

<Layout title="Finance" description="Personal financial overview — all data stays on your device">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/me" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors group">
      <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      ME Drive
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gradient mb-3" style="font-family: 'Outfit', sans-serif;">Finance</h1>
      <p class="text-[var(--color-text-secondary)] text-lg">Your money, your data. Nothing leaves this device.</p>
    </div>

    <!-- Privacy Lock -->
    <div class="glass-strong p-10 text-center mb-12">
      <div class="h-20 w-20 rounded-3xl bg-emerald-500/10 flex items-center justify-center mx-auto mb-6 ring-1 ring-emerald-500/20">
        <svg class="h-10 w-10 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
      </div>
      <h2 class="text-xl font-semibold text-white mb-2">Local-Only Financial Data</h2>
      <p class="text-sm text-[var(--color-text-muted)] max-w-lg mx-auto leading-relaxed">This page is designed for personal financial tracking. All data you enter here is stored exclusively in your browser's localStorage — encrypted at rest by your browser. No API calls, no analytics, no tracking. Not even I (Chirag) can see it.</p>
    </div>

    <!-- Financial Overview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="glass p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-white/40 uppercase tracking-wider">Monthly Income</span>
          <svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg>
        </div>
        <div id="income-display" class="text-2xl font-bold text-emerald-400">--</div>
        <p class="text-xs text-white/25 mt-1">Set in your local data</p>
      </div>
      <div class="glass p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-white/40 uppercase tracking-wider">Monthly Expenses</span>
          <svg class="h-4 w-4 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 13l-5 5m0 0l-5-5m5 5V6" /></svg>
        </div>
        <div id="expenses-display" class="text-2xl font-bold text-rose-400">--</div>
        <p class="text-xs text-white/25 mt-1">Tracked locally</p>
      </div>
      <div class="glass p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-medium text-white/40 uppercase tracking-wider">Savings Rate</span>
          <svg class="h-4 w-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
        </div>
        <div id="savings-display" class="text-2xl font-bold text-amber-400">--</div>
        <p class="text-xs text-white/25 mt-1">Auto-calculated</p>
      </div>
    </div>

    <!-- Entry Form -->
    <div class="glass-strong p-8 mb-8">
      <h2 class="text-base font-semibold text-white mb-5">Update Financial Data</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
        <div>
          <label class="block text-xs font-medium text-white/40 mb-2 uppercase tracking-wider">Monthly Income (₹)</label>
          <input id="fin-income" type="number" placeholder="0" class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-emerald-500/50 transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-white/40 mb-2 uppercase tracking-wider">Monthly Expenses (₹)</label>
          <input id="fin-expenses" type="number" placeholder="0" class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-rose-500/50 transition-colors" />
        </div>
      </div>
      <div class="mb-5">
        <label class="block text-xs font-medium text-white/40 mb-2 uppercase tracking-wider">Notes</label>
        <textarea id="fin-notes" rows="2" placeholder="Any notes about this month..." class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-amber-500/50 resize-none transition-colors"></textarea>
      </div>
      <button id="save-finance" class="btn-primary">Save to Local Storage</button>
    </div>

    <!-- History -->
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">History</h2>
      <button id="clear-finance" class="text-xs text-white/20 hover:text-red-400 transition-colors">Clear All Data</button>
    </div>
    <div id="finance-history" class="space-y-3">
      <div class="text-center text-white/30 text-sm py-8">No financial data saved yet.</div>
    </div>
  </main>
  <Footer />
  <AIChat client:load />
  <ChatWidget client:load />

  <script is:inline>
    function loadFinance() {
      const data = JSON.parse(localStorage.getItem('chirag-singhal-finance') || '{"entries":[]}');
      const entries = data.entries || [];

      // Update summary from latest entry
      if (entries.length > 0) {
        const latest = entries[0];
        const income = latest.income || 0;
        const expenses = latest.expenses || 0;
        const savingsRate = income > 0 ? Math.round(((income - expenses) / income) * 100) : 0;
        document.getElementById('income-display').textContent = '₹' + income.toLocaleString('en-IN');
        document.getElementById('expenses-display').textContent = '₹' + expenses.toLocaleString('en-IN');
        document.getElementById('savings-display').textContent = savingsRate + '%';
      }

      // Render history
      const hist = document.getElementById('finance-history');
      if (entries.length === 0) {
        hist.innerHTML = '<div class="text-center text-white/30 text-sm py-8">No financial data saved yet.</div>';
        return;
      }
      hist.innerHTML = entries.map(e => `
        <div class="glass p-5 group">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs text-white/30">${new Date(e.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            <button onclick="deleteFinance('${e.id}')" class="text-xs text-white/20 hover:text-red-400 transition-colors opacity-0 group-hover:opacity-100">Delete</button>
          </div>
          <div class="flex gap-6 text-sm">
            <span class="text-emerald-400/80">Income: ₹${(e.income || 0).toLocaleString('en-IN')}</span>
            <span class="text-rose-400/80">Expenses: ₹${(e.expenses || 0).toLocaleString('en-IN')}</span>
            <span class="text-amber-400/80">Savings: ${e.income > 0 ? Math.round(((e.income - e.expenses) / e.income) * 100) : 0}%</span>
          </div>
          ${e.notes ? `<p class="text-xs text-white/40 mt-2">${e.notes}</p>` : ''}
        </div>
      `).join('');
    }

    window.deleteFinance = function(id) {
      const data = JSON.parse(localStorage.getItem('chirag-singhal-finance') || '{"entries":[]}');
      data.entries = (data.entries || []).filter(e => e.id !== id);
      localStorage.setItem('chirag-singhal-finance', JSON.stringify(data));
      loadFinance();
    };

    document.getElementById('save-finance')?.addEventListener('click', () => {
      const income = parseInt(document.getElementById('fin-income').value) || 0;
      const expenses = parseInt(document.getElementById('fin-expenses').value) || 0;
      const notes = document.getElementById('fin-notes').value.trim();
      if (income === 0 && expenses === 0) return;

      const data = JSON.parse(localStorage.getItem('chirag-singhal-finance') || '{"entries":[]}');
      data.entries = data.entries || [];
      data.entries.unshift({ id: Date.now().toString(), income, expenses, notes, date: new Date().toISOString() });
      localStorage.setItem('chirag-singhal-finance', JSON.stringify(data));

      document.getElementById('fin-income').value = '';
      document.getElementById('fin-expenses').value = '';
      document.getElementById('fin-notes').value = '';
      loadFinance();
    });

    document.getElementById('clear-finance')?.addEventListener('click', () => {
      if (confirm('Delete all financial data? This cannot be undone.')) {
        localStorage.removeItem('chirag-singhal-finance');
        loadFinance();
        document.getElementById('income-display').textContent = '--';
        document.getElementById('expenses-display').textContent = '--';
        document.getElementById('savings-display').textContent = '--';
      }
    });

    loadFinance();
  </script>
</Layout>
