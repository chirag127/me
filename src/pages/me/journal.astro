---
import JournalApp from '../../components/islands/JournalApp';
import Layout from '../../layouts/Layout.astro';
import CommandPalette from '../../components/CommandPalette.astro';

---

<Layout title="Journal" description="Personal journal entries — stored locally in your browser">  <CommandPalette />
  <main class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/me" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] mb-8 transition-colors group">
      <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      Chirag Singhal
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gradient mb-3" style="font-family: 'Outfit', sans-serif;">Journal</h1>
      <p class="text-[var(--color-text-secondary)] text-lg">Write freely. Everything stays on your device.</p>
    </div>

    <!-- Privacy notice -->
    <div class="glass p-4 mb-8 flex items-center gap-3">
      <svg class="h-5 w-5 text-emerald-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
      <p class="text-xs text-[var(--color-text-muted)]">All entries are securely synced to your account via <code class="text-emerald-400/80 bg-emerald-400/10 px-1.5 py-0.5 rounded text-[11px]">Firestore</code>.</p>
    </div>

    <JournalApp client:load />
    
  </main></Layout>
