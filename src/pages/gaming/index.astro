---
import * as fs from 'node:fs/promises';
import * as path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CommandPalette from '../../components/CommandPalette.astro';
import StatsCounter from '../../components/islands/StatsCounter';
import { fetchSpeedRunUser } from '../../lib/api';
import CONFIG from '../../lib/config';

let db: any = {};
try {
  const raw = await fs.readFile(path.resolve('./src/data/generated/games.json'), 'utf-8');
  db = JSON.parse(raw);
} catch (e) {
  console.warn('[Gaming Hub] games.json not found. Run pnpm run fetch-data first.');
}

const lichessStats = db.lichessStats || null;
const steamGames = db.steamGames || [];
const steamRecent = db.steamRecent || [];

const speedrunUser = await fetchSpeedRunUser().catch(() => null);

const totalGames = lichessStats?.totalGames || 0;
const wins = lichessStats?.wins || 0;
const draws = lichessStats?.draws || 0;
const losses = lichessStats?.losses || 0;
const winRate = totalGames > 0 ? ((wins / totalGames) * 100).toFixed(1) : '0';

// Chess ratings with colors
const ratings = [
  lichessStats?.ratings?.bullet ? { name: 'Bullet', rating: lichessStats.ratings.bullet.rating, games: lichessStats.ratings.bullet.games, color: 'text-red-400', bg: 'bg-red-400/10', border: 'border-red-400/20' } : null,
  lichessStats?.ratings?.blitz ? { name: 'Blitz', rating: lichessStats.ratings.blitz.rating, games: lichessStats.ratings.blitz.games, color: 'text-amber-400', bg: 'bg-amber-400/10', border: 'border-amber-400/20' } : null,
  lichessStats?.ratings?.rapid ? { name: 'Rapid', rating: lichessStats.ratings.rapid.rating, games: lichessStats.ratings.rapid.games, color: 'text-emerald-400', bg: 'bg-emerald-400/10', border: 'border-emerald-400/20' } : null,
  lichessStats?.ratings?.classical ? { name: 'Classical', rating: lichessStats.ratings.classical.rating, games: lichessStats.ratings.classical.games, color: 'text-[var(--color-accent-violet)]', bg: 'bg-[var(--color-accent-violet)]/10', border: 'border-[var(--color-accent-violet)]/20' } : null,
].filter(Boolean);

const chessPlatforms = [
  { name: 'Lichess', handle: `@${CONFIG.user.lichess}`, description: 'Free, open-source chess server. Bullet, blitz, and rapid rated games.', icon: '♟️' },
  { name: 'Steam', handle: `@${process.env.STEAM_USER_ID ? 'User' : 'Unknown'}`, description: 'PC Gaming platform and library tracking.', icon: '🎮' },
  { name: 'Speedrun.com', handle: `@${CONFIG.user.speedrun}`, description: speedrunUser ? `Speedrunner from ${speedrunUser.data?.location?.country?.names?.international || 'Unknown'}. Submit runs and compete on leaderboards.` : 'Speedrun records and leaderboard submissions.', icon: '⚡' },
];
---

<Layout title="Gaming Drive" description="Chess ratings, game tracking, and speedrun records — Chirag Singhal">
  <Navbar />
  <CommandPalette />
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 relative">
    <div class="absolute top-0 right-0 w-72 h-72 bg-violet-500/6 rounded-full blur-3xl pointer-events-none"></div>

    <!-- Header -->
    <div class="mb-12 relative flex items-center justify-between">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/40 mb-6">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-violet)]"></span>
          GAMING Drive
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Gaming Stats</h1>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl">Chess ratings, game tracking, and speedrun records — fetched at build time.</p>
      </div>
    </div>

    <!-- Chess Ratings -->
    {lichessStats?.username && (
      <div class="glass-strong p-8 mb-8 border border-white/5 bg-gradient-to-br from-white/5 to-transparent">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-12 w-12 rounded-xl bg-[var(--color-accent-violet)]/10 flex items-center justify-center">
            <span class="text-2xl">♟️</span>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white">Lichess Chess Ratings</h2>
            <p class="text-xs text-[var(--color-text-muted)]">@{lichessStats.username}</p>
          </div>
        </div>

        <!-- Rating Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          {ratings.map((r) => (
            <div class={`p-5 rounded-xl ${r!.bg} border ${r!.border} text-center transition-transform hover:-translate-y-1 hover:shadow-lg`}>
              <div class={`text-3xl font-bold ${r!.color}`}>{r!.rating}</div>
              <div class="text-sm text-white/80 font-medium mt-1">{r!.name}</div>
              <div class="text-xs text-white/40 mt-0.5">{r!.games} games played</div>
            </div>
          ))}
        </div>

        <!-- Win/Loss/Draw Record -->
        <div class="border-t border-[var(--color-border)] pt-6">
          <h3 class="text-sm font-medium text-[var(--color-text-muted)] mb-4">Overall Record</h3>
          <div class="grid grid-cols-3 gap-6 mb-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-emerald-400">{wins}</div>
              <div class="text-xs text-white/40">Wins</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white/50">{draws}</div>
              <div class="text-xs text-white/40">Draws</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-red-400">{losses}</div>
              <div class="text-xs text-white/40">Losses</div>
            </div>
          </div>
          <!-- Win rate bar -->
          <div class="flex items-center gap-3">
            <span class="text-xs font-semibold text-[var(--color-primary)] w-16 text-right">{winRate}%</span>
            <div class="flex-1 h-2 rounded-full overflow-hidden bg-white/5 flex">
              <div class="h-full bg-emerald-400/80 transition-all" style={`width: ${(wins/totalGames)*100}%`}></div>
              <div class="h-full bg-white/20 transition-all" style={`width: ${(draws/totalGames)*100}%`}></div>
              <div class="h-full bg-red-400/60 transition-all" style={`width: ${(losses/totalGames)*100}%`}></div>
            </div>
          </div>
          <div class="text-xs text-white/30 mt-3 text-center">{totalGames} total games played</div>
        </div>
      </div>
    )}

    <!-- Steam Recent Games -->
    {steamRecent.length > 0 && (
      <div class="mb-12">
        <h2 class="text-xl font-bold text-white mb-6">Recently Played on Steam</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {steamRecent.slice(0, 4).map((game: any) => (
            <div class="glass-strong overflow-hidden rounded-xl border border-white/5 group hover:border-white/20 transition-colors">
              <div class="h-24 bg-cover bg-center" style={`background-image: url('${game.logoUrl}')`}>
                <div class="w-full h-full bg-gradient-to-t from-[#111] to-transparent"></div>
              </div>
              <div class="p-4 relative">
                {game.iconUrl && (
                  <img src={game.iconUrl} alt={game.name} class="w-8 h-8 rounded absolute -top-4 right-4 shadow-lg border border-white/10" />
                )}
                <h3 class="font-semibold text-sm text-white truncate pr-10">{game.name}</h3>
                <p class="text-xs text-[var(--color-accent-primary)] font-medium mt-1">{game.playtimeHours} hrs combined</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Gaming Stats Counter Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="glass p-6 text-center"><StatsCounter client:visible value={totalGames} label="Chess Games" icon="♟️" /></div>
      <div class="glass p-6 text-center"><StatsCounter client:visible value={wins} label="Wins" icon="🏆" /></div>
      <div class="glass p-6 text-center"><StatsCounter client:visible value={steamGames.length} label="Steam Games" icon="🖥️" /></div>
      <div class="glass p-6 text-center"><StatsCounter client:visible value={chessPlatforms.length} label="Platforms" icon="🎮" /></div>
    </div>

    <!-- Gaming Platforms -->
    <h2 class="text-xl font-bold text-white mb-6">Gaming Platforms</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {chessPlatforms.map((p) => (
        <div class="glass p-6 border border-white/5 hover:border-white/10 transition-colors">
          <span class="text-3xl mb-4 block drop-shadow-sm">{p.icon}</span>
          <h3 class="text-lg font-semibold text-white mb-1 group-hover:text-[var(--color-accent-violet)] transition-colors">{p.name}</h3>
          <p class="text-sm text-[var(--color-primary)] font-medium mb-3">{p.handle}</p>
          <p class="text-sm text-white/50 leading-relaxed">{p.description}</p>
        </div>
      ))}
    </div>

    <!-- Source note -->
    <div class="glass p-6 flex items-center gap-4 border border-white/5">
      <div class="h-10 w-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0">
        <svg class="h-5 w-5 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-white font-medium">Data fetched via Build-Time Orchestrator</p>
        <p class="text-xs text-[var(--color-text-muted)] mt-0.5">Lichess and Steam metrics automatically cached during site build to guarantee performance.</p>
      </div>
    </div>

  </main>
  <Footer />
</Layout>
