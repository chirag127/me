---
import '../styles/tokens.css';
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import AuthBanner from '../components/islands/AuthBanner';
import ChatWrapper from '../components/islands/ChatWrapper';
import CookieBanner from '../components/islands/CookieBanner';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Hide sidebar on specific pages (e.g. landing) */
  fullWidth?: boolean;
}

const {
  title,
  description =
    'Chirag Singhal — Software Engineer & ' +
    'AI Specialist building scalable systems, ' +
    'intelligent agents & cloud-native solutions.',
  ogImage,
  fullWidth = false,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  'https://me.oriz.in',
);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030303" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />

    <!-- Open Graph -->
    <meta
      property="og:title"
      content={`Chirag Singhal — ${title}`}
    />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && (
      <meta property="og:image" content={ogImage} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={`Chirag Singhal — ${title}`}
    />
    <meta
      name="twitter:description"
      content={description}
    />

    <!-- Fonts — preload critical weights -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="dns-prefetch"
      href="https://js.puter.com"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Puter.js for AI features (deferred) -->
    <script src="https://js.puter.com/v2/" is:inline defer
    ></script>

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Chirag Singhal',
        url: 'https://me.oriz.in',
        email: 'hi@chirag127.in',
        jobTitle: 'Software Engineer & AI Specialist',
        worksFor: {
          '@type': 'Organization',
          name: 'Tata Consultancy Services',
        },
        sameAs: [
          'https://github.com/chirag127',
          'https://linkedin.com/in/chirag127',
          'https://dev.to/chirag127',
          'https://bsky.app/profile/chirag127.bsky.social',
        ],
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Bhubaneswar',
          addressRegion: 'Odisha',
          addressCountry: 'India',
        },
      })}
    />

    <title>Chirag Singhal — {title}</title>

    <!-- Theme script — prevents flash -->
    <script is:inline>
      (function () {
        const theme =
          localStorage.getItem('theme') || 'dark';
        document.documentElement.classList.remove(
          'light',
          'dark',
        );
        document.documentElement.classList.add(theme);
      })();
    </script>
  </head>
  <body
    class="min-h-screen bg-[var(--surface-base,#030303)]
      text-[var(--text-primary,#fff)] antialiased"
  >
    <!-- Skip to content (a11y) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed
        focus:top-4 focus:left-4 focus:z-[60]
        focus:px-4 focus:py-2 focus:rounded-lg
        focus:bg-teal-500 focus:text-white
        focus:outline-none"
    >
      Skip to main content
    </a>

    <AuthBanner client:load />

    <div id="app" class="flex min-h-screen">
      <!-- Sidebar (hidden on fullWidth pages) -->
      {!fullWidth && <Sidebar />}

      <!-- Main content area -->
      <div
        class:list={[
          'flex flex-col flex-1 min-h-screen',
          !fullWidth && 'lg:ml-[var(--sidebar-width,240px)]',
        ]}
      >
        <!-- Top header bar -->
        <header
          class="sticky top-0 z-30 flex items-center
            justify-between px-4 sm:px-6
            h-[var(--header-height,56px)]
            bg-[var(--surface-base,#030303)]/80
            backdrop-blur-xl
            border-b border-[var(--border-subtle)]"
        >
          <!-- Mobile hamburger -->
          <button
            id="sidebar-toggle"
            class="lg:hidden flex items-center
              justify-center h-9 w-9 rounded-lg
              text-white/50 hover:text-white
              hover:bg-white/5 transition-colors"
            aria-label="Open navigation"
            type="button"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          <!-- Page title -->
          <h1
            class="text-sm font-medium text-white/60
              hidden sm:block"
            style="font-family: var(--font-sans);"
          >
            {title}
          </h1>

          <!-- Right side CTAs -->
          <div class="flex items-center gap-2">
            <!-- Hire Me CTA -->
            <a
              href="/connect"
              class="hidden sm:inline-flex items-center
                gap-2 px-4 py-1.5 rounded-full
                text-xs font-semibold
                bg-gradient-to-r from-teal-500
                to-violet-500
                text-white shadow-lg
                hover:shadow-teal-500/25
                transition-all duration-300
                hover:scale-[1.02]"
            >
              <span class="h-1.5 w-1.5 rounded-full
                bg-white animate-pulse"></span>
              Hire Me
            </a>

            <!-- Command palette trigger -->
            <button
              id="cmd-palette-btn"
              class="flex items-center gap-1.5 px-3
                py-1.5 rounded-lg border
                border-[var(--border-default)]
                text-xs text-white/40
                hover:text-white/60
                hover:border-[var(--border-hover)]
                transition-colors"
              type="button"
              title="Search (⌘K)"
            >
              <svg
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
              <span class="hidden sm:inline">⌘K</span>
            </button>
          </div>
        </header>

        <!-- Main content -->
        <main
          id="main-content"
          class="flex-1"
          role="main"
        >
          <slot />
        </main>

        <!-- Footer -->
        <footer
          class="border-t
            border-[var(--border-subtle)]
            py-8 px-6"
        >
          <div class="max-w-[var(--content-max-width)]
            mx-auto flex flex-col sm:flex-row
            items-center justify-between gap-4">
            <p class="text-xs text-white/25">
              &copy; {new Date().getFullYear()} Chirag
              Singhal. Built with Astro + React.
            </p>
            <div class="flex items-center gap-4">
              <a
                href="/legal/privacy"
                class="text-xs text-white/25
                  hover:text-white/50 transition-colors"
              >
                Privacy
              </a>
              <a
                href="/legal/terms"
                class="text-xs text-white/25
                  hover:text-white/50 transition-colors"
              >
                Terms
              </a>
              <a
                href="https://github.com/chirag127"
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-white/25
                  hover:text-white/50 transition-colors"
              >
                GitHub
              </a>
            </div>
          </div>
        </footer>
      </div>
    </div>

    <ChatWrapper client:load />
    <CookieBanner client:load />

    <!-- Scroll-triggered reveal animations -->
    <script is:inline>
      (function () {
        const obs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                obs.unobserve(e.target);
              }
            });
          },
          {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px',
          },
        );
        function observe() {
          document
            .querySelectorAll(
              '.reveal,.reveal-left,' +
                '.reveal-scale,.reveal-stagger',
            )
            .forEach(function (el) {
              obs.observe(el);
            });
        }
        if (document.readyState === 'loading') {
          document.addEventListener(
            'DOMContentLoaded',
            observe,
          );
        } else {
          observe();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
