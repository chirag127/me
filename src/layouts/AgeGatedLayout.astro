---
import Layout from './Layout.astro';
import AgeGate from '../components/islands/AgeGate';

/**
 * AgeGatedLayout — Wrapper for pages that surface adult-content rows.
 *
 * Use this in place of Layout.astro for any page that *might* render an
 * `age-gated-18` event row. The gate guards the listing page itself, not
 * just per-item detail views — otherwise poster/cover thumbnails would
 * leak before the visitor confirms.
 *
 * Behaviour:
 *
 * - Renders the standard chrome via Layout.astro.
 * - Adds `<meta name="rating" content="adult">` to head (RTA / SafeSurf).
 * - Adds `<meta name="robots" content="noindex">` so search engines don't
 *   surface the page and link previews don't leak content.
 * - Tags the gated wrapper with `data-oriz-age-gate="required"` so analytics
 *   and chrome can detect a gated page without URL pattern matching.
 * - Wraps the page slot in <AgeGate client:only="react"> so the SSR HTML
 *   for a non-attested visitor contains only the gate prompt — never the
 *   gated children.
 *
 * Policy: knowledge/decisions/age-gating-policy.md
 */

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  fullWidth?: boolean;
  /** Short label for the gate copy, e.g. 'Anime tracking' / 'Films'. */
  contentLabel: string;
  /** Where 'I'm not 18' sends the visitor. Defaults to '/library/'. */
  declinePath?: string;
}

const {
  title,
  description,
  ogImage,
  fullWidth = false,
  contentLabel,
  declinePath = '/library/',
} = Astro.props;

// exactOptionalPropertyTypes: don't pass undefined explicitly to Layout —
// build only the keys that are actually set.
const layoutProps = {
  title,
  fullWidth,
  ...(description !== undefined ? { description } : {}),
  ...(ogImage !== undefined ? { ogImage } : {}),
};
---

<Layout {...layoutProps}>
  <Fragment slot="head">
    <meta name="rating" content="adult" />
    <meta name="robots" content="noindex" />
  </Fragment>

  <div data-oriz-age-gate="required">
    <AgeGate
      client:only="react"
      minimumAge={18}
      contentLabel={contentLabel}
      declinePath={declinePath}
    >
      <slot />
    </AgeGate>
  </div>
</Layout>
