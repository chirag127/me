---
/**
 * BaseLayout — thin wrapper around @chirag127/astro-shell's Base.
 *
 * The shell handles <head>, theme tokens, and named slots (head, seo,
 * analytics, consent, header, footer). We just import its global
 * stylesheet here so every page gets Tailwind v4 + the family theme
 * tokens.
 *
 * TODO(astro-chrome): when @chirag127/astro-chrome ships, mount its
 * <Header />, <Footer />, <Analytics />, <Consent />, and <Auth />
 * components into the shell's named slots from this file.
 */
import Base from "@chirag127/astro-shell/layouts/Base.astro";
import Layout from "@chirag127/astro-chrome/Layout.astro";
import "../styles.css";

export type Props = Parameters<typeof Base>[0];
const props = Astro.props;
const bottomBarActions = [
  { icon: '⌂', label: 'Home', href: 'https://oriz.in/' },
  { icon: '✎', label: 'Blog', href: 'https://blog.oriz.in/' },
  { icon: '⚒', label: 'Tools', href: 'https://oriz.in/tools/' },
  { icon: 'ℹ', label: 'About', href: '/' },
]
import '@chirag127/astro-shell/tokens.css'
---

<Base {...props}>
	<slot name="head" slot="head" />
	<slot name="seo" slot="seo" />
	<Layout bottomBarActions={bottomBarActions}>
		<slot />
	</Layout>
	<slot name="footer" slot="footer" />
</Base>
