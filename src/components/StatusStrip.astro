---
// Server-side: nothing to fetch (the data is dynamic, fetched client-side
// from /api/now so build artefacts stay static + cacheable).
---

<aside
  id="status-strip"
  class="flex flex-wrap items-center gap-4 sm:gap-6 px-4 py-3
         rounded-xl border border-[var(--border-subtle)]
         bg-[var(--surface-card)] text-xs"
  aria-label="Live status"
>
  <!-- Presence -->
  <div class="flex items-center gap-2 min-w-0">
    <span
      id="status-presence-dot"
      class="h-2 w-2 rounded-full bg-[var(--text-faint)] flex-shrink-0"
      aria-hidden="true"
    ></span>
    <span
      id="status-presence-label"
      class="text-[var(--text-secondary)] truncate"
    >
      Loading presence…
    </span>
  </div>

  <span class="text-[var(--text-faint)] hidden sm:inline" aria-hidden="true">·</span>

  <!-- Now playing -->
  <div class="flex items-center gap-2 min-w-0">
    <span aria-hidden="true">🎵</span>
    <span
      id="status-track-label"
      class="text-[var(--text-secondary)] truncate"
    >
      Loading track…
    </span>
  </div>

  <span class="text-[var(--text-faint)] hidden sm:inline" aria-hidden="true">·</span>

  <!-- Weather -->
  <div class="flex items-center gap-2 min-w-0">
    <span aria-hidden="true">🌤️</span>
    <span
      id="status-weather-label"
      class="text-[var(--text-secondary)] truncate"
    >
      Loading weather…
    </span>
  </div>
</aside>

<script is:inline>
(function () {
  // Hydration: swap skeleton text for live data when /api/now responds.
  // Falls back silently if the endpoint is unreachable (still in dev).
  fetch('/api/now', { headers: { Accept: 'application/json' } })
    .then((r) => (r.ok ? r.json() : null))
    .then((data) => {
      if (!data) return;
      var presence = data.presence || {};
      var track    = data.track    || null;
      var weather  = data.weather  || null;

      var dot = document.getElementById('status-presence-dot');
      var presenceLabel = document.getElementById('status-presence-label');
      if (dot && presenceLabel) {
        var color = '#52525e';
        if (presence.status === 'online')  color = '#10b981';
        if (presence.status === 'idle')    color = '#f59e0b';
        if (presence.status === 'dnd')     color = '#f43f5e';
        if (presence.status === 'offline') color = '#52525e';
        dot.style.background = color;
        presenceLabel.textContent = presence.label || 'Offline';
      }

      var trackLabel = document.getElementById('status-track-label');
      if (trackLabel) {
        if (track && track.title) {
          trackLabel.textContent = track.artist
            ? track.title + ' — ' + track.artist
            : track.title;
        } else {
          trackLabel.textContent = 'Not listening right now';
        }
      }

      var weatherLabel = document.getElementById('status-weather-label');
      if (weatherLabel) {
        if (weather && weather.temp != null) {
          weatherLabel.textContent =
            weather.location + ' · ' + Math.round(weather.temp) + '°' +
            (weather.unit || 'C');
        } else {
          weatherLabel.textContent = 'Bhubaneswar';
        }
      }
    })
    .catch(function () {
      // Silently degrade — leave the skeleton labels in place but mark them
      // as unavailable.
      var ids = ['status-presence-label', 'status-track-label', 'status-weather-label'];
      for (var i = 0; i < ids.length; i++) {
        var el = document.getElementById(ids[i]);
        if (el) el.textContent = '—';
      }
    });
})();
</script>
