          </a>
          <a href="https://linkedin.com/in/chirag127" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="mailto:hi@chirag127.in" class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
          <a href="https://bsky.app/profile/chirag127.bsky.social" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.588 3.476 6.15 3.226-3.984.664-7.418 2.648-2.976 8.527 4.726 5.632 6.76-1.564 8.202-5.633 1.443 4.069 3.476 11.265 8.202 5.633 4.442-5.879.008-7.863-2.976-8.527 2.562.25 5.365-.6 6.15-3.226C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.861-.902-2.203-.66-.3-1.664-.621-4.3 1.24C16.046 4.747 13.087 8.686 12 10.8z"/></svg>
          </a>
        </div>
      </div>

      <!-- Explore -->
      <div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Explore</h3>
        <ul class="space-y-2">
          <li><a href="/work" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Work</a></li>
          <li><a href="/code" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Code</a></li>
          <li><a href="/library" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Library</a></li>
          <li><a href="/gaming" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Gaming</a></li>
          <li><a href="/me" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Me</a></li>
          <li><a href="/me/gear" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Gear</a></li>
        </ul>
      </div>

      <!-- Library -->
      <div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Library</h3>
        <ul class="space-y-2">
          <li><a href="/library/movies" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Movies</a></li>
          <li><a href="/library/anime" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Anime</a></li>
          <li><a href="/library/books" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Books</a></li>
          <li><a href="/library/music" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Music</a></li>
          <li><a href="/library/manga" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Manga</a></li>
          <li><a href="/library/videos" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Videos</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Connect</h3>
        <ul class="space-y-2">
          <li><a href="/connect" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">All Platforms</a></li>
          <li><a href="/connect/contact" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Contact</a></li>
          <li><a href="https://github.com/chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">GitHub ↗</a></li>
          <li><a href="https://dev.to/chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">Dev.to ↗</a></li>
          <li><a href="https://leetcode.com/chirag127" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-text-muted)] hover:text-amber-400 transition-colors">LeetCode ↗</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-[var(--color-border)] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[var(--color-text-muted)]">
        © {year} Chirag Singhal. Built with Astro, React, Tailwind CSS, and Puter.js.
      </p>
      <div class="flex items-center gap-4">
        <a href="/system/changelog" class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] hover:text-amber-400 transition-colors font-medium">
          Changelog
        </a>
        <a href="/system/admin" class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] hover:text-amber-400 transition-colors font-medium">
          Admin
        </a>
      </div>
    </div>
  </div>
</footer>
