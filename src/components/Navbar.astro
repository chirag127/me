---
import AuthWidget from './islands/AuthWidget';

const currentPath = Astro.url.pathname;

const navLinks = [
  { name: 'Home', path: '/' },
  { 
    name: 'Work', 
    path: '/work',
    children: [
      { name: 'Career', path: '/work/career' },
      { name: 'Skills', path: '/work/skills' },
      { name: 'Projects', path: '/work/projects' },
      { name: 'Education', path: '/work/education' },
      { name: 'Certifications', path: '/work/certifications' },
    ]
  },
  { 
    name: 'Code', 
    path: '/code',
    children: [
      { name: 'Dashboard', path: '/code' },
      { name: 'Repositories', path: '/code/repos' },
      { name: 'NPM', path: '/code/npm' },
      { name: 'StackOverflow', path: '/code/stackoverflow' },
      { name: 'Holopin', path: '/code/holopin' },
    ]
  },
  { 
    name: 'Library', 
    path: '/library',
    children: [
      { name: 'Movies', path: '/library/movies' },
      { name: 'Anime', path: '/library/anime' },
      { name: 'Manga', path: '/library/manga' },
      { name: 'Books', path: '/library/books' },
      { name: 'Music', path: '/library/music' },
      { name: 'Videos', path: '/library/videos' },
      { name: 'Podcasts', path: '/library/podcasts' },
    ]
  },
  { name: 'Gaming', path: '/gaming' },
  { 
    name: 'Me', 
    path: '/me',
    children: [
      { name: 'Story', path: '/me/story' },
      { name: 'Philosophy', path: '/me/philosophy' },
      { name: 'Interests', path: '/me/interests' },
      { name: 'Gear', path: '/me/gear' },
      { name: 'Journal', path: '/me/journal' },
      { name: 'Finance', path: '/me/finance' },
    ]
  },
  { name: 'Connect', path: '/connect' },
];

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(`${path}/`) || currentPath === path;
}
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/80 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-amber-400 to-orange-500 text-white font-bold text-sm transition-transform group-hover:scale-110" style="font-family: 'Outfit', sans-serif;">
          CS
        </div>
        <span class="text-lg font-bold tracking-tight text-[var(--color-text-primary)] hidden sm:inline" style="font-family: 'Outfit', sans-serif;">
          Chirag Singhal
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <div class="relative group/nav">
            <a
              href={link.path}
              class:list={[
                "relative px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 inline-flex items-center gap-1",
                isActive(link.path)
                  ? "text-amber-400 bg-amber-400/10"
                  : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-white/5"
              ]}
            >
              {link.name}
              {link.children && (
                <svg class="h-3 w-3 opacity-50 transition-transform group-hover/nav:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              )}
              {isActive(link.path) && !link.children && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-6 rounded-full bg-amber-400" />
              )}
            </a>
            {link.children && (
              <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200">
                <div class="w-48 rounded-xl bg-[#12121e]/95 backdrop-blur-xl border border-white/10 shadow-2xl overflow-hidden py-1">
                  {link.children.map((child) => (
                    <a
                      href={child.path}
                      class:list={[
                        "block px-4 py-2 text-sm transition-colors",
                        isActive(child.path)
                          ? "text-amber-400 bg-amber-400/5"
                          : "text-white/60 hover:text-white hover:bg-white/5"
                      ]}
                    >
                      {child.name}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Auth Widget (Desktop) -->
        <div class="hidden md:block">
          <AuthWidget client:only="react" />
        </div>

        <div class="h-4 w-px bg-[var(--color-border)] mx-1 hidden md:block"></div>

        <!-- Command Palette Trigger -->
        <button
          id="cmd-trigger"
          class="flex items-center gap-2 px-3 py-1.5 text-sm text-[var(--color-text-muted)] rounded-lg border border-[var(--color-border)] hover:border-[var(--color-border-active)] hover:text-[var(--color-text-secondary)] transition-all"
          onclick="document.getElementById('command-palette')?.classList.remove('hidden')"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <kbd class="hidden sm:inline-flex items-center gap-1 rounded border border-[var(--color-border)] px-1.5 py-0.5 text-xs font-mono">
            <span class="text-xs">⌘</span>K
          </kbd>
        </button>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center h-9 w-9 rounded-lg border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
          onclick="document.getElementById('mobile-menu')?.classList.toggle('hidden')"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur-xl max-h-[80vh] overflow-y-auto">
    <div class="px-4 py-3 space-y-4">
      <div class="space-y-1">
        {navLinks.map((link) => (
          <div>
            <a
              href={link.path}
              class:list={[
                "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-all",
                isActive(link.path)
                  ? "text-amber-400 bg-amber-400/10"
                  : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-white/5"
              ]}
            >
              {link.name}
            </a>
            {link.children && (
              <div class="ml-4 space-y-0.5 mt-1">
                {link.children.map((child) => (
                  <a
                    href={child.path}
                    class:list={[
                      "block px-3 py-1.5 rounded-lg text-xs transition-all",
                      isActive(child.path)
                        ? "text-amber-400 bg-amber-400/5"
                        : "text-white/40 hover:text-white/70 hover:bg-white/5"
                    ]}
                  >
                    {child.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
      <div class="pt-2 border-t border-[var(--color-border)]">
        <AuthWidget client:only="react" />
      </div>
    </div>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-16"></div>

<script is:inline>
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('command-palette')?.classList.toggle('hidden');
    }
    if (e.key === 'Escape') {
      document.getElementById('command-palette')?.classList.add('hidden');
      document.getElementById('mobile-menu')?.classList.add('hidden');
    }
  });
</script>
