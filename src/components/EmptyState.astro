---
interface Props {
  /** Big emoji displayed above the message — friendly, themed. */
  emoji?: string;
  /** Title (1 line). */
  title: string;
  /** Body explaining why and what to do (1–3 sentences). */
  message: string;
  /** Optional CTA. */
  actionLabel?: string;
  actionHref?: string;
}

const { emoji = '📭', title, message, actionLabel, actionHref } = Astro.props;
---

<div
  class="my-8 mx-auto max-w-md text-center px-6 py-10
         rounded-2xl border border-[var(--border-default)]
         bg-[var(--surface-card)]"
  role="status"
>
  <div class="text-5xl mb-4 opacity-80" aria-hidden="true">{emoji}</div>
  <h3
    class="text-base font-semibold text-[var(--text-primary)] mb-1.5"
    style="font-family: var(--font-display, 'Outfit');"
  >
    {title}
  </h3>
  <p class="text-sm text-[var(--text-tertiary)] leading-relaxed">
    {message}
  </p>
  {actionLabel && actionHref && (
    <a
      href={actionHref}
      class="inline-flex items-center gap-1.5 mt-5 px-4 py-1.5 rounded-lg
             border border-[var(--primary-subtle)]
             text-xs font-semibold text-[var(--primary-light)]
             hover:bg-[var(--primary-faint)]
             transition-colors"
    >
      {actionLabel}
      <span aria-hidden="true">→</span>
    </a>
  )}
</div>
