---
interface Props {
  /** Section label, displayed inside a small pill above the title (e.g. "WORK", "LIBRARY"). Auto-uppercased. */
  section: string;
  /** Optional emoji rendered before the section pill text — adds personality. */
  emoji?: string;
  /** Big H1. */
  title: string;
  /** One-line subtitle / description rendered under the title in muted text. */
  description: string;
  /** Optional accent color override — defaults to the user's --primary token. */
  accent?: 'primary' | 'emerald' | 'amber' | 'rose' | 'sky';
}

const { section, emoji, title, description, accent = 'primary' } = Astro.props;
// `accent` reserved for future use — currently all variants render against --primary.
void accent;
---

<header class="mb-10 relative reveal">
  <div class:list={[
    'inline-flex items-center gap-2 px-3 py-1.5 rounded-full',
    'bg-[var(--primary-faint)] border border-[var(--primary-subtle)]',
    'text-[11px] font-semibold text-[var(--primary-light)] uppercase tracking-wider mb-5',
  ]}>
    <span class="h-1.5 w-1.5 rounded-full bg-[var(--primary-light)] animate-pulse"></span>
    {emoji && <span aria-hidden="true">{emoji}</span>}
    {section}
  </div>
  <h1
    class="text-3xl sm:text-4xl font-black text-[var(--text-primary)] mb-2"
    style="font-family: var(--font-display, 'Outfit');"
  >
    {title}
  </h1>
  <p class="text-base text-[var(--text-tertiary)] max-w-2xl">
    {description}
  </p>
</header>
