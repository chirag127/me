---
/**
 * Sidebar Navigation — Desktop persistent, mobile overlay.
 * Desktop ≥1024px: 240px, collapsible to 64px icon-only.
 * Tablet 768–1023px: 64px icon-only, expand on hover.
 * Mobile <768px: hidden, overlay via hamburger.
 */

const currentPath = Astro.url.pathname;

// Used directly in the template below
const navSections = [
  {
    name: 'Home',
    path: '/',
    icon: 'home',
    exact: true,
  },
  {
    name: 'Work',
    path: '/work',
    icon: 'briefcase',
    children: [
      { name: 'Career', path: '/work/career' },
      { name: 'Skills', path: '/work/skills' },
      { name: 'Projects', path: '/work/projects' },
      { name: 'Education', path: '/work/education' },
      { name: 'Certifications', path: '/work/certifications' },
    ],
  },
  {
    name: 'Code',
    path: '/code',
    icon: 'code',
    children: [
      { name: 'Dashboard', path: '/code' },
      { name: 'Repositories', path: '/code/repos' },
      { name: 'NPM', path: '/code/npm' },
      { name: 'StackOverflow', path: '/code/stackoverflow' },
    ],
  },
  {
    name: 'Library',
    path: '/library',
    icon: 'book-open',
    children: [
      { name: 'Movies', path: '/library/movies' },
      { name: 'TV Shows', path: '/library/shows' },
      { name: 'Anime', path: '/library/anime' },
      { name: 'Books', path: '/library/books' },
      { name: 'Music', path: '/library/music' },
      { name: 'Manga', path: '/library/manga' },
    ],
  },
  {
    name: 'Gaming',
    path: '/gaming',
    icon: 'gamepad-2',
  },
  {
    name: 'Me',
    path: '/me',
    icon: 'user',
    children: [
      { name: 'Story', path: '/me/story' },
      { name: 'Philosophy', path: '/me/philosophy' },
      { name: 'Interests', path: '/me/interests' },
      { name: 'Gear', path: '/me/gear' },
      { name: 'Journal', path: '/me/journal' },
      { name: 'Finance', path: '/me/finance' },
    ],
  },
  {
    name: 'Connect',
    path: '/connect',
    icon: 'link',
  },
  {
    name: 'System',
    path: '/system',
    icon: 'settings',
    children: [
      { name: 'Settings', path: '/system' },
      { name: 'Changelog', path: '/system/changelog' },
      { name: 'Admin', path: '/system/admin' },
    ],
  },
];

/**
 * Determines whether a nav item is active based on current path.
 * Uses exact match for root path, partial match for others.
 */
function isActive(
  path: string,
  exact?: boolean,
): boolean {
  if (exact) return currentPath === path;
  if (path === '/') return currentPath === '/';
  return (
    currentPath === path ||
    currentPath.startsWith(`${path}/`)
  );
}

/**
 * Map icon name to Lucide SVG path data.
 * Using inline SVGs to avoid extra dependencies.
 */
const iconPaths: Record<string, string> = {
  home: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10',
  briefcase: 'M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16 M2 10h20 M22 10v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z',
  code: 'M16 18l6-6-6-6 M8 6l-6 6 6 6',
  'book-open': 'M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z',
  'gamepad-2': 'M6 11h4 M8 9v4 M15 12h.01 M18 10h.01 M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z',
  user: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
  link: 'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71 M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71',
  settings: 'M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.39a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
};
---

<!-- Sidebar overlay (mobile) -->
<div
  id="sidebar-overlay"
  class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm
    opacity-0 pointer-events-none transition-opacity
    duration-300 lg:hidden"
  aria-hidden="true"
></div>

<aside
  id="sidebar"
  class="fixed top-0 left-0 z-50 h-full
    bg-[var(--surface-sidebar,rgba(10,10,14,0.95))]
    backdrop-blur-xl
    border-r border-[var(--border-default,rgba(255,255,255,0.07))]
    flex flex-col
    transition-all duration-300 ease-[var(--ease-out-expo)]
    -translate-x-full lg:translate-x-0
    w-[var(--sidebar-width,240px)]"
  role="navigation"
  aria-label="Main navigation"
>
  <!-- Logo -->
  <div class="flex items-center gap-3 px-5 h-14
    border-b border-[var(--border-subtle,rgba(255,255,255,0.04))]
    flex-shrink-0">
    <a href="/" class="flex items-center gap-3 group">
      <div class="flex h-8 w-8 items-center justify-center
        rounded-lg bg-gradient-to-br from-teal-400
        to-violet-500 text-white font-bold text-xs
        transition-transform group-hover:scale-110"
        style="font-family: var(--font-display, 'Outfit');">
        CS
      </div>
      <span class="sidebar-label text-sm font-bold
        tracking-tight text-white/90
        transition-opacity duration-200"
        style="font-family: var(--font-display, 'Outfit');">
        Chirag Singhal
      </span>
    </a>
  </div>

  <!-- Nav links -->
  <nav class="flex-1 overflow-y-auto py-4 px-3
    scrollbar-hidden" aria-label="Site sections">
    <ul class="space-y-1" role="list">
      {navSections.map((section) => {
        const active = isActive(section.path, section.exact);
        const iconPath = iconPaths[section.icon] || '';
        const hasChildren = section.children && section.children.length > 0;
        const childActive = hasChildren && section.children!.some(
          (c) => isActive(c.path),
        );

        return (
          <li>
            <a
              href={section.path}
              class:list={[
                'group flex items-center gap-3 px-3 py-2',
                'rounded-xl text-sm font-medium',
                'transition-all duration-200',
                active || childActive
                  ? 'bg-gradient-to-r from-teal-500/10 to-violet-500/10 text-white border border-teal-500/20'
                  : 'text-white/50 hover:text-white/80 hover:bg-white/[0.03] border border-transparent',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              <svg
                class:list={[
                  'h-[18px] w-[18px] flex-shrink-0',
                  'transition-colors duration-200',
                  active || childActive
                    ? 'text-teal-400'
                    : 'text-white/30 group-hover:text-white/60',
                ]}
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                {iconPath.split(' M').map((seg, i) => (
                  <path d={i === 0 ? seg : `M${seg}`} />
                ))}
              </svg>
              <span class="sidebar-label
                transition-opacity duration-200">
                {section.name}
              </span>
              {(active || childActive) && (
                <span class="ml-auto h-1.5 w-1.5
                  rounded-full bg-teal-400 animate-pulse
                  sidebar-label" />
              )}
            </a>

            {hasChildren && (active || childActive) && (
              <ul class="mt-1 ml-[30px] space-y-0.5
                border-l border-white/5 pl-3" role="list">
                {section.children!.map((child) => {
                  const cActive = isActive(child.path);
                  return (
                    <li>
                      <a
                        href={child.path}
                        class:list={[
                          'sidebar-label block py-1.5 px-2',
                          'rounded-lg text-xs font-medium',
                          'transition-all duration-150',
                          cActive
                            ? 'text-teal-300 bg-teal-500/5'
                            : 'text-white/35 hover:text-white/60 hover:bg-white/[0.02]',
                        ]}
                        aria-current={
                          cActive ? 'page' : undefined
                        }
                      >
                        {child.name}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </nav>

  <!-- Sidebar footer -->
  <div class="flex-shrink-0 px-3 py-3
    border-t border-[var(--border-subtle,rgba(255,255,255,0.04))]">
    <div class="flex items-center gap-2 px-3 py-2
      rounded-xl bg-emerald-500/5 border
      border-emerald-500/10">
      <span class="h-2 w-2 rounded-full bg-emerald-400
        animate-pulse flex-shrink-0"></span>
      <span class="sidebar-label text-[10px] font-semibold
        text-emerald-400/80 uppercase tracking-wider">
        Available for hire
      </span>
    </div>
  </div>
</aside>

<!-- Toggle script -->
<script is:inline>
  (function () {
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const btn = document.getElementById('sidebar-toggle');

    function openSidebar() {
      if (!sidebar || !overlay) return;
      sidebar.classList.remove('-translate-x-full');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      if (!sidebar || !overlay) return;
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100');
      document.body.style.overflow = '';
    }

    if (btn) btn.addEventListener('click', openSidebar);
    if (overlay) overlay.addEventListener('click', closeSidebar);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeSidebar();
    });

    // Expose for external use
    window.__sidebar = { open: openSidebar, close: closeSidebar };
  })();
</script>

<style>
  /* Collapsed state for sidebar-label elements */
  @media (min-width: 1024px) {
    aside#sidebar {
      width: var(--sidebar-width, 240px);
    }
  }

  /* Scrollbar hidden utility */
  .scrollbar-hidden::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hidden {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
