rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'whyiswhen@gmail.com' || 
        request.auth.token.email == 'chirag127.in@gmail.com'
      );
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }
    
    function isValidUserData() {
      let data = request.resource.data;
      return data.userId == request.auth.uid
          && data.userEmail is string
          && data.userEmail == request.auth.token.email
          && data.userName is string
          && data.userName.size() > 0
          && data.userName.size() <= 100;
    }
    
    function isValidChatMessage() {
      let data = request.resource.data;
      return data.userId == request.auth.uid
          && data.userEmail is string
          && data.userEmail == request.auth.token.email
          && data.userName is string
          && data.message is string
          && data.message.size() > 0
          && data.message.size() <= 10000;
    }
    
    function isValidChatSession() {
      let data = request.resource.data;
      return data.userId == request.auth.uid
          && data.title is string
          && data.title.size() > 0
          && data.title.size() <= 200
          && data.messages is list;
    }
    
    function isValidJournalEntry() {
      let data = request.resource.data;
      return data.userId == request.auth.uid
          && data.userEmail is string
          && data.userEmail == request.auth.token.email
          && data.text is string
          && data.text.size() > 0
          && data.text.size() <= 50000;
    }
    
    function isValidUserSettings() {
      let data = request.resource.data;
      return data.userId == request.auth.uid
          && data.userEmail is string
          && data.userEmail == request.auth.token.email
          && data.displayName is string
          && data.createdAt is string
          && (data.notifications == null || data.notifications is bool)
          && (data.theme == null || data.theme is string)
          && (data.language == null || data.language is string);
    }

    // ======================
    // USER PROFILE COLLECTION
    // ======================
    match /users/{userId} {
      // Anyone can read user profiles (for display purposes)
      // Users can read their own profile
      // Admins can read all user profiles
      allow read: if isOwner(userId) || isAdmin();
      
      // Only the owner can create/update their own profile
      allow create: if isOwner(userId) && isValidUserData();
      allow update: if isOwner(userId) && isValidUserData();
      
      // Only admins can delete user profiles
      allow delete: if isAdmin();
    }
    
    // ======================
    // USER SETTINGS COLLECTION
    // ======================
    match /userSettings/{userId} {
      // Users can read their own settings
      // Admins can read all user settings
      allow read: if isOwner(userId) || isAdmin();
      
      // Only owner can create/update their own settings
      allow create: if isOwner(userId) && isValidUserSettings();
      allow update: if isOwner(userId) && isValidUserSettings();
      
      // Only admins can delete user settings
      allow delete: if isAdmin();
    }
    
    // ======================
    // CHAT MESSAGES COLLECTION
    // ======================
    match /chatMessages/{messageId} {
      // Anyone can read chat messages (public chat)
      // Users can read all messages for chat history
      allow read: if isSignedIn();
      
      // Only authenticated users can create chat messages
      // Must be owner of the message (userId matches auth.uid)
      allow create: if isSignedIn() && isValidChatMessage();
      
      // Only the message owner or admin can update/delete
      allow update: if isSignedIn() 
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() 
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // ======================
    // CHAT SESSIONS COLLECTION
    // ======================
    match /chatSessions/{sessionId} {
      // Users can read their own chat sessions
      // Admins can read all chat sessions
      allow read: if isOwnerOrAdmin(resource.data.userId);
      
      // Only the owner can create chat sessions
      allow create: if isSignedIn() && isValidChatSession();
      
      // Only the owner can update their own sessions
      allow update: if isOwner(resource.data.userId) 
        && request.resource.data.userId == resource.data.userId;
      
      // Only the owner or admin can delete sessions
      allow delete: if isOwnerOrAdmin(resource.data.userId);
    }
    
    // ======================
    // JOURNAL ENTRIES COLLECTION
    // ======================
    match /journalEntries/{entryId} {
      // Users can read their own journal entries
      // Admins can read all journal entries (for moderation)
      allow read: if isOwnerOrAdmin(resource.data.userId);
      
      // Only the owner can create journal entries
      allow create: if isOwner(request.resource.data.userId) && isValidJournalEntry();
      
      // Only the owner can update their own entries
      allow update: if isOwner(resource.data.userId);
      
      // Only the owner or admin can delete entries
      allow delete: if isOwnerOrAdmin(resource.data.userId);
    }
    
    // ======================
    // USER DATA (General user-specific data)
    // ======================
    match /userData/{userId} {
      // Users can read their own data
      // Admins can read all user data
      allow read: if isOwnerOrAdmin(userId);
      
      // Only owner can create/update their own data
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      
      // Only admins can delete user data
      allow delete: if isAdmin();
    }
    
    // ======================
    // ADMIN COLLECTION (Admin-only data)
    // ======================
    match /admin/{documentId} {
      // Only admins can access admin collection
      allow read, write: if isAdmin();
    }
    
    // ======================
    // USER PREFERENCES COLLECTION
    // ======================
    match /userPreferences/{userId} {
      // Users can read their own preferences
      // Admins can read all preferences
      allow read: if isOwnerOrAdmin(userId);
      
      // Only owner can create/update preferences
      allow create, update: if isOwner(userId);
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // ======================
    // NOTIFICATIONS COLLECTION
    // ======================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      // Admins can read all notifications
      allow read: if isOwnerOrAdmin(resource.data.userId);
      
      // Only owner can create their own notifications
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && (request.resource.data.message == null || request.resource.data.message is string)
        && (request.resource.data.read == null || request.resource.data.read is bool)
        && (request.resource.data.createdAt == null || request.resource.data.createdAt is string);
      
      // Only owner can update their own notifications (mark as read)
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
      
      // Only owner or admin can delete notifications
      allow delete: if isOwnerOrAdmin(resource.data.userId);
    }
    
    // ======================
    // ANALYTICS COLLECTION (Read-only for users, write for system)
    // ======================
    match /analytics/{documentId} {
      // Everyone can read analytics data (if public)
      // Admins can read all analytics
      allow read: if isAdmin();
      
      // Only system/service accounts can write analytics (no client writes)
      allow write: if false;
    }
    
    // ======================
    // AI CHATS COLLECTION
    // ======================
    match /aiChats/{chatId} {
      // Admins can read/write all AI chats
      allow read, write: if isAdmin();
      
      // Users can create their own AI chats
      allow create: if isSignedIn();
      
      // Users can read/update their own AI chats
      allow read, update: if isSignedIn() 
        && (resource == null || resource.data.userId == request.auth.uid);
    }
    
    // ======================
    // AI QUERIES COLLECTION
    // ======================
    match /aiQueries/{queryId} {
      // Only admins can access all queries
      allow read, write: if isAdmin();
      
      // Users can create queries (when interacting with AI)
      allow create: if isSignedIn();
    }
    
    // ======================
    // UNKNOWN QUERIES COLLECTION
    // ======================
    match /unknownQueries/{queryId} {
      // Admins can read/write all unknown queries
      allow read, write: if isAdmin();
      
      // System/Users can create unknown queries for review
      allow create: if isSignedIn();
    }
    
    // ======================
    // VISITORS COLLECTION
    // ======================
    match /visitors/{visitorId} {
      // Admins can read/write all visitor data
      allow read, write: if isAdmin();
      
      // Users can create/update their own visitor record
      allow create: if isSignedIn();
      allow update: if isSignedIn() 
        && (resource.data.userId == request.auth.uid);
    }
    
    // ======================
    // FEEDBACK COLLECTION
    // ======================
    match /feedback/{feedbackId} {
      // Admins can read/write all feedback
      allow read, write: if isAdmin();
      
      // Users can create feedback
      allow create: if isSignedIn();
    }
    
    // ======================
    // MEDIA COLLECTION (Cached data)
    // ======================
    match /media/{categoryId} {
      // Everyone can read media data
      allow read: if true;
      
      // Only admins can update media data
      allow write: if isAdmin();
    }
    
    // ======================
    // FALLBACK RULE
    // Deny all other access by default
    // ======================
    match /{documentId=**} {
      allow read, write: if false;
    }
  }
}